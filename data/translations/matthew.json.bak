{
  "book": "Matthew",
  "slug": "matthew",
  "chapters": [
    {
      "chapter": 0,
      "verses": [
        {
          "verse": 0,
          "original": "κατα μαθθαιον",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 1,
      "verses": [
        {
          "verse": 1,
          "original": "βιβλοϲ γενεϲεωϲ ιυ χυ · ὑϊου δα δ ὑϊου αβρααμʼ",
          "translation": "The book of the genealogy of Jesus Christ, son of David, son of Abraham.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "αβρααμʼ ε γενʼνηϲεν ‾̷‾ τον ϊ ϲακ · ιϲακ ϊϲαακ · ιϲαακ δε εγενʼνη ϲεν τον ϊακωβʼ · ϊα κωβʼ δε εγενʼνηϲ ε τον ϊουδαν · και τουϲ αδελφουϲ αυτου ·",
          "translation": "Abraham was the father of Isaac, Isaac the father of Jacob, Jacob the father of Judah and his brothers,",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ϊουδαϲ δε εγενʼνη ϲεν τον φαρεϲ · και τον ζαρα εκ τηϲ θα μαρʼ φαρεϲ δε εγενʼ νηϲεν τον εϲρωμ · εϲρωμʼ δε εγεννη ϲεν τον αραμʼ :",
          "translation": "Judah the father of Perez and Zerah by Tamar, Perez the father of Hezron, Hezron the father of Ram,",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "αραμʼ δε εγεννηϲεν τ ο αμιναδαβʼ ˙ αμινα δαμʼ δε εγεννηϲ ε τον νααϲϲων · να αϲϲων δε εγενʼνη ϲεν τον ϲαλμων ·",
          "translation": "Ram the father of Amminadab, Amminadab the father of Nahshon, Nahshon the father of Salmon,",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ϲαλμων δε εγεν νηϲεν τον βοεϲ εκ τηϲ ραχαβ βοεϲ δε εγεννηϲεν τον ϊωβηδ εκ τηϲ ρουθ : ϊωβηδ δε εγεννη ϲεν τον ϊεϲϲαι ·",
          "translation": "Salmon the father of Boaz by Rahab, Boaz the father of Obed by Ruth, Obed the father of Jesse,",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ϊεϲϲαι δε εγεννη ϲεν τον δα δ τον βαϲιλεα : δαυειδʼ δε ‾̷‾ εγεννηϲεν τον ϲαλομων ϲαλωμωνα εκ τηϲ του ουριου :",
          "translation": "Jesse the father of King David. David was the father of Solomon by the wife of Uriah,",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ϲολομων ϲα̣λωμων δε εγενʼ νηϲεν τον ροβο αμ · [2 chars] ροβοαμ δε εγεννηϲεν τον αβια · αβιαϲ αβια δε εγεν νηϲεν τον αϲαφ ˙",
          "translation": "Solomon the father of Rehoboam, Rehoboam the father of Abijah, Abijah the father of Asaph,",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αϲαφʼ δε εγεννηϲ ε τον ϊωϲαφατʼ ϊωϲαφατʼ δε εγεν νηϲεν τον ϊωραμʼ ϊωραμʼ δε εγεννη ϲεν τον οζειαν οζιαν",
          "translation": "Asaph the father of Jehoshaphat, Jehoshaphat the father of Joram, Joram the father of Uzziah,",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "οζιαϲ δε εγεννη ϲεν τον ϊωαθαμ · ϊωαθαμ δε εγενʼνη ϲεν τον αχαϲ αχαζ : αχαϲ δε εγενʼνηϲ ε τον εζεκιαν",
          "translation": "Uzziah the father of Jotham, Jotham the father of Ahaz, Ahaz the father of Hezekiah,",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "εζεκιαϲ δε εγεννη ϲεν τον μαναϲϲηϲ μαναϲϲη μαναϲϲηϲ μαναϲϲη δε εγεν νηϲεν τον αμωϲ αμωϲ δε εγεννη ϲεν τον ϊωϲειαν ϊωϲιαν",
          "translation": "Hezekiah the father of Manasseh, Manasseh the father of Amos, Amos the father of Josiah,",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ϊωϲειαϲ δε εγενʼνη ϲεν τον ϊεχονιαν και τουϲ αδελφουϲ αυτου επι τηϲ με τοικεϲιαϲ βαβυλω νοϲ · ‾̷‾",
          "translation": "Josiah the father of Jeconiah and his brothers at the time of the exile to Babylon.",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "μετα δε την μετοι κεϲιαν βαβυλωνοϲ ϊεχονιαϲ εγεννη ϲεν τον ϲαλαθιηλʼ · ϲαλαθιηλ δε εγεν νηϲεν τον ζορο βαβελʼ ·",
          "translation": "After the Babylonian exile, Jeconiah was the father of Shealtiel, Shealtiel the father of Zerubbabel,",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ζοροβαβελ δε εγεννηϲεν τον αβιουτ αβιουδʼ : [1 chars] αβιουδʼ δε εγεννηϲεν τον ελιακειμ ελιακειμ δε εγεν νηϲεν τον αζωρ :",
          "translation": "Zerubbabel the father of Abiud, Abiud the father of Eliakim, Eliakim the father of Azor,",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "αζωρ δε εγεννηϲ ε τον ϲαδωχ ϲαδωκ : ϲαδωχ ϲαδωκ δε εγεννη ϲεν τον αχειμ αχιμ : αχειμ αχιμ δε εγεννη ϲεν τον ελιουτ ελιουδ :",
          "translation": "Azor the father of Zadok, Zadok the father of Achim, Achim the father of Eliud,",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ελιουτ ελιουδ δε εγεννη ϲεν τον ελεαζαρ : ελεαζαρ δε εγεννη ϲεν τον ματʼθαν · ματʼθαν δε εγεννη ϲεν τον ϊακωβʼ :",
          "translation": "Eliud the father of Eleazar, Eleazar the father of Matthan, Matthan the father of Jacob,",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ϊακωβʼ δε εγεννη ϲεν τον ϊωϲηφ τον ανδρα μαριαϲ εξ ἡϲ εγενʼνηθη ιϲ ὁ λεγομενοϲ χϲ · ‾̷‾",
          "translation": "Jacob the father of Joseph, the husband of Mary, of whom was born Jesus, who is called Christ.",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "παϲαι ουν ἁι γενε αι · απο αβρααμ ˙ εωϲ δα δʼ γενεαι ιδ · ‾̷‾ και απο δαδ ʼ εωϲ τηϲ μετοικεϲιαϲ βαβυλωνοϲ γενε αι ι δ ‾̷‾ και απο τηϲ μετοι κεϲιαϲ βαβυλωνοϲ εωϲ του χυ γενε αι ι δ ‾̷‾",
          "translation": "So all the generations from Abraham to David are fourteen generations, from David to the Babylonian exile fourteen generations, and from the Babylonian exile to the Christ fourteen generations.",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "του δε ιυ χυ η γενε ϲιϲ ὁυτωϲ ην μνηϲ ϲτευθιϲηϲ μνηϲτευθειϲηϲ τηϲ μη τροϲ αυτου μαριαϲ τω ϊωϲηφ πρὶν η ϲυνελθιν αυτουϲ ἑυρέθη εν γαϲτρι εχουϲα εκ πνϲ α γιου [1 chars] · [1 chars]",
          "translation": "The birth of Jesus Christ was like this. His mother Mary was betrothed to Joseph, but before they came together she was found to be pregnant by the Holy Spirit.",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ϊωϲηφ ‾̷‾ δε ὁ ανηρ αυτηϲ δι καιοϲ ὡν και μη θελων αυτην πα ραδιγματιϲαι δειγματιϲαι παραδειγματιϲαι εβου ληθη λαθρα απο λυϲε αυτην · ‾̷‾",
          "translation": "Joseph her husband, being a righteous man and not wanting to disgrace her publicly, planned to divorce her quietly.",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ταυτα δε αυτου εν θυμηθεντοϲ ϊ δου αγʼγελοϲ κυ κατ οναρ εφανη αυτω λεγων ϊω ϲηφʼ υ ϊοϲ δ ʼ α δ μη φοβηθηϲ παραλα βειν μαριαμ την γυναικα ϲου το γαρ εν αυτη γεννη θεν εκ π νϲ εϲτιν αγιου",
          "translation": "But as he was thinking about this, an angel of the Lord appeared to him in a dream, saying, 'Joseph, son of David, do not be afraid to take Mary as your wife, for the child conceived in her is from the Holy Spirit.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "τεξεται δε υν υιον και καλεϲειϲ το ο νομα αυτου ιν ι̣η̣ϲ̣ο̣υ̣ν̣ αυτο̣ϲ̣ γαρ ϲωϲι τον λαον αυτου απο των ἁ μαρτιῶν ἁυτων ‾̷‾",
          "translation": "'She will give birth to a son, and you shall name him Jesus, for he will save his people from their sins.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "τουτο δε ολον γεγο νεν ινα πληρωθη το ρηθεν υ πο κυ > δια του προφητου > λεγοντοϲ",
          "translation": "All this happened to fulfill what the Lord had spoken through the prophet:",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ιδου η > παρθενοϲ εν γαϲ τρι > γα >ϲτρι εξι και τεξετε τεξεται > υν και καλεϲουϲ ι > το ονομα αυτου [1 chars] εμʼμα νουηλʼ > ὁ εϲτιν με θερμηνευομεν ο μεθʼ ημων ο θϲ · ‾̷‾",
          "translation": "'Behold, the virgin will conceive and give birth to a son, and they will call him Immanuel' — which means 'God with us.'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "εγερθειϲ δε ϊωϲηφ απο του ϋπνου ε ποιηϲεν ὡϲ προϲ εταξεν αυτω ο αγ γελοϲ κυ και παρε λαβεν μαριαμ · την γυνε κα γυναικα αυτου εαυτου ·",
          "translation": "When Joseph woke from his sleep, he did as the angel of the Lord commanded him. He took Mary as his wife,",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και ουκ ε γινωϲκεν αυτην εωϲ ὁυ ετεκεν ὑϊ ον ὑϊον ὑϊ ον και εκαλεϲεν το ονομα αυτου ιν ‾̷‾",
          "translation": "but did not have sexual relations with her until she gave birth to a son. And he named him Jesus.",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 2,
      "verses": [
        {
          "verse": 1,
          "original": "του δε ιυ γεννηθεντοϲ εν βηθλεεμʼ τηϲ ϊ ουδαιαϲ εν ημερεϲ ημεραιϲ ηρωδου του του βαϲι λεωϲ ϊδο'υ μάγοι απο ανατολων παρεγενοντο ιϲ ειϲ ϊεροϲολυμα ·",
          "translation": "After Jesus was born in Bethlehem of Judea, in the days of Herod the king, wise men from the east arrived in Jerusalem,",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "λε γοντεϲ · που εϲτιν ὁ τεχθειϲ βαϲιλευϲ των ϊουδαιων ι δομεν ειδομεν ιδομεν γαρ αυτου τον αϲτεραν αϲτερα εν τη α νατολη και ηλθο μεν προϲκυνη ϲαι αυτω : ‾̷‾",
          "translation": "saying, 'Where is the one born king of the Jews? We saw his star when it rose and have come to worship him.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ακουϲαϲ δε ο βαϲι λευϲ ηρωδηϲ ετα ραχθη και παϲα ϊ εροϲολυμα μετʼ αυ του",
          "translation": "When King Herod heard this, he was troubled, and all Jerusalem with him.",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και ϲυναγαγ ω πανταϲ τουϲ αρχι ερειϲ αρχι ϊερειϲ και γραμμα τειϲ του λαου επυν θανετο παρ αυτ ω πο'υ ο χϲ γεννατε γενναται",
          "translation": "He gathered all the chief priests and scribes of the people together and asked them where the Christ was to be born.",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ὁι δε εῖπαν αυτω αυτω ‾̷‾ εν βηθλεεμʼ τηϲ ‾̷‾ ϊουδαιαϲ · : ουτωϲ γαρ γεγραπται δια του προφητου · >",
          "translation": "'In Bethlehem of Judea,' they said, 'for this is what the prophet wrote:'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και ϲυ βηθλεεμ γη > ϊουδα ουδαμωϲ ε λαχίϲτή > ει εν τοιϲ > ηγεμοϲιν ϊουδα · ε ξ > ου γαρ εξελευϲεται η γουμενοϲ > ὁϲτιϲ > ποιμανι ποιμανε'ι τον λα ο > μου τον ι η λ ‾̷‾",
          "translation": "'And you, Bethlehem, in the land of Judah, are by no means least among the rulers of Judah, for from you will come a ruler who will shepherd my people Israel.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "τοτε ηρωδηϲ λαθρα καλεϲαϲ τουϲ μαγουϲ ηκριβωϲεν παρ αυ των τον χρονον του φαινομενου αϲτεροϲ ·",
          "translation": "Then Herod secretly called the wise men and asked them exactly when the star had appeared.",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "και πεμ ψαϲ αυτουϲ ειϲ βη θλεεμʼ εῖπεν πο ρευθεντεϲ εξετα ϲατε ακριβωϲ πε ρι του πεδιου · επ α δε ἑύρητε απαγγι λατε μοι · ὁπωϲ κα γω ελθων προϲ κυνηϲω αυτω ‾̷‾",
          "translation": "He sent them to Bethlehem and said, 'Go and search carefully for the child. When you find him, report to me, so I too can go and worship him.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "ὁι δε ακουϲαντεϲ του βαϲιλεωϲ ε πορευθηϲαν · και ϊδου ὁ αϲτηρ ὁν ϊ δον εῖδον εν τη ανατο λη προῆγεν προηγον αυτουϲ ἑωϲ ελθων εϲτα θη ὁυ ἠν το παιδιον ·",
          "translation": "After hearing the king, they went on their way. The star they had seen when it rose went ahead of them until it stopped over the place where the child was.",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ϊδον τεϲ δε τον αϲτεραν αϲτερα εχαρηϲαν χαραν μεγαλην ϲφοδρα · ‾̷‾",
          "translation": "When they saw the star, they were overjoyed.",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "και ελθοντεϲ ειϲ την οικιαν ϊδον εῖδον το παιδιον μετα μαριαϲ τηϲ μητροϲ αυτου · και πεϲον τεϲ προϲεκυνηϲαν αυτω · και ανοιξαν τεϲ τουϲ θηϲαυρουϲ ἁυτων προϲηνεγʼ καν αυτω δωρα χρυϲον · και λιβαν ο · και ϲμυρναν ·",
          "translation": "They entered the house and saw the child with his mother Mary. They bowed down and worshiped him. Then they opened their treasure chests and gave him gifts of gold, frankincense, and myrrh.",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και χρηματιϲθεντεϲ κατ ὁναρ μη ανα καμψαι προϲ ηρω δην διʼ άλʼληϲ ὁδου ανεχωρηϲαν ειϲ την εαυτων χω ραν χωραν αὑτων · ‾̷‾",
          "translation": "Having been warned in a dream not to return to Herod, they went back to their country by another route.",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "αναχωρηϲαντ ω δε αυτων ϊδου αγ γελοϲ κυ φαινε ται κατʼ οναρ τω ϊ ωϲηφ ˙ λεγων · εγερ θειϲ παραλαβε το παιδιον και την μητερα ἀυτου · και φευγε ειϲ αιγυπτ ο αιγυπτ ο · και ϊϲθι εκει ἑωϲ αν έιπω ϲοι · μελʼ λει γαρ ηρωδηϲ ζητιν το πεδιον του απολεϲε αυτο · ‾̷‾",
          "translation": "After they had left, an angel of the Lord appeared to Joseph in a dream, saying, 'Get up, take the child and his mother, and flee to Egypt. Stay there until I tell you, for Herod is going to search for the child to kill him.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ὁ δε εγερθειϲ παρε λαβε το πεδιον και την μητερα ἁυτου νυκτοϲ νυκτο [1 chars] και ανεχωρηϲεν ει ϲ αιγυπτον ·",
          "translation": "He got up and took the child and his mother during the night and left for Egypt.",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και η εκι εωϲ τηϲ τελευ τηϲ ἡρωδου ϊνα πληρωθῆ το ρηθ ε ϋπο κυ δια του προ φητου > λεγοντοϲ > εξ αιγυπτου εκα λεϲα > τον υν ὑιον μου ‾̷‾",
          "translation": "He stayed there until Herod died. This fulfilled what the Lord had spoken through the prophet: 'Out of Egypt I called my son.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "τοτε ηρωδηϲ ϊδ ω ὁτι ενεπεχθη υ πο των μαγων εθυμωθη λειαν λῖαν και αποϲτιλαϲ α νἑιλεν πανταϲ τουϲ παιδαϲ τουϲ εν βηθλεεμ · και εν πᾶϲι τοιϲ ὁρὶοιϲ ἀυτηϲ απο διετουϲ · και κατωτερω · κα τα τον χρονον ὁν ηκριβωϲεν πα ρα των μαγων · ‾̷‾",
          "translation": "When Herod realized he had been outwitted by the wise men, he became furious. He gave orders to kill all the male children in Bethlehem and its vicinity who were two years old and under, according to the time he had learned from the wise men.",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "τοτε επληρωθη το ρηθεν δια ϊερε μιου του προφη του λεγοντοϲ >",
          "translation": "Then what was spoken through the prophet Jeremiah was fulfilled:",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "φωνη εν ραμα η κουϲθη > · κλαυθμοϲ > και οδυρμοϲ πολυϲ · > ραχηλ · κλαιουϲα τα > τεκνα ἁυτηϲ · και > ουκʼ ηθελεν παρα κληθηναι > ὁτι ου κʼ > ειϲιν ‾̷‾",
          "translation": "'A voice was heard in Ramah, weeping and great mourning — Rachel weeping for her children, refusing to be comforted, because they are no more.'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "δε του ηρωδου · ϊ δου αγγελοϲ κυ φαινεται κατʼ οναρ τω ϊωϲηφʼ εν αι γυπτω",
          "translation": "After Herod died, an angel of the Lord appeared in a dream to Joseph in Egypt,",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "λεγων : ε γερθειϲ παραλαβε το παιδιον και τ η μρ α ἀυτου · και πο ρευου ειϲ γην ιηλ · τεθνηκαϲιν γαρ ὁι ζητουντεϲ την ψυχην του πεδιου · ‾̷‾",
          "translation": "saying, 'Get up, take the child and his mother, and go to the land of Israel, for those who sought the child's life are dead.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ὁ δε εγερθιϲ παρε λαβε το παιδιον · και την μρ α αυτου · και ειϲῆλθεν ειϲ γην ιη λ ‾̷‾",
          "translation": "He got up, took the child and his mother, and went to the land of Israel.",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "άκουϲαϲ δε ὁτι αρ χελαοϲ βαϲιλευει τηϲ ϊουδαιαϲ · αντι του πρϲ αυτου ηρω δου · εφοβηθη εκει απελθειν · χρημα τιϲθειϲ δε κατʼ οναρ ανεχωρηϲεν ειϲ τα μερη τηϲ γαλι λαιαϲ ·",
          "translation": "But when he heard that Archelaus was reigning over Judea in place of his father Herod, he was afraid to go there. Having been warned in a dream, he withdrew to the region of Galilee.",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και ελθων κατʼώκηϲεν ειϲ πολιν λεγομεν η ναζαρετʼ · ὁπωϲ πληρωθη το ρηθ ε δια υπο των προφητ ω ' > ὁτι ναζωρᾶιοϲ > κληθηϲεται : ‾̷‾",
          "translation": "He went and settled in a town called Nazareth, so that what was spoken through the prophets would be fulfilled: 'He will be called a Nazarene.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 3,
      "verses": [
        {
          "verse": 1,
          "original": "εν δε ταιϲ ημερεϲ εκειναιϲ παραγει νεται παραγινεται ϊωανʼνηϲ ο βαπτιϲτηϲ · κηρυϲ ϲων εν τη ερημω τηϲ ϊουδεαϲ",
          "translation": "In those days, John the Baptist appeared, preaching in the wilderness of Judea,",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "λεγ ω μετανοεῖτε ηγʼγι κεν γαρ η βαϲιλια βαϲιλεῖα των ουνω ν ·",
          "translation": "'Repent, for the kingdom of heaven has come near.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ου τοϲ ‾̷‾ γαρ εϲτιν ο ρη θιϲ δια ηϲαιου του προφητου λεγον τοϲ > · φωνη βοων τοϲ > εν τη ερημω · > ἑτοιμαϲατε την > οδον κυ ευθιαϲ > ποιειται ποιειτε ταϲ τρι βουϲ > αυτου ‾̷‾",
          "translation": "This is the one spoken of through the prophet Isaiah: 'A voice of one crying out in the wilderness: Prepare the way of the Lord, make his paths straight.'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "αυτοϲ δε ὁ ϊωανʼ νηϲ ειχεν το εν δυμα ἁυτου απο τριχων καμηλου . και ζωνην δερ ματινην περι την ὂϲφυν ἁυτου η δε τροφη ην αυ του ακριδεϲ · και με λι αγριον ‾̷‾",
          "translation": "John wore a garment of camel's hair and a leather belt around his waist. His food was locusts and wild honey.",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "τοτε εξεπορευε το προϲ αυτον ϊ εροϲολυμα και παϲα ἡ ϊουδεα ϊουδαῖα κ(αι) παϲα ἡ [1 chars] περιχω ροϲ του ϊορδανου",
          "translation": "Jerusalem and all Judea and the whole region around the Jordan were going out to him.",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και εβαπτιζοντο εν τω ϊορδανη ποταμω υ πʼ αυτου εξομο λογουμενοι ταϲ ἁμαρτιαϲ ἁυ των : ‾̷‾",
          "translation": "They were baptized by him in the Jordan River, confessing their sins.",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ϊδων δε πολʼλουϲ των φαριϲαιων και ϲαδʼδουκαι ω ερχομενουϲ ε πι το βαπτιϲμα αυτου εῖπεν αυτοιϲ · γενʼ νηματα εχιδνῶν τιϲ υ πεδειξεν ϋ μιν φυγιν απο τηϲ μελʼλουϲηϲ ορ γηϲ · ‾̷‾",
          "translation": "When he saw many of the Pharisees and Sadducees coming to his baptism, he said to them, 'You brood of vipers! Who warned you to flee from the coming wrath?'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ποιηϲάτε ουν καρ πον αξιον τηϲ με τανοιαϲ ·",
          "translation": "'Bear fruit worthy of repentance.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και μη δο ξητε λεγιν εν ε αυτοιϲ πρα εχο μεν τον αβρααμʼ λεγω γαρ υ μιν ὁ τι δυναται ο θϲ εκ των λιθων του των εγιραι εγεῖραι τεκνα τω αβρααμʼ ·",
          "translation": "'Do not presume to say to yourselves, \"We have Abraham as our father.\" I tell you, God can raise up children for Abraham from these stones.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ηδη δε ἡ αξίνη προϲ ‾̷‾ την ριζαν των δ έ δρων κειται παν ουν δενδρον μη ποιουν καρπον καλον εκκοπτε ται και ειϲ πυρ βαλʼ λεται · ‾̷‾",
          "translation": "'The ax is already laid at the root of the trees. Every tree that does not bear good fruit is cut down and thrown into the fire.'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "εγω μεν γαρ υ μαϲ βαπτιζω εν υ δα τι εν υ δατι βαπτιζω ειϲ μετανοι α ὁ δε οπιϲω μου ερχομενοϲ ϊϲ χυροτεροϲ μου εϲτιν ὁυ ουκʼ ειμι ϊκανοϲ τα υ ποδη ματα βαϲταϲαι αυ τοϲ υ μαϲ βαπτιϲι εν πνι ἁγιω και πυ ρι ˙",
          "translation": "'I baptize you with water for repentance, but the one who comes after me is more powerful than I. I am not worthy to carry his sandals. He will baptize you with the Holy Spirit and fire.'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ὁυ το πτῦον εν ‾̷‾ τη χειρι αυτου και διακαθαριε'ι διακατ̣αριει την ἅλωνα ἁυτου · και ϲυναξει τον ϲιτ ο ἁυτου ειϲ την α ποθηκην · το δε αχυρον κατακαυ ϲι πυρι αϲβεϲτω · ‾̷‾",
          "translation": "'His winnowing fork is in his hand. He will clear his threshing floor and gather his wheat into the barn, but the chaff he will burn with unquenchable fire.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε παραγινεται ο ιϲ απο τηϲ γαλι λαιαϲ επι τον ϊορ δανην προϲ τον ϊωανʼνην του βα πτιϲθηναι ὑ πʼ αυ του",
          "translation": "Then Jesus came from Galilee to the Jordan to be baptized by John.",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ὁ δε ιωαννηϲ διεκωλυ εν ‾̷‾ αυτον · λεγ ω · εγω χριαν χρειαν εχω υ πο ϲου βαπτιϲθη νε βαπτιϲθηναι · και ϲυ ερχη προϲ με : ‾̷‾",
          "translation": "But John tried to stop him, saying, 'I need to be baptized by you, and you come to me?'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "αποκριθειϲ δε ὁ ιϲ ειπεν προϲ αυ τον άφεϲ αρτι ˙ ου τω ουτωϲ γαρ πρεπον ε ϲτιν ἡμαϲ ἡμιν ἡμιν πλη ρωϲαι παϲαν δι καιοϲυνην · τοτε ‾̷‾ αφιηϲιν αυτον : ‾̷‾",
          "translation": "Jesus answered him, 'Let it be so for now, for it is fitting for us to fulfill all righteousness.' Then John allowed him.",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "βαπτιϲθειϲ δε ὁ ιϲ ευθυϲ ανεβη απο του υ δατοϲ και ϊ δου ανεωχθηϲαν αυτω οι ουρανοι και εῖ δεν πν α θυ κατα βᾶινον ὡϲει πε ριϲτεραν κ(αι) ερχο μενον επ αυτ ο ·",
          "translation": "After Jesus was baptized, he immediately came up from the water. Suddenly the heavens were opened, and he saw the Spirit of God descending like a dove and coming to rest on him.",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "και ϊδου φωνη εκ των ο υνω ν λεγουϲα ὁυτοϲ ε ϲτιν ὁ υϲ ὑιοϲ μου ὁ α γαπητοϲ εν ὡ η υ δοκηϲα ε υ δοκηϲα η υ δοκηϲα ‾̷‾",
          "translation": "And a voice from heaven said, 'This is my beloved Son, with whom I am well pleased.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 4,
      "verses": [
        {
          "verse": 1,
          "original": "τοτε ο ιϲ ανηχθη υ πο του πν ϲ ειϲ την ερημον πι ραϲθηνε̣ι πειραϲθηναι ϋπο του διαβολου",
          "translation": "Then Jesus was led up by the Spirit into the wilderness to be tempted by the devil.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και νη ϲτευϲαϲ ημεραϲ τεϲϲερακοντα κ(αι) τεϲϲερακοντα νυκταϲ υ ϲτερον επιναϲεν ‾̷‾",
          "translation": "After fasting forty days and forty nights, he was hungry.",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και προϲελθων ὁ πιραζων εῖπ ε αυτω ἑι υ ἱοϲ ει του θυ εὶπε ειπον ι να οι λιθοι ὁυτοι αρτοι γενωνται : > ‾̷‾",
          "translation": "The tempter came to him and said, 'If you are the Son of God, command these stones to become bread.'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "ὁ δε δ αποκριθειϲ > εῖπεν · γεγραπται γεγραπτε > ουκʼ επ αρτω μο νω > ζηϲεται ὁ ανο ϲ > αλʼλ επι παντι ρη ματι > εκπορευο μενω > δια ϲτομα τοϲ > θυ : ‾̷‾",
          "translation": "He answered, 'It is written: Man does not live by bread alone, but by every word that comes from the mouth of God.'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "τοτε παραλαμβα νι αυτον ὁ διαβο λοϲ ειϲ την ἁγι αν πολιν και εϲτη ϲεν αυτον επι το πτερυγιον του ϊ ερου",
          "translation": "Then the devil took him to the holy city and set him on the pinnacle of the temple.",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και λεγει ειπεν λεγει αυ τω ει ὑϊοϲ ει του θυ βαλε ϲεαυτον κατω : γεγραπται γαρ ὁτι τοιϲ αγʼγε λοιϲ ἁυτου εντε λιτε εντελεῖτε εντελεῖτε περὶ ϲου και επι χειρων αροῦ ϲίν αρουϲι ϲε μήποτε προϲκόψηϲ προϲ λιθον τον ποδα ϲου ·",
          "translation": "He said to him, 'If you are the Son of God, throw yourself down, for it is written: He will command his angels concerning you, and they will lift you up in their hands, so that you will not strike your foot against a stone.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "εφη αυτω ο ιϲ ‾̷‾ παλιν · γεγραπται · > ουκʼ εκπιραϲειϲ > κν τον θν ϲου · ‾̷‾",
          "translation": "Jesus said to him, 'It is also written: Do not put the Lord your God to the test.'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "παλιν παραλαμ βανει αυτον ὁ δι αβολοϲ ειϲ ὅροϲ υ ψηλον λῖαν και δικνυει αυτω πα ϲαϲ ταϲ βαϲιλιαϲ του κοϲμου · και την δοξαν αυτ ω",
          "translation": "Again the devil took him to a very high mountain and showed him all the kingdoms of the world and their glory.",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και ειπεν αυτω · ταυτα ϲοι παντα δωϲω ˙ εαν πεϲ ω προϲκυνηϲηϲ μοι · ‾̷‾",
          "translation": "He said to him, 'I will give you all these things if you will fall down and worship me.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "τοτε λεγι ο ιϲ ϋπαγε ϲατανα · > γεγραπται γαρ κν > τον θν ϲου προϲ κυνηϲηϲ > · και αυ τω > μονω λατρευ ϲιϲ > : ‾̷‾",
          "translation": "Jesus said to him, 'Get away, Satan! For it is written: Worship the Lord your God, and serve only him.'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "τοτε αφιηϲιν αυ τον ὁ διαβολοϲ ‾̷‾ και ϊδου αγʼγελοι προϲῆλθον και διηκονουν αυτω :",
          "translation": "Then the devil left him, and angels came and began ministering to him.",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ακουϲαϲ δε ι ωαν νηϲ ‾̷‾ οτι ὁτι ι ωαννηϲ ὁτι ι ωαννηϲ παρεδο θη ανεχωρηϲ ε ειϲ την γαλιλαι α : ‾̷‾",
          "translation": "When Jesus heard that John had been arrested, he withdrew to Galilee.",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και καταλιπων την ναζαρεθʼ ναζαρα ελ θων κατώκηϲ ε ειϲ καφαρναουμ την παρα θαλαϲϲ α παραθαλαϲϲι α · εν ὁριοιϲ ζαβου λων · και νεφθα λειμʼ ·",
          "translation": "He left Nazareth and went to live in Capernaum by the sea, in the region of Zebulun and Naphtali,",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ϊνα πληρω θῆ ‾̷‾ το ρηθεν δια ηϲαϊου του προ φητου λεγοντοϲ · >",
          "translation": "to fulfill what was spoken through the prophet Isaiah:",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "γη ζαβουλων · > και γη νεφθαλειμ · > ὁδον θαλαϲϲηϲ > περαν του ϊορδα νου > γαλιλαῖα των > εθνῶν",
          "translation": "'Land of Zebulun and land of Naphtali, the way of the sea, beyond the Jordan, Galilee of the Gentiles —",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ὁ λαοϲ ὁ > καθημενοϲ εν > ϲκοτι ϲκοτια φωϲ ιδεν εῖδεν > μεγα · και τοιϲ κα θημενοιϲ > εν χω ρα > και ϲκιᾶ θανα του > φωϲ ανετι λεν > αυτοιϲ : ‾̷‾",
          "translation": "the people living in darkness have seen a great light, and on those living in the land of the shadow of death, a light has dawned.'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "απο τοτε ηρξατο ο ιϲ κηρυϲϲιν κηρυϲϲειν · και λεγιν μετανοεῖ τε ηγʼγικεν γαρ ἡ βαϲιλια βαϲιλεῖα των ου ρανων : ‾̷‾",
          "translation": "From that time on, Jesus began to preach, 'Repent, for the kingdom of heaven has come near.'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "περιπατων δε πα ρα την θαλαϲϲαν τηϲ γαλιλαῖαϲ εῖ δεν δυο αδελφουϲ · ϲιμωνα τον λεγο μενον καλουμενον πετρον · και ανδρεαν τον αδελʼφον αυτου βαλʼλονταϲ αμ φιβληϲτρον ειϲ την θαλαϲϲαν η ϲαν γαρ ἁλεειϲ ἁλιειϲ ἁλιειϲ ·",
          "translation": "As he walked by the Sea of Galilee, he saw two brothers — Simon, who is called Peter, and his brother Andrew — casting a net into the sea, for they were fishermen.",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και ‾̷‾ λεγει αυτοιϲ · δευ τε ὀπιϲω μου · και ποιηϲω ϋμαϲ γενεϲθαι αλιειϲ α̣λε̣ειϲ ανων",
          "translation": "He said to them, 'Follow me, and I will make you fishers of people.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ὁι δε ευθεωϲ αφεντεϲ τα δικτυα ηκολου θηϲαν αυτω · ‾̷‾",
          "translation": "Immediately they left their nets and followed him.",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "και προβαϲ εκει θεν ˙ ϊδεν αλʼλουϲ δυο αδελφουϲ · ϊα κωβον τον του ζεβεδαιου · και ϊω ανʼνην τον αδελ φον ἁυτου εαυτου ἁυτου · εν τω πλοιω μετα ζε βεδαιου του πρ ϲ ἁυτων καταρτί ζονταϲ τα δικτυ α ἁυτων και εκα λεϲεν αυτουϲ ·",
          "translation": "Going on from there, he saw two other brothers — James son of Zebedee and his brother John — in the boat with their father Zebedee, mending their nets. He called them,",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "οι δε ευθεωϲ αφ ε τεϲ το πλοιον αυ των και τον πατε ρα ἁυτων ηκολου θηϲαν αυτω : ‾̷‾",
          "translation": "and immediately they left the boat and their father and followed him.",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και περιῆγεν ο ιϲ εν τη γαλιλαια ολην την γαλιλαιαν δι δαϲκων αυτουϲ εν ταιϲ ϲυναγω γαιϲ ἀυτων και κη ρυϲϲων το ευαγʼγε λιον τηϲ βαϲιλι αϲ · και θεραπευ ω παϲαν νοϲον και παϲαν μαλα κιαν εν τω λαω ·",
          "translation": "Jesus went throughout all Galilee, teaching in their synagogues, preaching the good news of the kingdom, and healing every disease and sickness among the people.",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "και εξηλθεν η α κοη ‾̷‾ αυτου ειϲ πα ϲαν την ϲυριαν και προϲηνεγʼκ α αυτω πανταϲ τουϲ κακωϲ εχονταϲ ποικιλαιϲ νοϲοιϲ και βαϲανουϲ βαϲανοι̣ϲ ϲυ νεχομενουϲ και δε̣μονιαζο μενουϲ ϲ̣ελ̣η̣νιαζομενουϲ δα̣ι̣μονιαζομενουϲ και ϲε ληνιαζομενουϲ · και παραλυτικουϲ · και εθεραπευϲεν αυτουϲ ‾̷‾",
          "translation": "News about him spread throughout all Syria. People brought to him all who were sick — those afflicted with various diseases and pains, the demon-possessed, epileptics, and paralytics — and he healed them.",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και ηκολουθηϲ α αυτω οχλοι πολʼ λοι απο τηϲ γαλι λαιαϲ και δεκαπο λεωϲ και ϊεροϲο λυμων · και ϊου δαιαϲ · και περαν του ϊορδανου : ‾̷‾",
          "translation": "Large crowds followed him from Galilee, the Decapolis, Jerusalem, Judea, and from beyond the Jordan.",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 5,
      "verses": [
        {
          "verse": 1,
          "original": "ϊδων δε τουϲ ο χλουϲ ανεβη ειϲ το οροϲ και καθι ϲαντοϲ αυτου προ ϲηλθαν προϲῆλθον αυτω οι μαθηται αυτου · ‾̷‾",
          "translation": "When he saw the crowds, he went up on the mountain. After he sat down, his disciples came to him.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ανοιξαϲ το ϲτο μα ἁυτου εδιδα ϲκεν αυτουϲ λεγ ω : ‾̷‾",
          "translation": "He opened his mouth and began to teach them, saying:",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "μακαριοι οι πτω χοι τω πν ι ὁτι αυ των εϲτιν η βα ϲιλια βαϲιλε'ια των ο υνω ‾̷‾",
          "translation": "'Blessed are the poor in spirit, for theirs is the kingdom of heaven.",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "μακαριοι οι πεν θουντεϲ νυν οτι αυ τοι παρακληθη ϲονται · ‾̷‾",
          "translation": "Blessed are those who mourn, for they will be comforted.",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "μακαριοι οι πρα ειϲ ὁτι αυτοι κλη ρονομηϲουϲιν την γην ‾̷‾",
          "translation": "Blessed are the meek, for they will inherit the earth.",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "μακαριοι ὁι πιν ω τεϲ και διψωντεϲ την δικαιοϲυν η οτι αυτοι χορτα ϲθηϲονται · ‾̷‾",
          "translation": "Blessed are those who hunger and thirst for righteousness, for they will be filled.",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "μακαριοι ὁι ελε ημονεϲ ὁτι αυ τοι ελεηθηϲον ται ‾̷‾",
          "translation": "Blessed are the merciful, for they will receive mercy.",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "μακαριοι ὁι καθα ροι τη καρ̣δια καρδια ὁτι αυτοι τον θν ο ψονται ‾̷‾",
          "translation": "Blessed are the pure in heart, for they will see God.",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "μακαριοι ὁι ϊρη νοποιοι οτι υ ι οι θυ κληθηϲον ται · ‾̷‾",
          "translation": "Blessed are the peacemakers, for they will be called children of God.",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "μακαριοι οι δεδι ωγμενοι ενεκ ε δικαιοϲυνηϲ ὁτι αυτων εϲτιν η βα ϲιλια βαϲιλε'ια των ουραν ω · ‾̷‾",
          "translation": "Blessed are those who are persecuted because of righteousness, for theirs is the kingdom of heaven.",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "μακαριοι εϲτε οτ α ονειδιϲωϲιν υ μαϲ και διωξου ϲιν · και ειπωϲιν παν πονηρον κα θ υμων ψευδομε νοι ενεκεν εμου ·",
          "translation": "'Blessed are you when people insult you, persecute you, and falsely say all kinds of evil against you because of me.",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "χαιρεται και αγαλʼ λιαϲθε ὁτι ο μι ϲθοϲ υ μων πολυϲ εν τοιϲ ο υνοι ϲ ου τωϲ γαρ εδιωξαν τουϲ προφηταϲ τουϲ προ υ μων · ‾̷‾",
          "translation": "Rejoice and be glad, for your reward in heaven is great. For that is how they persecuted the prophets before you.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "υ μιϲ ὲϲτε το ἁλα ἁλαϲ ἁλα τηϲ γηϲ εαν δε το ἁλα μωρανθῆ εν τί νι ἁλιϲθηϲεται · ειϲ ουδεν ϊϲχυει ετι ει μη βληθεν εξω καταπατιϲθε υ πο των ανθρω πων · ‾̷‾",
          "translation": "'You are the salt of the earth. But if the salt loses its flavor, how can it be made salty again? It is no longer good for anything except to be thrown out and trampled underfoot.",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "υ μειϲ εϲται το φωϲ του κοϲμου · ου δυ ναται πολιϲ κρυ βηναι επανω ο ρουϲ κειμενη",
          "translation": "'You are the light of the world. A city on a hill cannot be hidden.",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ου δε κεουϲιν λυχν ο ‾̷‾ και τιθεαϲιν αυ τον υ πο τον μοδι ο αλʼλʼ επι την λυ χνιαν · και λαμπι παϲιν τοιϲ εν τη οικια",
          "translation": "People do not light a lamp and put it under a basket, but on a lampstand, and it gives light to everyone in the house.",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ὁυτωϲ λαμ ψατω το φωϲ υ μων εμπροϲθ ε των α νων οπωϲ ἴδωϲιν υ μων τα καλα εργα και δοξαϲωϲιν τον [1 chars] πρα υ μων τον π̣ρ̣ α̣ εν τοιϲ ο υνοι ϲ · ‾̷‾",
          "translation": "In the same way, let your light shine before people, so they may see your good works and give glory to your Father in heaven.'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "μη νομιϲητε ο τι ηλθον καταλυ ϲαι τον νομον η τουϲ προφηταϲ ουκʼ ηλθον κατα λυϲαι αλʼλα πλη ρωϲαι · ‾̷‾",
          "translation": "'Do not think I have come to abolish the Law or the Prophets. I have not come to abolish them but to fulfill them.",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "αμην γαρ λεγω υ μιν ἑωϲ αν πα ρελθη ὁ ουρανοϲ και ἡ γη ϊῶτα ε ν εν ἠ μία κεραια κερεα ου μη παρελθη απο του νομου ἑωϲ αν παντα γενηται · ‾̷‾",
          "translation": "Truly I tell you, until heaven and earth pass away, not one letter or one stroke of the law will pass away until everything is accomplished.",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ὁϲ εαν ουν λυϲη μι αν των εντολ ω τουτων των ελα χιϲτων και διδα ξη ουτωϲ τουϲ α θρωπουϲ ελαχι ϲτοϲ κληθηϲετε εν τη βαϲιλια τ ω ο υνω ν οϲ δʼ αν ποιηϲη κ(αι) διδαξη ουτοϲ μεγαϲ κληθηϲεται εν τη βαϲι λεια των ουρανων",
          "translation": "Therefore, whoever breaks one of the least of these commands and teaches others to do the same will be called least in the kingdom of heaven. But whoever does them and teaches them will be called great in the kingdom of heaven.",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "λεγω γαρ υ μιν ὁτι εαν μη περιϲϲευϲη υ μ ω η δικαιοϲυνη πλεον πλῖεον πλειον των γραμʼ ματεων και φα ριϲαιων ου μη ει ϲελθηται ειϲελθητε ειϲ την βαϲιλιαν των ου ρανων ‾̷‾",
          "translation": "For I tell you, unless your righteousness surpasses that of the scribes and Pharisees, you will never enter the kingdom of heaven.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ηκουϲατε οτι ερʼ ρεθη τοιϲ αρχαιοιϲ [1 chars] ου φονευϲειϲ ὁϲ δ αν φονευϲη ε νοχοϲ εϲται τη κριϲει ·",
          "translation": "'You have heard that it was said to the people long ago: Do not murder, and whoever murders will be subject to judgment.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "εγω δε λεγω ‾̷‾ ϋμιν οτι πᾶϲ ὁ ορ γιζομενοϲ τω αδελφω ἁυτου εικη ενοχοϲ εϲτε τη κριϲει · οϲ δ αν εί πη τω αδελφω ἁυτου ραχα ρακα ενο χοϲ εϲται τω ϲυ νεδριω ˙ ὁϲ δʼ αν ειπη μωρε ενο χοϲ εϲτε ειϲ την γεενʼναν του πυ ροϲ · ‾̷‾",
          "translation": "'But I tell you that everyone who is angry with his brother will be subject to judgment. Whoever insults his brother will be subject to the council. Whoever says \"You fool!\" will be subject to hell fire.'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "εαν ουν προϲφε ρηϲ το δωρον ϲου επι το θυϲιαϲτη ριον κακει μνη ϲθηϲ ὁτι ὁ αδελ φοϲ ϲου εχι τι κα τα ϲου ·",
          "translation": "'So if you are offering your gift at the altar and there remember that your brother has something against you,'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "αφεϲ εκι το δωρον ϲου εμπρο ϲθεν του θυϲια ϲτηριου · και υ παγε πρωτον διαλʼλαγη θι τω αδελφω ϲου · και τοτε ελθων προϲφερε το δω ρον ϲου · ‾̷‾",
          "translation": "'leave your gift there at the altar and go. First be reconciled to your brother, and then come and offer your gift.'",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ϊϲθι ευνοων τω αντιδικω ϲου τα χυ εωϲ ὅτου ει με τʼ αυτου εν τη οδω · μηποτε ϲε παρα δω ὁ αντίδικοϲ τω κριτη · και ὁ κρι τηϲ τω ϋπηρετη και ειϲ φυλακην βληθηϲη ·",
          "translation": "'Make friends quickly with your accuser while you are on the way to court, or your accuser may hand you over to the judge, and the judge to the guard, and you will be thrown in prison.'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "αμην λεγω ϲοι · ου μη εξελθηϲ εκι θεν εωϲ α ν απο δῶϲ τον εϲχατ ο κοδραντην · ‾̷‾",
          "translation": "'Truly I tell you, you will never get out until you have paid the last penny.'",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ηκουϲατε ὁτι ερ ρεθη ου μοιχευϲιϲ ·",
          "translation": "'You have heard that it was said: Do not commit adultery.'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "εγω δε λεγω υ μ ι ὁτι παϲ ο βλεπ ω γυναικα προϲ το επιθυμηϲε αυτηϲ ηδη εμοιχευϲεν αυ την εν τη καρδι α ἁυτου ‾̷‾",
          "translation": "'But I tell you that everyone who looks at a woman lustfully has already committed adultery with her in his heart.'",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ει δε ο οφθαλμοϲ ϲου ὁ δεξιοϲ ϲκαν δαλιζι ϲε ἑξἑλε αυτον · και βαλε απο ϲου ϲυμφε ρι γαρ ϲοι ἱνα απολη ται ἑν των μελ ω ϲου και μη ὁλον το ϲωμα ϲου βλη θῆ ειϲ γεενναν · ‾̷‾",
          "translation": "'If your right eye causes you to sin, tear it out and throw it away! It is better for you to lose one part of your body than for your whole body to be thrown into hell.'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και ει ἡ δεξια ϲου χειρ ϲκανδαλιζι ϲε εκκοψον αυτ η και βαλε απο ϲου · ϲυμφερι γαρ ϲοι ϊ να απόληται ἑν τ ω μελων ϲου η κ(αι) μη ὁλον το ϲωμα ϲου ειϲ γε ενναν απελθη · ‾̷‾",
          "translation": "'And if your right hand causes you to sin, cut it off and throw it away! It is better for you to lose one part of your body than for your whole body to go into hell.'",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ερρέθη δε δε ὁϲ ἁν απο λυϲη την γυναικα ἁυτου δοτω αυτῆ αποϲταϲιον ·",
          "translation": "'It was also said: Whoever divorces his wife must give her a certificate of divorce.'",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "εγω δε λεγω υ μιν ὁτι ‾̷‾ πᾶϲ ὁ απολυων τ η γυναικα ἁυτου πα ρὲκτοϲ λογου πορ νιαϲ ποιε'ι αυτην μοιχευθηναι · και ὁϲ αν εαν απολε λυμενην γαμη ϲη μοιχατε μοιχαται : ‾̷‾",
          "translation": "'But I tell you: anyone who divorces his wife, except for sexual immorality, causes her to commit adultery. And whoever marries a divorced woman commits adultery.'",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "παλιν ηκουϲατε ο τι ερρέθη τοιϲ αρ χαιοιϲ ουκʼ εφιὁρ κηϲειϲ · αποδωϲιϲ δε τω κω τουϲ ορ κουϲ ϲου :",
          "translation": "'Again, you have heard that it was said to the people long ago: Do not break your oath, but keep your oaths to the Lord.'",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "εγω δε λεγω υ μ ι μη ομοϲαι ολωϲ · μητε εν τω ο υν ω ο υνω ὁτι θρονοϲ εϲτιν του θυ θυ",
          "translation": "'But I tell you: do not swear at all — not by heaven, for it is God's throne,'",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "μητε εν τη γη ὁτι υ ποποδι ον εϲτιν των πο δων αυτου · μητε ειϲ ϊεροϲολυμα ὁ τι πολιϲ εϲτιν του μεγαλου βαϲιλε ωϲ ·",
          "translation": "'or by the earth, for it is his footstool, or by Jerusalem, for it is the city of the great King.'",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "μητε μηδε μητε εν τη κε φαλη ‾̷‾ ϲου ομοϲηϲ ὁτι ου δυναϲαι μι αν τριχαν τριχα λευκ η ποιηϲαι ἠ μελαι ναν ·",
          "translation": "'And do not swear by your head, for you cannot make a single hair white or black.'",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "εϲτω δε ο λογοϲ ‾̷‾ υ μων ναι ναι · ου ου · το δε περιϲϲον του των εκ του πονη ρου εϲτιν : ‾̷‾",
          "translation": "'Simply let your yes be yes and your no be no. Anything more than this comes from the evil one.'",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "ηκουϲατε ὁτι ερρέ θη οφθαλμον αν τι οφθαλμου · και ὁδόντα αντι οδ ο τοϲ",
          "translation": "'You have heard that it was said: An eye for an eye and a tooth for a tooth.'",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "εγω δε λεγω υ μιν μη αντιϲτα θηναι τω πονη ρω ‾̷‾ : αλλ οϲτιϲ ϲε ρα πιζι ειϲ επι την δε ξιαν ϲιαγονα ϲτρε ψον αυτω και τ η αλλην",
          "translation": "'But I tell you: do not resist an evil person. If anyone slaps you on the right cheek, turn the other to him as well.'",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "και τω θε λοντι ϲοι κριθη ναι και τον χιτω να ϲου λαβιν αφεϲ τουτω αυτω και το ϊμα τιον ‾̷‾ ϲου :",
          "translation": "'If anyone wants to sue you and take your shirt, let him have your coat as well.'",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "και οϲτιϲ ϲε εαν ενγαρευϲη μιλιον εν υ παγε μετ αυτου δυο",
          "translation": "'If anyone forces you to go one mile, go with him two miles.'",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "τω αιτουντι ϲοι ϲε δοϲ και τον θελοντα απο ϲου δανιϲα ϲθαι μη αποϲτρα φηϲ",
          "translation": "'Give to the one who asks you, and do not turn away the one who wants to borrow from you.'",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "ηκουϲατε οτι ερ ρεθη αγαπηϲειϲ τον πληϲιον ϲου και μιϲηϲειϲ τον ‾̷‾ εχθρον ϲου ·",
          "translation": "'You have heard that it was said: Love your neighbor and hate your enemy.'",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "εγω δε λεγω υ μιν α γαπατε τουϲ ε χθρουϲ υμων και προϲευχεϲθαι υ περ των διωκον των υ μαϲ",
          "translation": "'But I tell you: love your enemies and pray for those who persecute you,'",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "οπωϲ γενηϲθε υϊοι του π ρ ϲ πρϲ ϋμων του ε ν ουρανοιϲ οτι τον ηλιον αυτου ανατελλι επι πο νηρουϲ και αγα θουϲ και βρεχι επι και βρεχι επι δικ(αι)ουϲ κ(αι) αδικουϲ ‾̷‾",
          "translation": "'so that you may be children of your Father in heaven. For he makes his sun rise on the evil and the good, and sends rain on the righteous and the unrighteous.'",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "εαν γαρ αγαπηϲη τε τουϲ αγαπων ταϲ υ μαϲ τινα μιϲ θον εχετε ουχι και οι τελωναι το αυτο ποιουϲιν",
          "translation": "'If you love only those who love you, what reward will you have? Do not even the tax collectors do the same?'",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "και εαν αϲπαϲη ϲθε τουϲ αδελφουϲ υ μων μονον τι περιϲϲον ποι ειται ουχι και οι εθνικοι το αυτο ποιουϲιν",
          "translation": "'And if you greet only your brothers, what are you doing more than others? Do not even the Gentiles do the same?'",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "εϲεϲθε ουν ϋμιϲ τε λιοι ωϲ ο πη ρ ϋμ ω ο ουρανιοϲ τελιοϲ ‾̷‾ εϲτιν :",
          "translation": "'Therefore, be perfect, as your heavenly Father is perfect.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 6,
      "verses": [
        {
          "verse": 1,
          "original": "προϲεχετε δε την δικαιοϲυ νην δοϲειν δικ(αι)οϲυνην υ μων μη ποιειν εμπροϲ θεν των α νω ν ανων προϲ το θεαθηνε αυτοιϲ ει δε μη γε μιϲθον ουκ εχετε παρα τω πρ ι πρι υ μ ω υ μ ω τω εν τοιϲ ου νο ιϲ ου νοι ϲ",
          "translation": "'Be careful not to practice your righteousness in front of people, to be seen by them. Otherwise, you have no reward from your Father in heaven.'",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "οταν ουν ποιηϲε̣ι̣ϲ̣ ποιηϲ ελεημοϲυνην μη ϲαλπιϲηϲ εμ προϲθεν ϲου ωϲ περ οι ϋποκριται ποιουϲιν εν τεϲ ϲυναγωγεϲ ταιϲ ϲυναγωγαιϲ και εν ταιϲ ρυμαιϲ ο πωϲ δοξαϲθωϲ ι υ πο των α νω ν ανω ν αμην αμην λεγω υ μιν απεχουϲ ι τον μιϲθον αυτ ω",
          "translation": "'So when you give to the needy, do not announce it with trumpets, as the hypocrites do in the synagogues and on the streets, to be praised by others. Truly I tell you, they have received their reward in full.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ϲου δε ποιουντοϲ ελαιημοϲυνην μη γνωτω η αριϲτε ρα ϲου τι ποιει η δεξια ϲου",
          "translation": "'But when you give to the needy, do not let your left hand know what your right hand is doing,'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "οπωϲ η ϲου ελεημοϲυ νη η η ελεημοϲυνη εν τω κρυ πτω και ο πηρ ϲου ο βλεπων εν τω κρυπτω αποδωϲι ϲοι",
          "translation": "'so that your giving may be in secret. And your Father who sees in secret will reward you.'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "και οταν προϲευ χη προϲευχηϲθαι · ουκ εϲεϲθε ωϲ [1 chars] οι υ ποκριται οτι φι λουϲιν εν ταιϲ ϲυ ναγωγαιϲ και εν ταιϲ γωνιαιϲ τ ω πλατιων εϲτω τεϲ προϲευχεϲθε οπωϲ φανωϲιν τοιϲ ανθρωποιϲ αμην λεγω υ μιν απεχουϲι τον μι ϲθον αυτων",
          "translation": "'When you pray, do not be like the hypocrites. They love to pray standing in the synagogues and on the street corners to be seen by people. Truly I tell you, they have received their reward in full.'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ϲυ δε οταν προϲευχηϲ προϲευχη ειϲελθε ειϲ το τα μιον ϲου και κλι ϲαϲ την θυραν ϲου προϲευξε [1 chars] τω π ρ ι πρ ι ϲου τω εν τω κρυπτω και ο π η ρ ϲου ο βλε πων εν τω κρυ πτω αποδωϲι ϲοι ‾̷‾",
          "translation": "'But when you pray, go into your room, shut the door, and pray to your Father who is in secret. And your Father who sees in secret will reward you.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "προϲευχομενοι δε μη βατταλογη ϲηται ωϲπερ οι ε θνικοι ε [1 chars] νικοι δοκουϲιν γαρ οτι εν τη πολυ λογια αυτων ειϲα κουϲθηϲονται",
          "translation": "'When you pray, do not babble on like the pagans, who think they will be heard because of their many words.'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "μη ουν ομοιωθητε αυτοιϲ οιδεν γαρ ο θϲ ο πη ρ ϋμων ων χριαν εχετε προ του ϋμαϲ αιτηϲαι αυτον",
          "translation": "'Do not be like them, for your Father knows what you need before you ask him.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "ουτωϲ ουν προϲ ευχεϲθαι ϋμειϲ περ ημων ο εν τοιϲ ο υνο ιϲ αγιαϲθη τω το ονομα ϲου",
          "translation": "'Pray then like this: Our Father in heaven, hallowed be your name.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ελθατω η βαϲιλια ϲου γενηθητω το θε λημα ϲου ωϲ εν ου ρανω και επι γηϲ",
          "translation": "'Your kingdom come. Your will be done, on earth as it is in heaven.'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "τον αρτον ημων τον επιουϲιον δοϲ ημιν ϲημερον",
          "translation": "'Give us today our daily bread.'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και αφεϲ ημιν τα οφιληματα ημ ω ωϲ και ημιϲ αφη καμεν αφιαιμεν τοιϲ οφι λεταιϲ ημων",
          "translation": "'And forgive us our debts, as we also have forgiven our debtors.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και μη ειϲενεγκηϲ η μαϲ ειϲ πιραϲμ ο αλλα ρυϲαι ημαϲ απο του πονηρου : ‾̷‾",
          "translation": "'And lead us not into temptation, but deliver us from the evil one.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "εαν γαρ αφηται τοιϲ α νοι ϲ τα παραπτω υτων αυτων αφη ϲι και υ μιν ο πη ρ υ μων ο ουρανιοϲ",
          "translation": "'For if you forgive other people their offenses, your heavenly Father will also forgive you.'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "εαν δε μη αφητε τοιϲ α νοι ϲ ουδε ο πη ρ υ μιν αφηϲι τα παραπτωματα υ μων ‾̷‾",
          "translation": "'But if you do not forgive others, your Father will not forgive your offenses.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και οταν δε νηϲτευ ητε μη γινεϲθε ωϲ οι υ ποκριται ϲκυ θρωποι αφανιζου ϲι γαρ το προϲωπ ο τα προϲωπα αυτων οπωϲ φα νωϲι τοιϲ α νο ιϲ ανο ιϲ νηϲτευοντεϲ αμην γαρ λεγω υ μ ι απεχουϲιν τον μιϲθον αυτων",
          "translation": "'When you fast, do not look gloomy like the hypocrites. They disfigure their faces so that people can see they are fasting. Truly I tell you, they have received their reward in full.'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ϲυ δε νηϲτευων αλι ψε ϲου την κεφα λην και το προϲω πον ϲου νιψαι",
          "translation": "'But when you fast, anoint your head and wash your face,'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ο πωϲ μη φανηϲ τοιϲ α νο ιϲ νηϲ τευων αλλα τω πρ ι ϲου τω εν τω κρυφαιω και ο πη ρ ϲου ο βλεπων ε τω κρυφεω κρυφαιω απο δωϲι ϲοι",
          "translation": "'so that your fasting may not be seen by people but by your Father who is in secret. And your Father who sees in secret will reward you.'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "μη θη ϲαυριζετε υ μιν θηϲαυρουϲ επι τηϲ γηϲ οπου ϲηϲ και βρωϲιϲ αφα νιζει και οπου κλε πται διορυϲϲουϲ ι και κλεπτουϲιν ‾̷‾",
          "translation": "'Do not store up for yourselves treasures on earth, where moth and rust destroy, and where thieves break in and steal.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "θηϲαυριζετε δε υ μιν θηϲαυρουϲ εν ο υν ω οπου ου τε ϲηϲ ουτε βρωϲιϲ αφανιζει και οπου κλεπται ου διορυϲ ϲουϲι και κλεπτου ϲιν",
          "translation": "'But store up for yourselves treasures in heaven, where moth and rust do not destroy, and where thieves do not break in and steal.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "οπου γαρ εϲτ ι ο θηϲαυροϲ ϲου ε κι εϲται και η καρ δια ϲου ‾̷‾",
          "translation": "'For where your treasure is, there your heart will also be.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ο λυχνοϲ του ϲω ματοϲ εϲτιν ο ο φθαλμοϲ εαν η ο οφθαλμοϲ ϲου α πλουϲ ολον το ϲωμα ϲου φωτι νον εϲτε",
          "translation": "'The eye is the lamp of the body. If your eye is good, your whole body will be full of light.'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "εαν δε η ο οφθαλμοϲ ϲου πονηροϲ ο οφθαλμοϲ ϲου πονηροϲ η ο λον το ϲωμα ϲου ϲκοτινον εϲται ει ουν το φωϲ το εν ϲοι ϲκοτοϲ ε ϲτιν το ϲκοτοϲ ποϲον ‾̷‾",
          "translation": "'But if your eye is bad, your whole body will be full of darkness. So if the light within you is darkness, how great is that darkness!'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ουδειϲ δυναται δυ ϲι κυριοιϲ δουλευ ειν ει γαρ τον ενα μιϲηϲι και τον ε τερον αγαπηϲι αγαπηϲει ˙ η ενοϲ ανθεξε τε και του ετερου καταφρονηϲει ου δυναϲθε θω δουλευειν και μαμωνα ‾̷‾",
          "translation": "'No one can serve two masters. Either you will hate the one and love the other, or you will be devoted to the one and despise the other. You cannot serve God and money.'",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "δια τουτο λεγω ϋ μιν μη μεριμνα ται τη ψυχη υ μ ω τι φαγηται μηδε τω ϲωματι υ μων τι εν δυϲηϲθε ουχι η ψυχη πλειον εϲ τι τηϲ τροφηϲ κ(αι) το ϲωμα του εν δυματοϲ",
          "translation": "'Therefore I tell you: do not worry about your life — what you will eat or drink — or about your body — what you will wear. Is not life more than food and the body more than clothing?'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "εμβλε ψαται ειϲ τα πετι να του ο υνο υ ο τι ου ϲπιρουϲιν ουδε θεριζουϲιν ουδε ϲυναγουϲ ι ειϲ ταϲ αποθηκαϲ και ο πη ρ ϋμων ο ουρανιοϲ τρε φι αυτα ουχ υμειϲ μαλλον διαφερε ται αυτων",
          "translation": "'Look at the birds of the air: they do not sow or reap or store away in barns, and yet your heavenly Father feeds them. Are you not worth much more than they?'",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "τιϲ δε ε ξ υμων μεριμν ω δυναται προϲθει ναι επι την ηλι κιαν αυτου πη χυν ενα",
          "translation": "'Which of you by worrying can add a single hour to your life?'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "και περι ενδυματοϲ τι με ριμναται καταμα θεται τα κρινα του αγρου πωϲ αυξα νουϲιν ου κοπι ωϲιν ουδε νη> θουϲιν · ου ξαινουϲιν ουδε νηθουϲιν ουδε κοπιωϲιν",
          "translation": "'And why do you worry about clothing? Consider the lilies of the field, how they grow: they do not labor or spin.'",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "λεγω δε ϋμιν ο τι ουδε ϲολομ ω εν παϲη τη δοξη αυτου περιεβαλε το ωϲ εν τουτων",
          "translation": "'Yet I tell you that not even Solomon in all his glory was dressed like one of these.'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ϊ δε τον χορτον του αγρου ϲημερον οντα και αυριον ειϲ κλιβανον βαλ λομενον ο θϲ ου τωϲ αμφιεννυϲ ι ου πολλω μαλλ ο υ μαϲ ολιγοπιϲτοι",
          "translation": "'If that is how God clothes the grass of the field, which is alive today and tomorrow is thrown into the furnace, will he not much more clothe you, you of little faith?'",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "μη ουν μεριμνη ϲητε λεγοντεϲ τι φαγωμεν η τι πιωμεν η τι περι βαλωμεθα",
          "translation": "'So do not worry, saying, \"What will we eat?\" or \"What will we drink?\" or \"What will we wear?\"'",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "ταυτα γαρ παντα τα εθνη επιζητουϲιν οι δεν γαρ δε γαρ ο θϲ ο πη ρ ϋμων οτι χρηζε τε τουτων απαν των",
          "translation": "'For the pagans run after all these things, and your heavenly Father knows you need them.'",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "ζητειτε δε γ̣α̣ρ̣ πρωτον την βαϲι λειαν και την δι καιοϲυνην αυτου και ταυτα παντα προϲτεθηϲεται ϋμιν",
          "translation": "'But seek first the kingdom of God and his righteousness, and all these things will be given to you as well.'",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "μη ουν με ριμνηϲητε ειϲ την αυριον η γαρ αυριον μεριμνηϲι εαυτηϲ αρκετον τη ημερα η κακια αυτηϲ ‾̷‾",
          "translation": "'Therefore do not worry about tomorrow, for tomorrow will worry about itself. Each day has enough trouble of its own.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 7,
      "verses": [
        {
          "verse": 1,
          "original": "μη κρινεται ϊνα μη κριθητε",
          "translation": "'Do not judge, so that you will not be judged.'",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "εν ω γαρ κριματι κρινε τε κριθηϲεϲθαι και εν ω μετρω μετριται μετρη θηϲεται ϋμιν ‾̷‾",
          "translation": "'For with the judgment you pronounce you will be judged, and with the measure you use it will be measured to you.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "τι δε βλεπιϲ το καρ φοϲ το εν τω ο φθαλμω του αδελ φου ϲου την δε δο κον την εν τω ϲω οφθαλμω εν τω ϲω οφθαλμω δοκον ου κα τανοειϲ",
          "translation": "'Why do you look at the speck in your brother's eye, but fail to notice the log in your own eye?'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "η πωϲ λεγιϲ εριϲ εριϲ τω αδελφω ϲου αδελφε αφεϲ εκβαλω το καρφοϲ εκ του οφθαλμου ϲου και ϊδου η δο κοϲ εν τω οφθαλ μω ϲου",
          "translation": "'How can you say to your brother, \"Let me take the speck out of your eye,\" when there is a log in your own eye?'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ϋποκριτα εκβαλε πρωτον εκ του οφθαλμου ϲου την δοκον και τοτε διαβλε ψιϲ εκβαλλειν το καρφοϲ εκ του ο φθαλμου του α δελφου ϲου ‾̷‾",
          "translation": "'You hypocrite! First take the log out of your own eye, and then you will see clearly to take the speck out of your brother's eye.'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "μη δωτε το αγιον τοιϲ κυϲιν μηδε βαλητε τουϲ μαρ γαριταϲ ϋμων εμπροϲθεν τ ω χοιρων μηποτε καταπατηϲωϲιν αυτουϲ εν τοιϲ πο ϲιν αυτων και ϲτραφεντεϲ ρη ξωϲιν ϋμαϲ",
          "translation": "'Do not give what is holy to the dogs, and do not throw your pearls before pigs, or they will trample them underfoot and turn and tear you to pieces.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "αιτειτε και δοθη ϲεται ϋμιν ζητει τε και ευρηϲετε κρουεται και ανοι γηϲεται ϋμιν",
          "translation": "'Ask, and it will be given to you. Seek, and you will find. Knock, and the door will be opened to you.'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "παϲ γαρ ο αιτων λαμ βανει και ο ζητ ω ευριϲκει και τω κρουοντι ανοι γηϲεται : [2 chars]",
          "translation": "'For everyone who asks receives, the one who seeks finds, and to the one who knocks, the door will be opened.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "η τιϲ ε ϲτιν [1 chars] εξ ϋμων αν θρωποϲ ον εαν αιτη ϲει ο υϲ αυτου αρ τον μη λιθον ε πιδωϲι αυτω",
          "translation": "'Is there anyone among you who, if your son asks for bread, will give him a stone?'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "η και ϊχθυν αιτηϲι μη οφιν επιδω ϲει αυτω",
          "translation": "'Or if he asks for a fish, will give him a snake?'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ει ουν ϋ μιϲ πονηροι ον τεϲ οιδαται δομα τα αγαθα διδοναι τοιϲ τεκνοιϲ ϋμ ω ποϲω μαλλον ο πηρ ϋμων ο εν τοιϲ ο υνο ιϲ δωϲει αγαθα τοιϲ αιτουϲ ι αυτον",
          "translation": "'If you then, who are evil, know how to give good gifts to your children, how much more will your Father in heaven give good things to those who ask him!'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "παντα ουν οϲα εαν θε ληται ϊνα ποιωϲ ι ϋμειν ϋμ [1 chars] ν οι ανοι ου τωϲ και ϋμιϲ ποι ειται αυτοιϲ ουτοϲ γαρ εϲτιν ο νομοϲ και οι προφηται",
          "translation": "'Therefore, whatever you wish that people would do to you, do also to them. For this is the Law and the Prophets.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ειϲελθατε δια τηϲ ϲτενηϲ πυληϲ οτι πλατια η πυλη και ευ ρυχωροϲ η οδοϲ η απαγουϲα ειϲ τ η απωλιαν και πολ λοι ειϲιν οι ειϲερχομε νοι πορευομαιμενοι ειϲερχομενοι δι αυτηϲ",
          "translation": "'Enter through the narrow gate. For wide is the gate and broad is the road that leads to destruction, and many enter through it.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "οτι τι τι ϲτενη η πυλη και τεθλιμμενη η οδοϲ η απαγου ϲα ειϲ την ζωην και ολιγοι ειϲιν οι ευριϲκοντεϲ αυ την :",
          "translation": "'But small is the gate and narrow the road that leads to life, and only a few find it.'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "προϲεχεται απο των ψευδοπρο φητων οιτινεϲ ερχονται προϲ ϋ μαϲ εν ενδυμα ϲι προβατων εϲω θεν δε ειϲιν λυ κοι αρπαγεϲ",
          "translation": "'Watch out for false prophets. They come to you in sheep's clothing, but inwardly they are ravenous wolves.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "απο των καρπων αυ των επιγνωϲε ϲθε αυτουϲ : μητι ϲυλλεγουϲιν απο ακανθων ϲτα φυλαϲ η απο τρι βολων ϲυκα",
          "translation": "'You will recognize them by their fruit. Do people pick grapes from thornbushes or figs from thistles?'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ουτω παν δενδρ ο αγαθον καρπουϲ καλουϲ ποιει το δε ϲαπρον δεν δρον καρπουϲ πο νηρουϲ ποιει :",
          "translation": "'Likewise, every good tree bears good fruit, but a bad tree bears bad fruit.'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ου δυναται δενδρον · αγαθον καρπουϲ πονηρουϲ ποιειν [1 chars] ουδε δενδρον ϲα προν καρπουϲ κα λουϲ ενεγκειν ποιειν ποιειν",
          "translation": "'A good tree cannot bear bad fruit, and a bad tree cannot bear good fruit.'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "παν δενδρον μη ποιουν καρπον καλον εκκοπτε ται και ειϲ πυρ βαλ λεται",
          "translation": "'Every tree that does not bear good fruit is cut down and thrown into the fire.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "αρα γε απο των καρπων αυ των επιγνωϲε ϲθαι αυτουϲ :",
          "translation": "'Thus, by their fruit you will recognize them.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ου παϲ ο λεγων μοι κε κε ειϲελευ ϲεται ειϲ την βα ϲιλιαν των ουρα νων αλλ ο ποι ω τα θεληματα το θελημα του πρϲ μου του εν τοιϲ ο υνοι ϲ",
          "translation": "'Not everyone who says to me, \"Lord, Lord,\" will enter the kingdom of heaven, but only the one who does the will of my Father in heaven.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "πολλοι ερουϲιν μοι εν εκεινη τη ημερα κε κε ου τω ϲω ονοματι επρο φητευϲαμεν και τω ϲω ονοματι δε μονια πολλα εξε βαλλομεν εξεβαλομεν και τω ϲω ονοματι δυ ναμιϲ πολλαϲ ε ποιηϲαμεν",
          "translation": "'On that day many will say to me, \"Lord, Lord, did we not prophesy in your name, cast out demons in your name, and perform many miracles in your name?\"'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και τοτε ομολογηϲω αυτοιϲ οτι ουδεπο τε εγνων ϋμαϲ αποχωρειτε απ ε μου οι εργαζομε νοι την ανομιαν",
          "translation": "'Then I will tell them plainly: \"I never knew you. Depart from me, you who practice lawlessness!\"'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "παϲ ουν οϲτιϲ α κουει μου τουϲ λο γουϲ τουτουϲ και ποιει αυτουϲ ομοι ωθηϲεται ανδρι φρονιμω οϲτιϲ ωκοδομηϲεν αυ του την οικιαν ε πι την πετραν",
          "translation": "'Therefore, everyone who hears these words of mine and puts them into practice is like a wise man who built his house on the rock.'",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και κατεβη η βροχη και ηλθον οι ποτα μοι και επνευϲ α οι ανεμοι και προϲ προϲεπεϲαν τη οικι α εκινη και ουκ ε πεϲεν τεθεμε λιωτο γαρ επι τ η πετραν",
          "translation": "'The rain fell, the floods came, and the winds blew and beat against that house, but it did not fall, because it was founded on the rock.'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "και παϲ και [1 chars] παϲ ο ακουων μου τουϲ λογουϲ του τουϲ και μη ποι ω αυτουϲ ομοιωθη ϲεται ανδρι μωρω οϲτιϲ ωκοδομη ϲεν αυτου την οι κιαν επι την αμ μον ψαμμον αμμον",
          "translation": "'But everyone who hears these words of mine and does not put them into practice is like a foolish man who built his house on the sand.'",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και κατεβη η βροχη και ηλθ α οι ποταμοι και επνευϲαν οι ανεμοι επνευϲαν οι ανεμοι κ(αι) προϲεκοψαν τη ︴ οικια εκινη και ε πεϲεν και ην η πτω ϲιϲ αυτηϲ μεγαλη",
          "translation": "'The rain fell, the floods came, and the winds blew and beat against that house, and it fell — and its collapse was great.'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "και εγενετο οτε ετε λεϲεν ο ιϲ τουϲ λο γουϲ τουτουϲ εξε πληττοντο εξεπληϲϲοντο επι τη διδαχη αυτου οι ο χλοι οι οχλοι επι τη διδαχη αυτου οι οχλοι επι τη διδαχη αυτου",
          "translation": "When Jesus finished saying these things, the crowds were astonished at his teaching,",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ην γαρ διδαϲ κων αυτουϲ ωϲ ε ξουϲιαν εχων και ουχ ωϲ οι γραμμα τειϲ αυτων",
          "translation": "for he taught them as one having authority, and not as their scribes.",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 8,
      "verses": [
        {
          "verse": 1,
          "original": "καταβαντι δε αυτω καταβαντοϲ δε αυτου απο του ορουϲ ηκο λουθηϲαν αυτω οχλοι πολλοι",
          "translation": "When he came down from the mountain, large crowds followed him.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ϊδου λεπροϲ προϲ ελθων προϲεκυ νει αυτω λεγων κε εαν θεληϲ δυ ναϲαι με καθαρι ϲαι",
          "translation": "A man with leprosy came and knelt before him, saying, 'Lord, if you are willing, you can make me clean.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και εκτιναϲ τ η χειρα αυτου αυτου ηψατο αυτου λεγων θελω καθαριϲθητι και ε καθαριϲθη ευθεωϲ εκαθαριϲθη αυτου η λεπρα",
          "translation": "Jesus reached out his hand and touched him, saying, 'I am willing. Be clean.' Immediately his leprosy was cleansed.",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και ειπεν λεγι αυτω ο ιϲ ορα μηδε νι ειπηϲ αλλα υ πα γε ϲεαυτον διξον τω ϊερει και προϲε νεγκε το δωρον ο προϲεταξεν μω ὑϲηϲ ειϲ μαρτυρι ο αυτοιϲ",
          "translation": "Then Jesus said to him, 'See that you do not tell anyone, but go show yourself to the priest and offer the gift Moses commanded, as a testimony to them.'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ειϲελθοντοϲ δε αυ του ειϲ καφαρναουμ προϲηλθεν αυτω εκατονταρχηϲ εκατονταρχοϲ πα ρακαλων αυτον",
          "translation": "When he entered Capernaum, a centurion came to him, pleading with him,",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και λεγων κε ο παιϲ μου βεβληται εν τη οικια παραλυτι κοϲ δινωϲ βαϲα νιζομενοϲ",
          "translation": "'Lord, my servant is lying at home paralyzed, suffering terribly.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "και λε γι αυτω ακολουθι μοι εγω ελθων θε ραπευϲω αυτον",
          "translation": "Jesus said to him, 'I will come and heal him.'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αποκριθειϲ δε κ(αι) αποκριθειϲ κ(αι) αποκριθειϲ ο ε κατονταρχηϲ εκατονταρχοϲ ει εφη εφη κε ουκ ειμι ϊ κανοϲ ϊνα μου υ πο την ϲτεγην ει ϲελθηϲ αλλα μον ο ειπε λογω και ϊα θηϲεται ο παιϲ μου",
          "translation": "The centurion replied, 'Lord, I am not worthy for you to come under my roof. Just say the word, and my servant will be healed.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και γαρ εγω ανο ϲ ει μι ϋπο εξουϲιαν ταϲϲομενοϲ εχ ω εχ ω ϋπ εμαυτον ϲτρα τιωταϲ και λεγω τουτω πορευθητι και πορευετε και αλλω ερχου και ερ χετε και τω δουλω μου ποιηϲον του το και ποιει ·",
          "translation": "'For I too am a man under authority, with soldiers under me. I say to one, \"Go,\" and he goes, and to another, \"Come,\" and he comes, and to my servant, \"Do this,\" and he does it.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ακουϲαϲ δε ο ιϲ ε θαυμαϲεν και ει πεν τοιϲ ακολου θουϲιν αμην λε γω υ μιν ουδε εν τω ι ηλ τοϲαυτην πιϲτιν ευρον",
          "translation": "When Jesus heard this, he was amazed and said to those following him, 'Truly I tell you, I have not found such faith in anyone in Israel.'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "λεγω δε ϋμιν οτι πολλοι απο ανατο λων · και δυϲμ ω ηξουϲιν και ανα κλιθηϲονται με τα αβρααμ και ϊϲακ και ϊακωβ εν τη βαϲιλεια των ου ρανων",
          "translation": "'I tell you, many will come from east and west and will recline at the table with Abraham, Isaac, and Jacob in the kingdom of heaven.'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "οι δε ϋϊοι τηϲ βαϲιλειαϲ εκβλη θηϲονται εξελευϲονται ειϲ το ϲκοτοϲ το εξωτε ρον · εκει εϲτε ο κλαυ θμοϲ και ο βρυγ μοϲ των οδοντ ω",
          "translation": "'But the sons of the kingdom will be thrown into the outer darkness, where there will be weeping and gnashing of teeth.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και ειπεν ο ιϲ τω εκατονταρχη εκατονταρχω εκατονταρχη ϋπα γε ωϲ επιϲτευϲαϲ γενηθητω ϲοι και ϊαθη ο παιϲ εν τη ωρα εκεινη και ϋ ποϲτρεψαϲ ο εκατ ο ταρχοϲ ειϲ τον οι κον αυτου εν αυτη τη ωρα ευρεν τ ο παιδα ϋγιαινοντα και ϋποϲτρεψαϲ ο εκατ ο ταρχοϲ ειϲ τον οικον αυτου εν αυτη τη ωρα ευρεν τ ο παιδα ϋγιαινοντα",
          "translation": "Then Jesus said to the centurion, 'Go. As you have believed, let it be done for you.' And his servant was healed at that very hour.",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και ελθων ο ιϲ ιϲ ειϲ την οικιαν πετρου ειδεν την πενθε ραν αυτου βεβλη μενην και πυρεϲ ϲουϲαν",
          "translation": "Jesus went into Peter's house and saw Peter's mother-in-law lying in bed with a fever.",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και ηψατο τηϲ χιροϲ αυτηϲ και αφηκεν αυτ η αυτ η ο πυρετοϲ και εγερ θιϲ ηγερθη κ(αι) διηκονι αυτοιϲ αυτω̣",
          "translation": "He touched her hand, and the fever left her. She got up and began to serve him.",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "οψιαϲ δε γενομε νηϲ προϲηνεγκ α προϲηνεγκ α αυτω δαιμονιζο μενουϲ πολλουϲ και εξεβαλεν τα πνα τα λογω και παν ταϲ τουϲ κακωϲ ε χονταϲ εθεραπευϲ ε",
          "translation": "When evening came, they brought to him many who were possessed by demons. He drove out the spirits with a word and healed all who were sick.",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "οπωϲ πληρωθη το ρηθεν δια ηϲαϊου του προφητου λε γοντοϲ αυτοϲ ταϲ αϲθενιαϲ ημων ελαβεν και ταϲ νο ϲουϲ εβαϲταϲεν",
          "translation": "This fulfilled what was spoken through the prophet Isaiah: 'He took our weaknesses and bore our diseases.'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ϊδων δε ο ιϲ πολλουϲ οχλουϲ περι αυτον εκελευ ϲεν απελθειν ειϲ το περαν",
          "translation": "When Jesus saw a crowd around him, he gave orders to go to the other side of the sea.",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και προϲελθων ειϲ γραμματευϲ ειπ ε αυτω διδαϲκαλε ακολουθηϲω ϲοι οπου εαν απερχη",
          "translation": "A scribe came and said to him, 'Teacher, I will follow you wherever you go.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και λεγει αυτω ο ιϲ αι αλωπεκεϲ φω λεουϲ εχουϲιν και τα πετινα του ο υνου καταϲκηνω ϲιϲ ο δε ϋϊοϲ του αν θρωπου ουκ εχι που την κεφαλ η κλινη ·",
          "translation": "Jesus said to him, 'Foxes have dens and birds of the sky have nests, but the Son of Man has nowhere to lay his head.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ετεροϲ δε των μα θητων ειπεν αυ τω κε επιτρεψον μοι πρωτον απελ θειν και θαψε τον πρ α μου",
          "translation": "Another of the disciples said to him, 'Lord, let me first go and bury my father.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ο δε λεγι αυτω ακο λουθι μοι και αφεϲ τουϲ νεκρουϲ θα ψε τουϲ εαυτων νεκρουϲ",
          "translation": "But Jesus said to him, 'Follow me, and let the dead bury their own dead.'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και εμβαντι αυτω ειϲ το το πλοιον ηκο λουθηϲαν αυτω οι μαθητε αυτου",
          "translation": "When he got into the boat, his disciples followed him.",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "και ϊδου ϲιϲμοϲ μεγαϲ εγενετο εν τη θαλαϲϲη ωϲτε το πλοιον καλυπτε ϲθε ϋπο των κυμα των αυτοϲ δε εκα θευδεν",
          "translation": "Suddenly a great storm arose on the sea, so that the waves covered the boat. But Jesus was sleeping.",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και προϲ ελθοντεϲ ηγιραν αυτον λεγοντεϲ κε ϲωϲον απολλυ μεθα",
          "translation": "They went and woke him, saying, 'Lord, save us! We are perishing!'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "και λεγι αυτοιϲ τι δι λοι εϲτε ολιγοπιϲ τοι τοτε εγερθιϲ ε πετιμηϲεν τω α νεμω τοιϲ ανεμοιϲ και τη θαλ λαϲϲη και εγενε το γαληνη μεγαλη",
          "translation": "He said to them, 'Why are you afraid, you of little faith?' Then he got up and rebuked the winds and the sea, and there was a great calm.",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "οι δε ανοι εθαυμα ϲαν λεγοντεϲ πο ταποϲ εϲτιν ουτοϲ οτι και οι ανεμοι και η θαλαϲϲα αυ τω υπακουουϲ ι",
          "translation": "The men were amazed, saying, 'What kind of man is this? Even the winds and the sea obey him!'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "και ελθοντων αυ των ελθοντοϲ αυτου ειϲ το περ α ειϲ την χωραν τ ω γαζαρηνων γεργεϲηνων υπ η τηϲαν αυτω δυο δεμονιζομενοι δαιμονιζομενοι · εκ των μνημι ω εξερχομενοι χα λεποι λιαν ωϲτε μη ϊϲχυειν τινα παρελθειν δια τηϲ οδου εκινηϲ",
          "translation": "When he arrived at the other side, in the region of the Gadarenes, two demon-possessed men coming from the tombs met him. They were so violent that no one could pass that way.",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και ϊδου εκραξαν λε γοντεϲ τι ημιν κ(αι) ϲοι ϋϊε υε του θυ ηλθεϲ ωδε ημαϲ απολε ϲαι προ καιρου προ καιρου βαϲανιϲαι ημαϲ",
          "translation": "They cried out, 'What do you want with us, Son of God? Have you come here to torment us before the appointed time?'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ην δε μακραν α π αυτων χοιρων πολλων βοϲκομενη",
          "translation": "Some distance away, a large herd of pigs was feeding.",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "οι δε δαιμονεϲ πα ρεκαλουν αυτ ο αυτ ο λεγοντεϲ ει εκβαλ λιϲ ημαϲ αποϲτι λον ημαϲ ειϲ την αγελην των χοι ρων",
          "translation": "The demons begged him, 'If you drive us out, send us into the herd of pigs.'",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "και ειπεν αυ τοιϲ ϋπαγετε οι δε εξελθοντεϲ απηλθον ειϲ τουϲ χοιρουϲ και ϊδου ωρμηϲεν παϲα η αγελη κατα του κρη μνου ειϲ την θα λαϲϲαν και απε θανον απεθαναν εν τοιϲ ϋδα ϲιν",
          "translation": "He said to them, 'Go!' So they came out and went into the pigs. The whole herd rushed down the steep bank into the sea and died in the water.",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "οι δε βοϲκον τεϲ εφυγον και απελθοντεϲ ειϲ την πολιν απηγ γιλαν παντα και τα των δαιμονι ζομενων",
          "translation": "The herdsmen ran away and went into the town and reported everything, including what had happened to the demon-possessed men.",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "και ϊ δου παϲα η πολιϲ εξηλθεν ειϲ ϋπ α τηϲιν του ιυ και ειδοντεϲ αυτον παρεκαλεϲαν ο πωϲ μεταβη απο των οριων αυτ ω",
          "translation": "The whole town came out to meet Jesus. When they saw him, they begged him to leave their region.",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 9,
      "verses": [
        {
          "verse": 1,
          "original": "και εμβαϲ ειϲ πλοι ον διεπεραϲεν κ(αι) ηλθεν ειϲ την ϊ διαν πολιν",
          "translation": "Jesus got into a boat, crossed over, and came to his own town.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ϊδου προϲεφε ρον αυτω παραλυ τικον επι κλινηϲ βεβλημενον · και ειδων ο ιϲ ιϲ την πι ϲτιν αυτων ειπεν τω παραλυτικω θαρϲει τεκνον α φιενται ϲου αι αμαρ τιαι",
          "translation": "Some people brought to him a paralyzed man lying on a mat. When Jesus saw their faith, he said to the paralyzed man, 'Take courage, son. Your sins are forgiven.'",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και ϊδου τινεϲ τ ω τ ω γραμματεων ει πον εν εαυτοιϲ ου τοϲ βλαϲφημει",
          "translation": "Some of the scribes said to themselves, 'This man is blaspheming!'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και ϊδων ο ιϲ ιϲ ταϲ ε θυμηϲειϲ αυτων ειπεν ϊνατι ενθυ μειϲθε πονηρα εν ταιϲ καρδιεϲ καρδιαιϲ ϋ μων",
          "translation": "Jesus knew what they were thinking and said, 'Why do you think evil in your hearts?'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "τι γαρ εϲτιν ευκοπωτερον ει πειν αφιονται αφιενται ϲου αι αμαρτιαι η ειπειν εγειρε κ(αι) περι πατι",
          "translation": "'Which is easier: to say, \"Your sins are forgiven,\" or to say, \"Get up and walk\"?'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ϊνα δε ειδητε οτι εξουϲιαν εχι ο υϲ υϲ του ανου επι τηϲ γηϲ αφιεναι αμαρτιαϲ τοτε λεγει τω παρα λυτικω εγερθειϲ αρον ϲου την κλι νην και πορευου υπαγε ειϲ τον οικον ϲου",
          "translation": "'But so you may know that the Son of Man has authority on earth to forgive sins...' Then he said to the paralyzed man, 'Get up, pick up your mat, and go home.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "και εγερθειϲ απηλ θεν ειϲ τον οικον αυτου",
          "translation": "The man got up and went home.",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ϊδοντεϲ δε οι οχλοι εφοβηθηϲαν κ(αι) εδοξαϲαν τον θν τον δοντα εξουϲι αν τοιαυτην τοιϲ α νοι ϲ",
          "translation": "When the crowds saw this, they were filled with awe and praised God, who had given such authority to people.",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και παραγων ο ιϲ ιϲ εκιθ ε ειδεν α νο ν α νον εκι καθη μενον επι το τε λωνιον μαθθαι ον λεγομενον κ(αι) λεγι αυτω ακολου θι μοι και αναϲταϲ ηκολουθει αυτω",
          "translation": "As Jesus passed on from there, he saw a man named Matthew sitting at the tax booth. He said to him, 'Follow me.' He got up and followed him.",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και ανακειμεν ω κ(αι) εγενετο ανακιμενου αυτου εν τη οικια ϊδου πολλοι τελωνε τελωναι και αμαρτωλοι ϲυ νανεκιντο ελθοντεϲ ϲυνανεκιντο τω ιυ και τοιϲ μαθητεϲ αυτου ·",
          "translation": "While Jesus was reclining at the table in Matthew's house, many tax collectors and sinners came and ate with him and his disciples.",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "και ϊδοντεϲ οι φαριϲαιοι ελεγ ο τοιϲ μαθηταιϲ αυ του δια τι μετα των τελωνων και α μαρτωλων εϲθι ει ο διδαϲκαλοϲ ϋμων",
          "translation": "When the Pharisees saw this, they said to his disciples, 'Why does your teacher eat with tax collectors and sinners?'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ο δε ακουϲαϲ ειπ ε ου χριαν εχουϲ ι οι ϊϲχυοντεϲ ϊατρ ω ϊατρ ω αλλ οι κακωϲ εχ ο τεϲ εχ ο τεϲ",
          "translation": "Jesus heard this and said, 'It is not the healthy who need a doctor, but the sick.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "πορευθεντεϲ δε μαθεται τι εϲτ ι εϲτ ι ελεοϲ θελω και ου θυϲιαν ου γαρ ηλ θον καλεϲαι δικαι ουϲ αλλα αμαρτω λουϲ",
          "translation": "'Go and learn what this means: I desire mercy, not sacrifice. For I did not come to call the righteous, but sinners.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "τοτε προϲερ χονται αυτω οι μαθηται ϊωαν νου λεγοντεϲ δι α τι ημιϲ και οι φα ριϲαιοι νηϲτευο μεν πυκνα πολλα οι δε μαθη ται ϲου ου νηϲτευ ουϲιν",
          "translation": "Then John's disciples came to him, saying, 'Why do we and the Pharisees fast, but your disciples do not fast?'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και ειπεν αυτοιϲ ο ιϲ μη δυνανται οι ϋϊοι του νυμφω νοϲ πενθειν ε φ οϲον μετ αυτ ω εϲτιν ο νυμφι οϲ ελευϲονται δε ημεραι οταν απαρθη απ αυ των ο νυμφειοϲ και τοτε νηϲτευ ϲουϲιν",
          "translation": "Jesus said to them, 'Can the wedding guests mourn while the bridegroom is with them? The days will come when the bridegroom is taken from them, and then they will fast.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ουδειϲ δε επιβαλ λει επιβλημα ρα κουϲ αγναφου ε πι ϊματιω παλεω αιρι γαρ το πληρω μα αυτου απο του ϊματιου και χειρον ϲχιϲμα γεινεται",
          "translation": "'No one sews a patch of unshrunk cloth on an old garment, for the patch will pull away from the garment and the tear will get worse.'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ουδε βαλλουϲιν οι νον νεον ειϲ αϲκουϲ παλαιουϲ ει δε μη γε ρηγνυνται οι α ϲκοι και ο οινοϲ εκ χειται και οι αϲκοι απολλυνται αλλ οινον νεον ειϲ αϲκουϲ καινουϲ βλητεον και αμ φοτεροι ϲυντηρο υ ται",
          "translation": "'Nor do people pour new wine into old wineskins. Otherwise the wineskins burst, the wine spills, and the wineskins are ruined. No, they pour new wine into new wineskins, and both are preserved.'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ταυτα αυτου λαλο υ τοϲ αυτοιϲ ϊδου αρ χων προϲελθ ω ειϲ προϲελθ ω ειϲελθ ω προϲεκυνι αυτω λεγων η θυγατηρ μου αρτι ετελευ τηϲεν αλλα ελθ ω επιθεϲ την χει ρα ϲου επ αυτην και ζηϲεται",
          "translation": "While he was saying these things, a synagogue leader came and knelt before him, saying, 'My daughter has just died. But come and lay your hand on her, and she will live.'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και εγερθειϲ ο ιϲ ηκολουθει αυτω και οι μαθηται αυ του",
          "translation": "Jesus got up and went with him, and so did his disciples.",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και ϊδου γυνη αιμαροουϲα αιμοροουϲα δω δεκα ετη προϲελ θουϲα οπιϲθεν ηψατο του κραϲπε δου του ϊματιου αυτου",
          "translation": "Just then, a woman who had been suffering from bleeding for twelve years came up behind him and touched the fringe of his cloak.",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ελεγεν γαρ εν εαυτη εαν α ψωμαι μονον αψωμαι του ϊματι ου αυτου ϲωθηϲο μαι",
          "translation": "She said to herself, 'If I only touch his cloak, I will be healed.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ο δε ιϲ ϲτραφειϲ και ϊδων αυτην ειπ ε θαρϲι θυγατερ η πι ϲτιϲ ϲου ϲεϲωκεν ϲε και εϲωθη η γυ νη απο τηϲ ωραϲ εκινηϲ",
          "translation": "Jesus turned and saw her. 'Take courage, daughter,' he said. 'Your faith has healed you.' And the woman was healed from that moment.",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και ελθ ω ο ιϲ ειϲ την οικι α του αρχοντοϲ και ϊδων τουϲ αυλη ταϲ ︴ και τον οχλον θορυβουμενον",
          "translation": "When Jesus came to the leader's house and saw the flute players and the noisy crowd,",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ελεγεν αναχωρι τε ου γαρ απεθαν ε το κοραϲιον αλλα καθευδει και κατε γελων αυτου ειδο τεϲ οτι απεθανεν",
          "translation": "he said, 'Go away! The girl is not dead but sleeping.' They laughed at him.",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "οτε δε εξεβληθη ο οχλοϲ ειϲελθ ω εκρατηϲεν τηϲ χιροϲ αυτηϲ και η γερθη το κοραϲι ο",
          "translation": "But when the crowd had been put outside, he went in and took her by the hand, and the girl got up.",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "και εξηλθεν η φημη αυτηϲ ειϲ ολην την γην ε κεινην",
          "translation": "News of this spread throughout that region.",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και παραγοντι εκει θεν τω ιυ ηκολου θηϲαν αυτω δυο τυφλοι κραυγαζ ο τεϲ και λεγοντεϲ ελεηϲον ημαϲ ϋϊε δαδ δαδ",
          "translation": "As Jesus went on from there, two blind men followed him, crying out, 'Have mercy on us, Son of David!'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ειϲελθοντι ελθοντι δε αυτω ειϲ την οι κιαν προϲηλθον αυτω οι δυο τυφλοι και λεγει αυτοιϲ ο ιϲ πι ϲτευετε οτι δυνα μαι υμιν τουτο ποι ηϲαι λεγουϲιν αυ τω ναι κε",
          "translation": "When he entered the house, the blind men came to him. Jesus said to them, 'Do you believe that I can do this?' 'Yes, Lord,' they answered.",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "τοτε η ψατο των οφθαλ μων αυτων λεγ ω κατα την πιϲτιν ϋμων γενηθητω ϋμιν",
          "translation": "Then he touched their eyes and said, 'According to your faith, let it be done to you.'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και ανεω χθηϲαν αυτων οι οφθαλ μοι και ενεβριμηθη αυτοιϲ ο ιϲ λεγ ω ορατε μηδιϲ γινω ϲκετω",
          "translation": "And their eyes were opened. Jesus sternly warned them, 'See that no one knows about this.'",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "οι δε εξελ θοντεϲ διεφημι ϲαν αυτον εν ολη τη γη εκεινη",
          "translation": "But they went out and spread the news about him throughout that region.",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "αυτων δε εξερχο μενων ϊδου προϲ ηνεγκαν αυτω κω φον δαιμονιζομε νον",
          "translation": "As they were going out, a demon-possessed man who could not speak was brought to him.",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "και εκβληθ ε τοϲ του δαιμονιου ελαληϲεν ο κω φοϲ και εθαυμα ϲαν οι οχλοι λεγ ο τεϲ ουδεποτε εφα νη ουτωϲ εν τω ιηλ",
          "translation": "After the demon was driven out, the man who had been mute spoke. The crowds were amazed and said, 'Nothing like this has ever been seen in Israel.'",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "οι δε φαριϲαι οι ελεγον εν τω αρχ ο τι αρχ ο τι των δαιμονι ων εκβαλλει τα δεμονια",
          "translation": "But the Pharisees said, 'He drives out demons by the ruler of demons.'",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "και περιηγεν ο ιϲ ταϲ πολιϲ παϲαϲ και ταϲ κωμαϲ δι δαϲκων εν ταιϲ ϲυναγωγαιϲ αυτ ω αυτων κ(αι) κηρυϲϲων το ευ αγγελιον τηϲ βα ϲιλειαϲ και θερα πευων παϲαν νο ϲον και παϲαν μα λακιαν εν τω λαω και ηκολουθηϲ α αυτω",
          "translation": "Jesus went through all the towns and villages, teaching in their synagogues, preaching the good news of the kingdom, and healing every disease and sickness.",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "ϊδων δε τουϲ οχλουϲ εϲπλαγχνιϲθη περι αυτων οτι η ϲαν εϲκυλμενοι και εριμμενοι ω ϲει προβατα μη ε χοντα ποιμενα",
          "translation": "When he saw the crowds, he was moved with compassion for them, because they were harassed and helpless, like sheep without a shepherd.",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "τοτε λεγι τοιϲ μα θητεϲ αυτου ο μ ε θεριϲμοϲ πολυϲ οι δε εργατε ολιγοι",
          "translation": "Then he said to his disciples, 'The harvest is plentiful, but the workers are few.'",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "δεηθητε ουν του κυ του θεριϲμου οπωϲ εκβαλη ερ γαταϲ ειϲ τον θε ριϲμον αυτου :",
          "translation": "'Therefore, ask the Lord of the harvest to send out workers into his harvest.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 10,
      "verses": [
        {
          "verse": 1,
          "original": "και προϲκαλεϲα μενοϲ τουϲ ιβ μα θηταϲ αυτου εδω κεν αυτοιϲ εξου ϲιαν πνα των ακα θαρτων ωϲτε εκ βαλλιν αυτα και θε ραπευειν παϲαν νοϲον και παϲαν μαλακιαν :",
          "translation": "He called his twelve disciples and gave them authority over unclean spirits, to drive them out, and to heal every disease and sickness.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "των δε ιβ αποϲτολων τα ο νοματα εϲτιν ταυ τα : πρωτοϲ ϲιμων ο λεγομενοϲ πετροϲ και ανδρεαϲ ο α δελφοϲ αυτου · κ(αι) ϊακωβοϲ ο του ζε βεδαιου · και ϊω αννηϲ ο αδελφοϲ αυτου ·",
          "translation": "These are the names of the twelve apostles: first, Simon (called Peter), and his brother Andrew; James son of Zebedee, and his brother John;",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "φιλιπποϲ και βαρθολομεοϲ θωμαϲ και μαθ θεοϲ ο τελωνηϲ ϊακωβοϲ ο του αλ φαιου κ(αι) θαδδαιοϲ",
          "translation": "Philip and Bartholomew; Thomas and Matthew the tax collector; James son of Alphaeus, and Thaddaeus;",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "ϲιμων ο κανανι τηϲ και ο ϊουδαϲ ο ϊ ϲκαριωτηϲ ο και παραδουϲ παραδιδουϲ παραδουϲ αυτον",
          "translation": "Simon the Zealot, and Judas Iscariot, who betrayed him.",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "τουτουϲ ιβ α πεϲτιλεν ο ιϲ πα ραγγιλαϲ αυτοιϲ λεγ ω ειϲ οδον εθνων μη απελ θηται και ειϲ πο λιν ϲαμαριτων μη ειϲελθηται",
          "translation": "Jesus sent out these twelve, instructing them: 'Do not go on the road to the Gentiles, and do not enter any Samaritan town.'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "πορευ εϲθε δε μαλλον προϲ τα προβατα τα απολωλοτα οι κου ι ϲλ",
          "translation": "'Go instead to the lost sheep of the house of Israel.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "πορευομε νοι δε κηρυϲϲετε λεγοντεϲ οτι ηγ γικεν η βαϲιλια των ο υνων",
          "translation": "'As you go, proclaim: The kingdom of heaven has come near.'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αϲθε νουνταϲ θεραπευ ετε νεκρουϲ εγειρε ται λ̣ε̣π̣ρουϲ εγειρεται νεκρουϲ εγειρεται λεπρουϲ καθα ριζεται δαιμονι α εκβαλλετε δωρε αν ελαβετε δωρε αν δοτε",
          "translation": "'Heal the sick, raise the dead, cleanse those with leprosy, drive out demons. You received freely, so give freely.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "μη κτηϲη ϲθαι χρυϲον μη δε μηδε αργυρ ο μηδε χαλκον ειϲ ταϲ ζωναϲ υ μων",
          "translation": "'Do not take any gold, silver, or copper in your belts.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "μη πηραν ειϲ οδον μηδε δυο χιτωναϲ μηδε ϋποδημα τα μηδε ραβδον αξιοϲ γαρ ο εργατηϲ τηϲ τροφηϲ αυτου",
          "translation": "'Do not take a bag for the road, or two tunics, or sandals, or a staff, for the worker is worth his keep.'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ειϲ ην δ αν πολιν η κωμην ειϲελθη ται εξεταϲαται εν αυ τη τιϲ αξιοϲ εϲτ ι κακει μινατε εωϲ αν εξελθηται",
          "translation": "'Whenever you enter a town or village, find out who is worthy there and stay with them until you leave.'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ει ϲερχομενοι δε ειϲ την οικιαν αϲπα ϲαϲθε αυτην λεγ ο τεϲ ειρηνη τω οι κω τουτω λεγοντεϲ ειρηνη τω οικω τουτω",
          "translation": "'When you enter a house, greet it.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και εαν μεν ῆ η οι κια αξια ελθατω η ϊρηνη υ μων επ αυ την εαν δε μη η α ξια η ϊρηνη ϋμ ω εφ υμαϲ επιϲτρα φητω",
          "translation": "'If the house is worthy, let your peace come upon it. But if it is not worthy, let your peace return to you.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και οϲ αν μη δεξηται ϋμαϲ μηδε ακουϲη τουϲ λογουϲ ϋμων εξερ χομενοι εξω τηϲ οικιαϲ η πολεωϲ η κωμηϲ εκινηϲ εκτιναξατε τον κονιορτον εκ τ ω ποδων ϋμων",
          "translation": "'If anyone will not welcome you or listen to your words, shake the dust off your feet when you leave that house or town.'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "αμην λεγω ϋμιν ανεκτοτερον ε ϲται γη ϲοδομ ω και γη γομορρων εν ημερα κριϲεωϲ η τη πολι εκινη",
          "translation": "'Truly I tell you, it will be more bearable for the land of Sodom and Gomorrah on the day of judgment than for that town.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ϊδου εγω αποϲτελ λω ϋμαϲ ωϲ προβα τα εν μεϲω λυκ ω γινεϲθε ουν φρο νιμοι ωϲ ο οφιϲ οι οφιϲ και ακαιρεοι ωϲ αι περιϲτεραι",
          "translation": "'Look, I am sending you out like sheep among wolves. Therefore be as shrewd as snakes and as innocent as doves.'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "προϲε χετε δε απο των α νων παραδω ϲουϲιν γαρ ϋμαϲ ειϲ ϲυνεδρια και εν ταιϲ ϲυναγω γαιϲ αυτων μαϲτι γωϲουϲιν ϋμαϲ",
          "translation": "'Be on guard against people. They will hand you over to councils and flog you in their synagogues.'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "και επι ηγεμοναϲ δε και βαϲιλιϲ α χθηϲεϲθαι ενε κεν εμου ειϲ μαρ τυριον αυτοιϲ κ(αι) τοιϲ εθνεϲιν",
          "translation": "'You will be brought before governors and kings because of me, as a testimony to them and to the Gentiles.'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ο ταν δε παραδωϲ ι ϋμαϲ μη μεριμνη ϲητε πωϲ η τι λα ληϲητε δοθηϲε ται γαρ ϋμιν εν ε κινη τη ωρα τι λα ληϲητε",
          "translation": "'But when they hand you over, do not worry about how to speak or what to say. What you should say will be given to you at that hour.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ου γαρ ϋ μιϲ εϲτε οι λαλο υ τεϲ αλλα το πν α του πρ ϲ ϋμων το λαλουν εν ϋμ ι",
          "translation": "'For it is not you speaking, but the Spirit of your Father speaking through you.'",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "παραδωϲι δε α δελφοϲ αδελφοϲ αδελφον ειϲ θανατον και πη ρ τεκνον και επαναϲτηϲον ται τεκνα επι γο νιϲ και θανατω ϲουϲιν αυτουϲ",
          "translation": "'Brother will hand brother over to death, and a father his child. Children will rise up against parents and have them put to death.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "κ(αι) κ(αι) ε ϲεϲθε μιϲουμε νοι ϋπο παντ ω δια το ονομα μου ο δε ϋπομιναϲ ειϲ τελοϲ ουτοϲ ϲω θηϲεται",
          "translation": "'You will be hated by everyone because of my name. But the one who endures to the end will be saved.'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "οταν δε διωκωϲιν ϋμαϲ εν τη πολι ταυτη φευγεται ειϲ την ετεραν αμην γαρ λεγω ϋ μιν ου μη τελε ϲητε ταϲ πολιϲ του ιηλ εωϲ ου ελθη ο υϲ του ανο υ",
          "translation": "'When they persecute you in one town, flee to the next. Truly I tell you, you will not finish going through the towns of Israel before the Son of Man comes.'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ουκ ε ϲτιν μαθητηϲ ϋ περ τον διδαϲκα λον αυτου ουδε δουλοϲ ϋπερ τον κν κν αυτου",
          "translation": "'A disciple is not above his teacher, nor a servant above his master.'",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "αρκετ ο τω μαθητη ϊνα γε νηται ωϲ ο διδαϲκα λοϲ αυτου και ο δου λοϲ ωϲ ο κϲ κϲ αυτου ει τον οικοδεϲποτ η οικοδεϲποτ η βεεζεβουλ επεκα λεϲαντο επεκαλεϲαν ποϲω μαλλον τουϲ οι κιακουϲ αυτου",
          "translation": "'It is enough for a disciple to become like his teacher, and a servant like his master. If they have called the master of the house Beelzebul, how much more will they malign the members of his household!'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "μη ουν φοβηθητε αυτουϲ ουδεν γαρ εϲτιν κεκαλυμ μενον ο ουκ απο καλυφθηϲετε και κρυπτον ο ου γνωϲθηϲετε",
          "translation": "'So do not be afraid of them. For nothing is concealed that will not be revealed, and nothing hidden that will not be made known.'",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ο λεγω ϋμιν εν τη ϲκοτια ειπατε εν τω φωτι και ο ειϲ το ουϲ ακουετε κη ρυξατε επι των δω ματων",
          "translation": "'What I tell you in the dark, speak in the light. What you hear whispered, proclaim from the housetops.'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "και μη φο βιϲθε απο των α ποκτεννοντ ω αποκτεννοντ ω το ϲωμα την δε ψυ χην μη δυναμε νων αποκτιναι δε μαλλ ο τον δυναμενον και την ψυχην και το ϲωμα απολεϲε ε ε γεεννη",
          "translation": "'Do not be afraid of those who kill the body but cannot kill the soul. Instead, fear the one who can destroy both soul and body in hell.'",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ουχι δυο ϲτρουθια αϲϲαριου πωλειτε και εν ε ξ αυτων ου πεϲι ται επι την γην αν ευ του πρϲ ϋμων",
          "translation": "'Are not two sparrows sold for a penny? Yet not one of them will fall to the ground apart from your Father.'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ϋμων δε και αι τρι χεϲ τηϲ κεφαληϲ παϲαι ηριθμημε νε ειϲιν",
          "translation": "'Even the hairs of your head are all numbered.'",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "μη ουν φοβιϲθε πολλ ω ϲτρουθιων δια φερεται ϋμιϲ",
          "translation": "'So do not be afraid. You are worth more than many sparrows.'",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "παϲ ουν οϲτιϲ ομολο γηϲι εν εμοι εμ προϲθεν των αν ω ανων ομολογηϲω κα γω εν αυτω εμπρο ϲθεν του πρϲ μου του εν ουρανοιϲ",
          "translation": "'Therefore, everyone who acknowledges me before others, I will also acknowledge before my Father in heaven.'",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "οϲτιϲ δ αν αρνηϲη ται με εμπροϲθεν των α νω ν αρνη ϲομε καγω αυτ ο εμπροϲθεν του πρϲ μου του εν ου ρανοιϲ",
          "translation": "'But whoever denies me before others, I will also deny before my Father in heaven.'",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "μη νομι ϲηται οτι ηλθον ϊ ρηνην βαλιν επι την γην ουκ ηλθ ο βαλιν ϊρηνην αλλα μαχαιραν",
          "translation": "'Do not think I have come to bring peace on earth. I did not come to bring peace, but a sword.'",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ηλθ ο γαρ διχαϲαι α νον κατα του πατροϲ αυ του και θυγατερα κατα τηϲ μητροϲ αυτηϲ και νυμφ η κατα τηϲ πενθε ραϲ αυτηϲ",
          "translation": "'For I have come to set a man against his father, a daughter against her mother, and a daughter-in-law against her mother-in-law.'",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "και εχ θροι του ανο υ ανο υ οι οικιακοι αυτου",
          "translation": "'A person's enemies will be the members of his own household.'",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "ο φιλων πρα η μρ α ϋπερ εμε ουκ εϲ τιν μου αξιοϲ και ο φιλων ϋϊον η θυγατερα ϋπε ρ εμε ουκ εϲτιν μου αξιοϲ",
          "translation": "'Anyone who loves father or mother more than me is not worthy of me. Anyone who loves son or daughter more than me is not worthy of me.'",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "και οϲ ου λαμβανι τον ϲταυρον αυτου και ακολουθι ο πιϲω μου ουκ ε ϲτιν μου αξιοϲ",
          "translation": "'Anyone who does not take up their cross and follow me is not worthy of me.'",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "ο ευρων την ψυχην αυτου απολεϲι αυτην κ(αι) ο απολεϲαϲ την ψυχην αυτου ενε κεν εμου ευρηϲι αυτην",
          "translation": "'Whoever finds their life will lose it, and whoever loses their life for my sake will find it.'",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "ο δεχομενοϲ ϋ μαϲ εμε δεχετε ο δε κ(αι) ο εμε δεχομε νοϲ δεχετε τον αποϲτιλαντα με",
          "translation": "'Whoever welcomes you welcomes me, and whoever welcomes me welcomes the one who sent me.'",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "ο δεχομενοϲ προ φητην ειϲ ονο μα προφητου μι ϲθον προφητου λημψετε και ο δε χομενοϲ δικαι ο ειϲ ονομα δικαιου μιϲθον δικεου λημ ψετε :",
          "translation": "'Whoever welcomes a prophet as a prophet will receive a prophet's reward, and whoever welcomes a righteous person as a righteous person will receive a righteous person's reward.'",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "και οϲ εαν πο τιϲη ενα των μι κρων τουτων πο τηριον ψυχρου μονον ειϲ ονο μα μαθητου αμην λεγω ϋμιν ου μη απολεϲη τον μιϲθον αυτου ‾̷‾",
          "translation": "'And if anyone gives even a cup of cold water to one of these little ones because he is my disciple, truly I tell you, he will certainly not lose his reward.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 11,
      "verses": [
        {
          "verse": 1,
          "original": "και εγενετο οτε ετελεϲεν ο ιϲ δια ταϲϲων τοιϲ ιβ μαθηταιϲ αυτου μετεβη εκειθ ε του διδαϲκιν και κηρυϲϲιν εν ταιϲ πολεϲιν αυτων",
          "translation": "After Jesus had finished instructing his twelve disciples, he moved on from there to teach and preach in their towns.",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "ο δε ϊωαννηϲ α κουϲαϲ εν τω δε ϲμωτηριω τα ερ γα του χυ πεμψαϲ δια των μαθητ ω αυτου",
          "translation": "When John heard in prison about the works of the Christ, he sent word through his disciples.",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ειπεν αυτω ϲυ ει ο ερχομενοϲ η ετερον προϲδο κωμεν",
          "translation": "They asked him, 'Are you the one who is to come, or should we expect someone else?'",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και αποκριθιϲ ο ιϲ ιϲ ειπεν αυτοιϲ πο ρευθεντεϲ απαγ γιλατε τω ϊωαννη α ακουετε και βλε πετε",
          "translation": "Jesus answered them, 'Go and report to John what you hear and see:'",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "τυφλοι ανα βλεπουϲιν και χω λοι περιπατουϲ ι περιπατουϲ ι λεπροι καθαριζ ο τε και κωφοι ακου ουϲιν και νεκροι εγιροντε και πτω χοι ευαγγελιζοντε",
          "translation": "'The blind receive sight, the lame walk, those with leprosy are cleansed, the deaf hear, the dead are raised, and the good news is preached to the poor.'",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και μακαριοϲ εϲ τιν · οϲ εαν μη ϲκ α δαλιϲθη ϲκ α δαλιϲθη εν εμοι",
          "translation": "'Blessed is anyone who does not fall away because of me.'",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "τουτων δε πορευ ομενων ηρξατο ο ιϲ λεγιν τοιϲ οχλοιϲ περι ϊωαννου τι εξηλθατε ειϲ τ η τ η ερημον θεαϲαϲθε καλαμον ϋπο α νεμου ϲαλευομε νον",
          "translation": "As they were leaving, Jesus began to speak to the crowds about John: 'What did you go out into the wilderness to see? A reed shaken by the wind?'",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αλλα τι εξηλ θαται α νο ν ϊδιν ϊδιν α νο ν ϊδιν α νον εν μαλακοιϲ ημ φιεϲμενον · ϊδου οι τα μαλακα φο ρουντεϲ εν τοιϲ οι κοιϲ των βαϲιλε ων ειϲιν",
          "translation": "'If not, what did you go out to see? A man dressed in fine clothes? Those who wear fine clothes are in kings' palaces.'",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "αλλα τι εξηλθα τε προφητην ϊδ ι ϊδ ι προφητην ναι λεγω υμιν κ(αι) περιϲϲοτερον προφητου",
          "translation": "'So what did you go out to see? A prophet? Yes, I tell you, and more than a prophet.'",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ουτοϲ εϲτιν περι ου γε γραπται ϊδου εγω αποϲτελ λω τον αγγελον μου προ προϲω που ϲου οϲ καταϲκευ αϲι την οδον ϲου εμπροϲθεν ϲου",
          "translation": "'This is the one of whom it is written: \"Look, I am sending my messenger ahead of you, who will prepare your way before you.\"'",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "αμην λεγω ϋμιν ουκ εγηγερτε εν γεννητοιϲ γυνε κων μιζων ϊω α νου του βαπτιϲτου ο δε μικροτεροϲ εν τη βαϲιλια τ ω ο υνω ν ο υνων μιζων αυτου εϲτιν",
          "translation": "'Truly I tell you, among those born of women there has not risen anyone greater than John the Baptist. Yet the least in the kingdom of heaven is greater than he.'",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "απο δε των ημερ ω ϊωαννου του βα πτιϲτου εωϲ αρτι η βαϲιλια των ου ρανων βιαζετε κ(αι) βιαζετε βιαϲτε αρπαζου ϲιν αυτην",
          "translation": "'From the days of John the Baptist until now, the kingdom of heaven has been suffering violence, and the violent take it by force.'",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "παντεϲ γαρ οι προ φηται και ο νομοϲ εωϲ ϊωαννου ε προφητευϲαν",
          "translation": "'For all the Prophets and the Law prophesied until John.'",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και ει θελετε δε ξαϲθε αυτοϲ εϲτ ι ηλιαϲ ο μελλων ερχεϲθε",
          "translation": "'And if you are willing to accept it, he is Elijah who was to come.'",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ο εχων ωτα ακουειν ακου ετω",
          "translation": "'Whoever has ears to hear, let him hear.'",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "τινι δε ομοιωϲω την γενεαν ταυτ η ομοια εϲτιν παιδι οιϲ καθημενοιϲ εν τεϲ αγορεϲ ταιϲ αγοραιϲ α προϲ φωνουντα τοιϲ ε τεροιϲ",
          "translation": "'To what should I compare this generation? It is like children sitting in the marketplaces who call out to others:'",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "λεγουϲιν η ϋληϲαμεν ϋμιν και ουκ ωρχηϲαϲθε εθρηνηϲαμεν και ουκ εκοψαϲθε",
          "translation": "'\"We played the flute for you, and you did not dance. We sang a lament, and you did not mourn.\"'",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ηλθεν γαρ ϊωαν νηϲ μητε εϲθι ω μητε πινων και λεγουϲιν δεμονι ον δαιμονιον εχει",
          "translation": "'For John came neither eating nor drinking, and they say, \"He has a demon.\"'",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ηλθεν ο υϲ του ανου εϲθι ων και πινων κ(αι) και λεγουϲιν ϊδου α νο ϲ φαγοϲ και οι νοποτηϲ φιλοϲ τελωνων και α μαρτωλων και ε δικεωθη η ϲοφι α απο των εργων αυτηϲ",
          "translation": "'The Son of Man came eating and drinking, and they say, \"Look, a glutton and a drunkard, a friend of tax collectors and sinners!\" Yet wisdom is justified by her deeds.'",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "τοτε ηρξατο ονιδι ζειν ταϲ πολειϲ εν αιϲ εγενοντο αι πλιϲται δυνα μιϲ αυτου οτι ου με τενοηϲαν",
          "translation": "Then he began to denounce the towns where most of his miracles had been done, because they did not repent:",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ουαι ϲοι χοραζειν ουαι ϲοι βηδϲαιδ α βηδϲαιδ α βηδϲαϊδα οτι ει η εν τυρω και ϲιδωνι εγενον το αι δυναμιϲ αι γε νομεναι εν ϋμ ι παλαι αν εν ϲακ κω και ϲποδω κα θημενοι μετενο ηϲαν",
          "translation": "'Woe to you, Chorazin! Woe to you, Bethsaida! For if the miracles that were done in you had been done in Tyre and Sidon, they would have repented long ago in sackcloth and ashes.'",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "πλην λεγω ϋμιν τυρω και ϲιδωνι ανεκτοτερον εϲτε εν ημερα κριϲεωϲ η ϋμιν",
          "translation": "'But I tell you, it will be more bearable for Tyre and Sidon on the day of judgment than for you.'",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και ϲυ καφαρναουμ μη εωϲ ο υνου ϋ ψωθηϲη εωϲ αδου καταβιβαϲθηϲη οτι ει εν ϲοδομοιϲ εγενηθηϲαν αι δυ ναμιϲ αι γενομε ναι εν ϲοι εμειν ε ϋμιν ε̣μ̣ε̣ι̣ν̣ ε̣ αν μεχρι τηϲ ϲημε ρον",
          "translation": "'And you, Capernaum, will you be lifted up to heaven? No, you will go down to Hades. For if the miracles that were done in you had been done in Sodom, it would have remained to this day.'",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "πλην λεγω ϋμιν οτι εϲτε γη ϲοδομων εν η μερα κριϲεωϲ η ϲοι",
          "translation": "'But I tell you that it will be more bearable for the land of Sodom on the day of judgment than for you.'",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "εν εκινω τω καιρω αποκριθιϲ ο ιϲ ειπ ε εξομολογουμαι ϲοι πε ρ κε του ου ρανου και τηϲ γηϲ οτι εκρυψαϲ ταυτα απο ϲοφων και ϲυ νετων και απεκα λυψαϲ αυτα νηπι οιϲ",
          "translation": "At that time Jesus said, 'I praise you, Father, Lord of heaven and earth, because you have hidden these things from the wise and learned and revealed them to little children.'",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ναι ο πη ρ οτι ουτωϲ ευδοκια εγενετο εμπρο ϲθεν ϲου",
          "translation": "'Yes, Father, for this was pleasing in your sight.'",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "παντα μοι παρε δοθη ϋπο του πρ ϲ μου και ουδιϲ επιγινω ϲκι τον υν ει μη ο πηρ ουδε τον πρ α τιϲ επιγινωϲκι ει μη ο υϲ και ω εαν βουλητε ο υϲ απο καλυψε",
          "translation": "'All things have been handed over to me by my Father. No one knows the Son except the Father, and no one knows the Father except the Son and anyone to whom the Son chooses to reveal him.'",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "δευτε προϲ με π α τεϲ οι κοπιωντεϲ και πεφορτιϲμε νοι καγω αναπαυ ϲω υμαϲ",
          "translation": "'Come to me, all you who are weary and burdened, and I will give you rest.'",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "αρατε τον ζυγον μ(ου) εφ υμαϲ και μαθε τε μαθετε απ εμου μαθετε απ εμου οτι πραϋϲ ειμι και ταπινοϲ τη καρ δια και ευρηϲετε αναπαυϲιν ταιϲ ψυχεϲ ϋμων",
          "translation": "'Take my yoke upon you and learn from me, for I am gentle and humble in heart, and you will find rest for your souls.'",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ο γαρ ζυγοϲ μου χρη ϲτοϲ και το φορτι ον μου ελαφρον ε ϲτιν :",
          "translation": "'For my yoke is easy and my burden is light.'",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 12,
      "verses": [
        {
          "verse": 1,
          "original": "εν εκινω τω καιρω επορευθη ο ιϲ τοιϲ ϲαββαϲιν δια των ϲποριμ ω οι δε μαθητε αυτου επιναϲαν και ηρ ξαντο τιλλιν ϲτα χυαϲ και εϲθιειν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "οι δε φαριϲαιοι ϊδ ο τεϲ ειπαν αυτω ϊ δου οι μαθηται ϲου ποιουϲιν ο ουκ ε ξεϲτιν ποιειν ε ε ϲαββατω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ο δε ειπεν αυτοιϲ ου κ ανεγνωτε τι ε ποιηϲεν δα δ οτε επιναϲεν και οι μετ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "πωϲ ειϲηλθεν ειϲ τον οικον του θυ και τουϲ αρτουϲ τηϲ προθεϲεωϲ εφαγ ο ουϲ ουκ εξον ην αυτω φαγιν ουδε τοιϲ μετ αυτου ει μη τοιϲ ϊερευϲιν μονοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "η ουκ ανεγνωτε εν τω νομω οτι τοιϲ ϲαββαϲιν οι ϊεριϲ εν τω ϊερω το ϲαββατον βεβη λουϲιν και αναι τιοι ειϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "λεγω δε ϋμιν οτι του μιζον εϲτιν ωδε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ει δε εγνωκειτε τι εϲτιν ελεοϲ θελω και ου θυϲιαν ου κ αν κατεδικαϲα τε τουϲ αναιτιουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "κϲ γαρ εϲτιν του ϲαβ βατου ο υϲ υϲ του α νου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και μεταβαϲ εκιθ ε ηλθεν ειϲ την ϲυ ναγωγην αυτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και ϊδου α νοϲ χιρα εχων ξηραν και επηρωτηϲαν αυ τον λεγοντεϲ ει εξεϲτιν τοιϲ ϲαβ βαϲιν θεραπευϲε ϊνα κατηγορηϲω ϲιν αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ο δε ειπεν αυτοιϲ τιϲ εϲται εξ υμ ω α νοϲ οϲ εξι προβα τον εν και εαν πε ϲη ενπεϲη τουτο τοιϲ ϲαβ βαϲιν ειϲ βοθυν ο ουχι κρατηϲαϲ ε γερει αυτο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ποϲω ουν διαφε ρι ανοϲ προβατου ωϲτε εξεϲτιν τοιϲ ϲαββαϲιν καλωϲ ποιειν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε λεγι τω α νω εκτινον ϲου την χειρα ϲου και εξετιν ε και απεκατεϲτα θη ϋγιηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "εξελθοντεϲ δε οι φαριϲεοι ϲυμβου λιον ελαβον κα τ αυτου οπωϲ αυ τον απολεϲωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ο δε ιϲ γνουϲ ανε χωρηϲεν εκιθ ε και ηκολουθηϲ α αυτω πολλοι και εθεραπευϲεν αυ τουϲ πανταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και επετιμηϲεν αυτοιϲ ϊνα μη φα νερον αυτον ποι ηϲωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ϊνα πλη ρωθη το ρηθεν δι α ηϲαιου του προ φητου λεγοντοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ϊδου ο παιϲ μου ο ν ο ηρετιϲα ο αγαπη τοϲ μου ειϲ ον ηϋδο κηϲεν η ψυχη μου θηϲω το πνα μου επ αυτον και κριϲ ι κριϲ ι τοιϲ εθνεϲιν απαγ γελει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ουκ εριϲει ου δε κραυγαϲει ουδε α κουϲει τιϲ εν τεϲ ταιϲ πλατιαιϲ την φω νην αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "καλα μον ϲυντετριμ μενον ου κατεα ξει και λινον τυ φομενον ου ϲβεϲι εωϲ αν εκβαλη ειϲ νικοϲ την κρι ϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "και τω ονο ματι αυτου εθνη ελπιουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "τοτε προϲηνεχθη αυτω δαιμονιζο μενοϲ τυφλοϲ και κωφοϲ και ε θεραπευϲεν αυ τουϲ αυτον ωϲτε τον κωφον κ(αι) λαλειν και βλεπιν :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και ε ξιϲταντο παντεϲ οι οχλοι και ελε γον μητι ουτοϲ εϲτιν ο υϲ δαδ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "οι δε φαριϲαιοι ακου ϲαντεϲ ειπον ου τοϲ ουκ εκβαλλι τα δαιμονια ει μη εν τω βεεζεβουλ αρχοντι των δε μονιων δαιμονιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ϊδωϲ ϊδων ϊδωϲ δε ταϲ ενθυ μηϲειϲ αυτων ει πεν αυτοιϲ παϲα βαϲιλια μεριϲθιϲα καθ εαυτηϲ ερημου ται και παϲα πολιϲ η οι κια μεριϲθιϲα κα θ εαυτηϲ ου ϲταθη ϲεται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "και ει ο ϲαταναϲ τον ϲαταναν εκβαλλι εφ εαυτον εμερι ϲθη πωϲ ουν ϲταθηϲε τε η βαϲιλια αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και ει εγω εν βεε ζεβουλ εκβαλλω τα δαιμονια οι ϋϊ οι ϋμων εν τινι εκβαλλουϲιν δια τουτο αυτοι κρι ται εϲονται ϋμ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ει δε εν πν ι θυ εγω εκβαλλω τα δεμο νια δαιμονια αρα εφθαϲεν εφ ϋμαϲ η βαϲιλι α του θυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "η πωϲ δυναται τιϲ ειϲελθιν ειϲ την οικιαν του ϊϲχυρου και τα ϲκευη αυ του διαρπαϲαι ε αν μη πρωτον δηϲη τον ϊϲχυρ ο και τοτε την οικι αν αυτου διαρπα ϲη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ο μη ων μετ εμου κατ εμου εϲτιν κ(αι) ο μη ϲυναγων με τ εμου ϲκορπιζι με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "δια τουτο λεγω ϋ μιν παϲα αμαρ τια και βλαϲφημι α αφεθηϲετε τοιϲ ανοιϲ η δε του πνϲ βλαϲφημια ουκ αφεθηϲετε το",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "και οϲ εαν ειπη λο γον κατα του ϋϊου του α νου α νου αφεθη ϲετε αυτω οϲ δ αν ειπη κατα του πνϲ πνϲ του αγιου ου μη ουκ ουκ αφεθηϲετε ουτε εν του τω τω αιωνι ουτε εν τω μελλοντι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "η ποιηϲαται το δεν δρον καλον και τ ο τ ο καρπον αυτου α λον α γαθον καλον η ποιηϲατε το δεν δρον ϲαπρον και τον καρπον αυτου ϲαπρον εκ γαρ του καρπου το δενδρον γινω ϲκετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "γεννημα γεννηματα εχιδν ω εχιδν ω πωϲ δυναϲθε αγα θα λαλιν πονηροι οντεϲ εκ γαρ του περιϲϲευματοϲ τηϲ καρδιαϲ το ϲτο μα λαλει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ο αγαθοϲ α νοϲ α νοϲ εκ του αγαθου θηϲαυ ρου εκβαλλει τα αγαθα και ο πονη ροϲ ανο ϲ εκ του πονηρου θηϲαυ ρου εκβαλλει πο νηρα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "λεγω δε ϋμιν ο τι παν ρημα αργ ο αργ ο ο λαληϲουϲιν οι ανο ι αποδωϲου ϲιν δωϲουϲιν αποδωϲουϲιν περι αυτου λο γον εν ημερα κρι ϲεωϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "εκ γαρ των λογων ϲου δικε ωθηϲη και εκ τ ω τ ω λογων καταδικα ϲθηϲη ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "τοτε απε κριθηϲαν αυτω τι νεϲ των γραμμα τεων και φαριϲε ων λεγοντεϲ δι δαϲκαλε θελομ ε απο ϲου ϲημιον ϊδιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "ο δε αποκριθιϲ ει πεν αυτοιϲ γενε α πονηρα και μοι χαλιϲ ϲημιον επι ζητι και ϲημιον ου δοθηϲετε αυτη ει μη το ϲημιον ϊωνα του προφη του",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "ωϲπερ γαρ ην ϊωναϲ εν τη κοι λια του κητουϲ τριϲ ημεραϲ και τριϲ νυκταϲ ουτωϲ ε ϲτε ο υϲ του ανο υ εν τη καρδια τηϲ γηϲ τριϲ ημεραϲ και γ νυκταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "ανδρεϲ νινευειτε αναϲτηϲοντε ε τη κριϲι μετα τηϲ γενεαϲ ταυτηϲ και κατακρινουϲ ι αυτην οτι μετε νοηϲαν ειϲ το κη ρυγμα ϊωνα και ϊδου πλειον ϊω να ωδε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "βαϲιλιϲ ϲα νοτου εγερθη ϲετε εν τη κριϲει μετα τηϲ γενεαϲ ταυτηϲ και κατα κρινι αυτην οτι ηλθεν εκ των πε ρατων τηϲ γηϲ α κουϲε την ϲοφι αν ϲολομωνοϲ και ϊδου πλειον ϲολομωνοϲ ω δε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "οταν δε το ακαθαρ τον πν α εξελθη απο του ανου διερ χετε δι ανυδρων τοπων ζητουν ζητων ζητουν αναπαυϲιν και ου χ ευριϲκει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "τοτε λεγι ειϲ τον οικ ο μου επιϲτρεψω οθεν εξηλθον κ(αι) ελ θον και ευριϲκει ϲχο λαζοντα και ϲεϲα ρωμενον και κε κοϲμημενον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "τοτε πορευετε κ(αι) παραλαμβανι με θ εαυτου επτα ετε ρα πνα τα πονηρο τερα εαυτου και ειϲ ελθοντα κατοι κι εκι και γινετε τα εϲχατα του α νου ανου εκινου χιρονα των πρωτων ουτωϲ εϲτε και τη γενεα ταυτη τη πονηρα :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "ετι αυτου λαλουντοϲ τοιϲ οχλοιϲ ϊδου η μητηρ και οι αδελφοι αυτου αυτου ϊϲτηκιϲαν εξω ζητουντεϲ αυτω λαληϲαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "ειπεν δε τιϲ των μαθητων αυτου ϊδου η μη ρ ϲου και οι αδελφοι ϲου εξω ζητουϲιν ϲε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "ο δε αποκριθειϲ ειπεν τω λεγον τι αυτω τιϲ εϲτ ι η μη ρ μου και τι νεϲ ειϲιν οι αδελ φοι μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 49,
          "original": "και εκτι ναϲ την χιρα αυτου χιραν̣ επι τουϲ μαθη ταϲ αυτου ειπεν ϊδου η μη ρ μου και οι αδελφοι μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 50,
          "original": "οϲτιϲ γαρ αν ποι ηϲη το θελημα του πρϲ μου του ε ν ουν οιϲ αυτοϲ μου αδελφοϲ κ(αι) αδελφη και μη ρ εϲτιν :",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 13,
      "verses": [
        {
          "verse": 1,
          "original": "εν τη ημερα εκινη εξελθων ο ιϲ εκ τηϲ οικιαϲ εκαθητο παρα τ η θαλαϲϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ϲυ νηχθηϲαν προϲ αυτον οχλοι πολ λοι ωϲτε αυτον ειϲ πλοιον εμβ α τα καθηϲθε και παϲ ο οχλοϲ επι τον αιγιαλον ϊϲτη κι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και ελαληϲεν αυ τοιϲ πολλα εν πα ραβολαιϲ λεγων ϊδου εξηλθεν ο ϲπι του ϲπιρε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και εν τω ϲπιριν αυ τον α μεν επεϲ ε παρα την οδον και ηλθεν τα πετινα και κατεφαγεν αυτα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "αλλα δε επεϲεν ε πι τα πετρωδη ο που ουκ ειχεν γ η πολλην και ευθε ωϲ εξανετιλεν δι α το μη εχιν βαθοϲ γηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ηλιου δε ανα τιλαντοϲ εκαυμα τιϲθη και δια το μη εχειν ριζαν ε ξηρανθη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "αλλα δε επεϲεν ε πι ταϲ ακανθαϲ και ανεβηϲαν αι ακανθαι και επνι ξαν αυτα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αλλα δε επεϲεν ε πι την γην την κα λην και εδιδου καρπον ο μεν ε κατον ο δε εξηκ ο τα ο δε λ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "ο εχων ωτα ακουε ι ακουετω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και προϲελθοντεϲ οι μαθηται ειπ α αυτω δια τι εν πα ραβολαιϲ αυτοιϲ λαλειϲ λαλειϲ αυτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ο δε αποκριθειϲ ειπεν οτι ϋμιν δεδοται γνωνε τα μυϲτηρια τηϲ βαϲιλιαϲ των ου ρανων εκινοιϲ δε ου δεδοται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "οϲτιϲ γαρ εχει δο θηϲετε αυτω και περιϲϲευθηϲετε οϲτιϲ δε ουκ εχι και ο εχει αρθηϲε τε απ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "δια του το εν παραβολεϲ παραβολαιϲ αυτοιϲ λαλω οτι βλεποντεϲ ου βλεπουϲιν και α κουοντεϲ ουκ α κουουϲιν ουδε ϲυνϊουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και αναπληρου ται αυτοιϲ η προ φητια ηϲαϊου η λεγουϲα ακοη ακουϲετε και ου μη ϲυνητε και βλεποντεϲ βλε ψητε και ου μη ϊ δητε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "επαχυνθη γαρ η καρδια του λαου τουτου και τοιϲ ωϲιν αυτ ω βαρεωϲ ηκουϲ α και τουϲ οφθαλ μουϲ αυτων εκαμ μυϲαν μηποτε ϊδωϲιν τοιϲ ο φθαλμοιϲ και τοιϲ ωϲιν αυτων ακουϲωϲ ι και τη καρδια ϲυνω ϲιν και επιϲτρε ψωϲιν και ϊαϲομε αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ϋμων δε μακαρι οι οι οφθαλμοι ο τι βλεπουϲιν τα ωτα ϋμων ο τι ακουουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "αμην λεγω ϋμιν οτι πολλοι προ φητε και δικεοι δικαιοι επεθυμηϲαν ϊδ ι α βλεπετε και ου κ ϊδαν και ακουϲε α ακουετε και ου κ ηκουϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ϋμιϲ ουν ακουϲα τε την παραβο λην του ϲπιραν τοϲ ϲπιροντοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "παντοϲ ακου ο τοϲ τον λογον τηϲ βαϲιλιαϲ και μη ϲυ νιεντοϲ ερχετε ο πονηροϲ και αρ παζι το εϲπαρμε νον εν τη καρδι α αυτου ουτοϲ ε ϲτιν ο παρα την ο δον ϲπαριϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ο δε επι τα πετρω δη ϲπαριϲ ουτοϲ εϲτιν ο τον λογ ο ακουων και ευ θυϲ μετα χαραϲ λαμ βανων αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ου κ εχι δε ριζαν εν ε αυτω αλλα προϲ καιροϲ εϲτιν γε νομενηϲ δε θλι ψεωϲ η διωγμου δια τον λογον ευ θυϲ ϲκανδαλιζε ται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ο δε ειϲ ταϲ ακαν θαϲ ϲπαρειϲ ου τοϲ εϲτιν ο τον λο γον ακουων και η μεριμνα του αι ωνοϲ τουτου και η απα τη του πλουτου ϲυνπνιγει τον λο γον και ακαρποϲ γινετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ο δε επι την καλ η καλ η γην ϲπαριϲ ουτοϲ εϲτιν ο τον λογ ο ακουων και ϲυνι ειϲ οϲ δη καρπο φορι και ποιει ο μεν ρ ο δε ξ ο δε λ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "αλλην παραβολ η παρεθηκεν αυτοιϲ λεγων ωμοιω θη η βαϲιλια τ ω ουρανων αν ω ανω ϲπιραντι καλον ϲπερμα εν τω α γρω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "εν δε τω καθευδιν τουϲ αν θρωπουϲ ηλθεν αυτου ο εχθροϲ κ(αι) επεϲπαρκεν επεϲπειρεν επεϲπειρεν ζι ζανια ανα μεϲον του ϲιτου και απηλ θεν ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "οτε δε εβλαϲτηϲεν ο χορτοϲ και καρ πον εποιηϲεν τοτε εφανη και τα ζιζανια",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "προϲελ θοντεϲ δε οι δου λοι του οικοδεϲπο του ειπον αυτω κε ουχι καλον ϲπερ μα εϲπιραϲ εν τω ϲω αγρω ποθεν ουν εχι τα ζιζανι α",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ο δε εφη αυτοιϲ ε χθροϲ α νοϲ του το εποιηϲεν οι δε δουλοι λεγου ϲιν αυτω θελιϲ ουν απελθοντεϲ ϲυλλεξωμεν αυ τα αυτα τα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ο δε φηϲιν ου · μηποτε ϲυλλεγ ο τεϲ τα ζιζανια εκ ριζωϲητε αμα αυ τοιϲ τον ϲιτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "α φετε ϲυναυξανε ϲθε αμφοτερα α χρι μεχρι αχρι του θεριϲμου και εν τω τω καιρω του θεριϲμου ερω τοιϲ θεριϲτεϲ ϲυλ λεξατε πρωτον τα ζιζανια και δη ϲατε αυτα ειϲ δεϲ μαϲ προϲ το κατα καυϲε αυτα τον δε ϲιτον ϲυναγαγε τε ειϲ την απο θηκην μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "αλλην παραβολ η παρεθηκεν αυ τοιϲ λεγων ομοι α εϲτιν η βαϲιλια των ουρανων κοκ κω ϲιναπεωϲ ο ο λαβων α νοϲ εϲ πιρεν εν τω αγρω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "ο μικροτε ρον μεν εϲτιν παντων των ϲ περματων ϲπερματων ϲπερματων οτ α δε αυξηθη αυξηϲη αυξηθη μειζ ο των λαχανων εϲτιν και γινετε δενδρον ωϲτε ελθειν τα πετι να του ο υνο υ και καταϲκηνουν ε τοιϲ κλαδοιϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "αλλην παραβολ η ελαληϲεν αυτοιϲ λεγων ομοια εϲτ ι εϲτ ι η βαϲιλεια των ο υνω ν ζυμη η η λαβουϲα γυνη ενε κρυψεν ειϲ αλευ ρου ϲατα τρια εωϲ ου εζυμωθη ολον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "ταυτα παντα ελα ληϲεν ο ιϲ εν πα ραβολαιϲ τοιϲ ο χλοιϲ και χωριϲ πα ραβοληϲ ουδεν ε λαληϲεν ουκ ελαλι αυτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "οπωϲ πληρωθη το ρηθεν δια ηϲα ϊου του προφητου λεγοντοϲ ανοι ξω εν παραβολεϲ το ϲτομα μου ερευ ξομαι κεκρυμ μενα απο κατα βοληϲ κοϲμου κοϲμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "τοτε αφιϲ τουϲ ο χλουϲ ειϲηλθεν ειϲ οικιαν και προϲηλθον προϲηλθεν αυτω οι μαθητε αυτου λεγοντεϲ διαϲαφηϲον φραϲον η μιν την παραβο λην των ζιζανι ων του αγρου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "ο δε αποκριθειϲ ει πεν ο ϲπιρων το καλον ϲπερμα εϲ τιν ο υϲ του ανο υ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "ο δε αγροϲ εϲτιν ο κοϲμοϲ το δε καλον ϲπερμα ουτοι ειϲιν οι ϋϊ οι τηϲ βαϲιλιαϲ τα δε ζιζανια ειϲιν οι ϋϊοι του πονη ρου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "ο δε εχθροϲ ο ϲπιραϲ αυτα εϲτ ι ο διαβολοϲ οι δε ο δε θεριϲμοϲ ϲυντελεια αιωνοϲ εϲτιν οι δε ο δε θεριϲμοϲ ϲυντελεια του αιωνοϲ εϲτιν οι δε θεριϲται αγγελοι ειϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "ωϲπερ ουν ϲυλλεγετε τα ζι ζανια και πυρι κα τακαιεται ουτωϲ ωᵨ εϲτε εν τη ϲυντε λια του αιωνοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "αποϲτελι ο υϲ του α νου τουϲ αγγελουϲ και ϲυλλεξουϲιν εκ τηϲ βαϲιλιαϲ αυτου παντα τα ϲκανδαλα και τουϲ ποιουνταϲ την ανομιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "και βαλλουϲιν βαλουϲιν βαλουϲιν αυτουϲ ειϲ την καμινον του πυροϲ εκι εϲτε εϲται ο κλαυθμοϲ και ο βρυγμοϲ των οδ ο των",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "τοτε οι δικε οι δικαιοι εκλαμψουϲιν ωϲ ο ηλιοϲ εν τη βαϲιλεια του πρϲ αυ των ο εχων ωτα ακουε ι ακουετω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "ομοια δε εϲτιν η βαϲι λια βαϲιλεια των ο υνω ν θηϲαυρω κεκρυμ μενω εν τω αγρω ον ευρ ω ευρ ω α νο ϲ ανοϲ εκρυψεν κ(αι) απο τηϲ χαραϲ αυ του ϋπαγι και πω λι παντα οϲα εχι και αγοραζει τον αγρον εκινον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "παλιν ομοια εϲτ ι εϲτ ι η βαϲιλια των ου ρανων ανθρωπω εμπορω ζητουντι καλουϲ μαργαριταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "ευρ ω ευρ ω δε ενα πολυτιμ ο μαργαριτην απελ θων πεπρακεν παντα οϲα ειχεν και ηγοραϲεν αυτ ο αυτ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "παλιν ομοια εϲτ ι η βαϲιλια των ου ρανων ϲαγηνη βληθιϲη ειϲ την θαλαϲϲαν και εκ παντοϲ γενουϲ ϲυναγαγουϲη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "ην οτε επληρωθη αναβιβαϲαντεϲ επι τον αιγιαλον και κ(αι) επι τον αιγιαλον επι τον αιγιαλον και καθιϲαντεϲ ϲυνελεξαν τα κα λα ειϲ αγγη τα δε ϲαπρα εξω εβαλλ ο εβαλ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 49,
          "original": "ουτωϲ εϲτε εν τη ϲυντελια του αιω νοϲ εξελευϲον τε οι αγγελοι και α φοριουϲι τουϲ πο νηρουϲ εκ μεϲου των δικαιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 50,
          "original": "και βαλλουϲιν βαλουϲιν βαλουϲιν αυτουϲ ειϲ την καμινον του πυροϲ εκει ε ϲτε ο κλαυθμοϲ και ο βρυγμοϲ τ ω τ ω οδοντων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 51,
          "original": "ϲυνη κατε ταυτα παντα ˙ λεγουϲιν αυτω ναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 52,
          "original": "ο δε ειπεν αυτοιϲ δια τουτο παϲ γραμ ματευϲ μαθητευ θιϲ τη βαϲιλια τ ω τ ω ουρανων ομοια ομοιοϲ ομοιοϲ εϲτιν α νω οικο δεϲποτη οϲτιϲ εκ βαλλει εκ του θηϲαυ ρου αυτου καινα και παλαια",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 53,
          "original": "και εγενετο οτε ε τελεϲεν ο ιϲ ταϲ παραβολαϲ ταυταϲ μετηρεν εκιθεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 54,
          "original": "και ελθων ειϲ τ η τ η αντιπατριδα πατριδα αυτου εδιδαϲκεν αυτουϲ εν τη ϲυναγωγη αυτων ωϲτε εκ πληϲϲεϲθε αυτουϲ και λεγειν ποθ ε τουτω η ϲοφια αυτη και αι δυνα μιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 55,
          "original": "ουχ ουτοϲ ε ϲτιν ο του τεκτο νοϲ υϲ ουχ η μ η ρ μηρ αυτου λεγετε μα ριαμ και οι αδελ φοι αυτου ϊακω βοϲ και ϊωϲηφ ϊωαννηϲ και ϲιμων και ιου δαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 56,
          "original": "και αι αδελφαι αυτου ουχι παϲαι προϲ ημαϲ ειϲιν ποθεν ουν τουτω ταυτα παντα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 57,
          "original": "και ε ϲκανδαλιζοντο εν αυτω ο δε ειπεν αυτοιϲ ουκ εϲτιν προφη τηϲ ατιμοϲ ει μη εν τη ϊδια πατριδι και εν τη οικια αυ του",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 58,
          "original": "και ουκ εποιη ϲεν εκι δυναμιϲ πολλαϲ δια την απιϲτιαν αυτων",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 14,
      "verses": [
        {
          "verse": 1,
          "original": "ηκουϲεν ηρωδηϲ εν εκινω τω και ρω εν εκινω τω καιρω ηκουϲεν ηρωδηϲ εν εκινω τω καιρω ηκουϲεν ηρωδηϲ ο τετρααρχηϲ την ακοην ιυ ιυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ειπεν τοιϲ παιϲιν αυτου ουτοϲ εϲτ ι εϲτ ι ϊωαννηϲ ο βαπτι ϲτηϲ αυτοϲ ηγερ θη απο των νεκρ ω νεκρ ω · και δια τουτο αι δυ ναμιϲ ενεργουϲ ι εν αυτω :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ο γαρ ηρω δηϲ κρατηϲαϲ τον ϊωαννην εδηϲ ε αυτ ο και εν φυλακη εν τη φυλακη κ(αι) α πεθετο δια ηρω διαδα την γυναι κα φιλιππου του αδελφου αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "ελεγεν γαρ ϊωαν νηϲ αυτω ουκ εξεϲτιν ϲοι εχιν αυτην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "κ(αι) κ(αι) θελων αυτον α ποκτιναι εφοβη θη τον οχλον ο τι ωϲ προφητην αυτον ειχον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "γενεϲιοιϲ δε γε νομενοιϲ του η ρωδου ωρχηϲα το η θυγατηρ τηϲ ηρωδιαδοϲ εν τω μεϲω και ηρε ϲεν τω ηρωδη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "οθεν μετα ορκου ωμολογηϲεν αυ τη δουναι ο εαν αιτηϲηται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "η δε προβιβαϲθιϲα ϋ πο τηϲ μρϲ αυτηϲ ειπεν δοϲ μοι φηϲιν ωδε επι πινακι την κεφαλην ϊ ωαννου του βα πτιϲτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και ελυπη θη ο βαϲιλευϲ δια δε τουϲ ορκουϲ και τουϲ ϲυνανακιμε νουϲ εκελευϲεν δοθηναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και πεμ ψαϲ απεκεφαλιϲ ε τον ϊωαννην εν τη φυλακη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "και ηνε χθη η κεφαλη αυ του επι πινακι και εδοθη τω κοραϲιω και ηνεγκεν τη μρ ι αυτηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και προϲ ελθοντεϲ οι μα θηται αυτου ηρ α το πτωμα αυτου αυτου και εθαψαν αυτον αυτο και ελθοντεϲ α πηγγιλαν τω ιυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ακουϲαϲ δε ο ιϲ α νεχωρηϲεν εκι θεν εν πλοιω ει ϲ ειϲ ερημον τοπον κατ ιδιαν και ακου ϲαντεϲ οι οχλοι ηκολουθηϲαν αυτω πεζοι απο των πολεων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και εξελθων ειδεν πολυν οχλον και εϲπλαγχνιϲθη επ αυτοιϲ και ε θεραπευϲεν τουϲ αρρωϲτουϲ αυτ ω αυτ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "οψιαϲ δε γενομε νηϲ προϲηλθον αυτω οι μαθητε λεγοντεϲ ερημοϲ εϲτιν ο τοποϲ και η ωρα παρηλθεν ηδη απολυϲον ουν τουϲ οχλουϲ ινα απελθοντεϲ ειϲ ταϲ χωραϲ κωμαϲ αγο ραϲωϲιν εαυτοιϲ βρωματα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ο δε ιϲ ειπεν αυτοιϲ ου χριαν εχουϲιν απελθιν δοτε αυ τοιϲ ϋμιϲ φαγιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "οι δε λεγουϲιν αυ τω ουκ εχομεν ωδε αρτουϲ ει μη πεν τε ει μη πεντε αρτουϲ και δυο ϊχθυαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ο δε ειπεν φερε τε μοι ωδε αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και εκελευϲεν τουϲ οχλουϲ ανακλιθη ναι επι του χορτου και λαβων τουϲ · ε · αρτουϲ και τουϲ · β · ϊχθυαϲ αναβλε ψαϲ ειϲ τον ο υν ον ο υνον ευλογηϲεν και κλαϲαϲ εδωκεν τοιϲ μαθηταιϲ τουϲ αρτουϲ οι δε μαθηται τοιϲ ο χλοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και εφαγον παντεϲ και εχορ ταϲθηϲαν και η ραν το περιϲϲευ ο των κλαϲματων δωδεκα κοφι νουϲ πληρειϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "οι δε εϲθιοντεϲ ηϲ α ηϲ α ανδρεϲ ωϲι ωϲει πεν τακιϲχιλιοι χω ριϲ γυναικων και παιδιων :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και ευθεωϲ η ναγκαϲεν τουϲ μαθηταϲ εμβη νε ειϲ το πλοιον και προαγιν αυ τον ειϲ το περαν εωϲ ου απολυϲη τουϲ οχλουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και κ(αι) απολυϲαϲ τουϲ οχλουϲ ανεβη ειϲ το οροϲ κατ ϊδιαν προ ϲευξαϲθε οψιαϲ δε γενομε νηϲ μονοϲ ην ε κει :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "το δε πλοιον ηδη μεϲον τηϲ θαλαϲϲηϲ ην βα ϲανιζομενον ϋ πο των κυματ ω κυματ ω ην γαρ εναντιοϲ ο ανεμοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "τεταρτη δε φυλα κη τηϲ νυκτοϲ ηλ θεν προϲ αυτουϲ πε ριπατων επι τ η τ η θαλαϲϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ϊδοντεϲ δε οι δε μαθηται ϊδοντεϲ αυτον επι τηϲ θαλαϲϲηϲ περιπα τουντα εταραχθη ϲαν λεγοντεϲ ο τι φανταϲμα εϲ και απο του φοβου εκραξαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ευθυϲ δε ελαληϲεν ο ιϲ αυτοιϲ λεγων θαρ ϲιτε εγω ειμι μη φοβιϲθε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "αποκριθιϲ δε αυτω ο πετροϲ ειπεν ει ϲυ ει κε κε κελευ ϲον με ελθιν προϲ ϲε επι τα ϋδατα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ο δε ειπεν ελθε και καταβαϲ απο του πλοιου πετροϲ πε ριεπατηϲεν επι τα ϋδατα ελθιν ηλ θεν ουν προϲ τ ο τ ο ι ν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "βλεπων δε τ ο τ ο ανεμον εφοβη θη και αρξαμενοϲ καταποντιζεϲθε εκραξεν λεγων κε κε ϲωϲον με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ευ θυϲ δε ο ιϲ εκτιναϲ την χειρα επελα βετο αυτου και λε γει αυτω ολιγοπι ϲτε ειϲ τι εδιϲταϲαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "και αναβαντων αυτων ειϲ το πλοι ον εκοπαϲεν ο α νεμοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "οι δε εν τω πλοιω προϲεκυ νηϲαν αυτω λε γοντεϲ αληθωϲ θυ υϲ ει :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "και διαπε ραϲαντεϲ ηλθον επι την γην ειϲ γ ε νηϲαρετ γ ε νηϲαρετ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "και επι γνοντεϲ αυτον οι ανδρεϲ του τοπου απεϲτιλαν ειϲ ολ η ολ η την περιχωρον εκινην και προϲη νεγκαν αυτω π α ταϲ π α ταϲ τουϲ κακωϲ ε χονταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "και παρε καλουν αυτον ϊ να μονον αψων ται του κραϲπεδου του ϊματιου αυτου και οϲοι ηψαντο εϲωθηϲαν",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 15,
      "verses": [
        {
          "verse": 1,
          "original": "τοτε προϲερχοντε τω ιυ απο ϊεροϲο λυμων φαριϲαι οι και γραμματειϲ λεγοντεϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "δια τι οι μαθητε ϲου παρα βενουϲι την παρα δοϲιν των πρεϲ βυτερων ου γαρ νιπτονται ταϲ χι ραϲ χειραϲ οταν αρτον εϲ θιωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ο δε αποκριθειϲ ει πεν αυτοιϲ δια τι κ(αι) ϋμειϲ παραβενε τε την εντολην του θυ δια την πα ραδοϲιν ϋμων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "ο γαρ θϲ ενετιλατο λε γων ειπεν ενετιλατο λεγων τιμα τον π ρ α και την μρ α και ο κακολογων π ρ α πρ α η μ ρ α μ ρα θανατω τελευτατω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ϋμιϲ δε λεγετε οϲ α ειπη τω πρι η τη μρ ι μρ ι δωρον ο εαν εξ ε μου ωφεληθηϲ ουδεν εϲτιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ου μη τιμηϲη τον π ρ α πρ α αυ του και ηκυρωϲα τε τον νομον λογον νομον του θυ δια την παραδο ϲιν υμων ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ϋποκριται καλωϲ επροφητευ ϲεν περι ϋμων η ϲαϊαϲ λεγων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ο λαοϲ ουτοϲ τοιϲ χιλεϲιν με τιμα η δε καρδια αυτ ω αυτ ω πορρω απεχει α π εμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "ματην δε ϲεβον ται με διδαϲκον τεϲ διδαϲκαλιαϲ ενταλματα α νω α νων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και προϲκαλεϲα μενοϲ τον οχλον ειπεν αυτοιϲ ακου ετε και ϲυνϊετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ου το ειϲερχομενον ειϲ το ϲτομα του το κοινοι τον αν θρωπον αλλα το εκπορευο μενον εκ του ϲτο ματοϲ τουτο κοι νοι τον α νο ν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "τοτε προϲελθοντεϲ οι μαθηται ειπαν αυτω οιδαϲ οτι οι φαριϲαιοι α κουϲαντεϲ τον λο γον εϲκανδαλιϲθη ϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ο δε αποκριθιϲ ειπ ε ειπ ε παϲα φυτια ην ου κ εφυτευϲεν ο πηρ μου ο ουρανιοϲ εκ ριζωθηϲετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "αφετε αυτουϲ οδη γοι ειϲιν τυφλοι τυφλοι ειϲιν οδηγοι τυφλων οδηγοι ειϲιν τυφλοι τυφλοϲ δε τυφλον εαν οδηγη αμφο τεροι ειϲ βοθυνον πεϲουνται πεϲουντε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "αποκριθειϲ δε ὁ πετροϲ ειπεν αυτω φραϲον ημιν την παραβολην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ο δε ειπεν ακμην και ϋμιϲ αϲυνετοι εϲτε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ουπω νοϊτε οτι παν το ειϲπορευ ομενον ειϲ το ϲτο μα ειϲ την κοιλι αν χωρι και ειϲ τον αφεδρωνα εκβαλ λετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "τα δε εκπορευ ομενα εκ του ϲτο ματοϲ εκ τηϲ καρ διαϲ εξερχεται κα κεινα κοιν οι αν θρωπον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "εκ γαρ τη ϲ καρ διαϲ εξερχονται διαλογιϲμοι πο νηροι φονοι · μοι χειαι · πορνιαι · κλο παι · ψευδομαρτυρι αι · βλαϲφημιαι ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ταυτα εϲτιν τα κοι νουντα τον α νο ν ανον το δε ανιπτοιϲ χερ ϲιν φαγιν ου κοι νοι τον α νο ν ανον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "και εξελθων εκι θεν ο ιϲ ιϲ ανεχωρη ϲεν ειϲ τα μερη τυ ρου και ϲιδωνοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και ϊδου γυνη χα ναναια απο των οριων εκινων ε ξελθουϲα εκραξ ε εκραζ ε λεγουϲα ελεηϲον με κε κε ϋϊε δα δ η θυ γατηρ μου κακωϲ δαιμονιζετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ὁ δε ουκ απεκριθη αυτη λογον και προϲελ θοντεϲ οι μαθη ται αυτου ηρωτο υ ηρωτο υ αυτον λεγοντεϲ απολυϲον αυτην οτι κραζει οπιϲθ ε ημων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ὁ δε αποκριθιϲ ει πεν ουκ απεϲτα λην ει μη ειϲ τα προβατα τα απο λωλοτα οικου ιηλ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "η δε ελθουϲα προ ϲεκυνι προϲεκυνηϲεν αυτω λε γουϲα κε βοηθι μοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ὁ δε αποκριθειϲ ει πεν ουκ εϲτιν κα λον λαβιν τον αρ τον των τεκν ω τεκν ω και βαλιν τοιϲ κυ ναριοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "η δε ειπ ε ειπ ε ναι κε κε και γαρ τα κυ ναρια εϲθιει απο τ ω τ ω ψιχιων των πιπτ ο των πιπτ ο των απο τηϲ τρα πεζηϲ των κυρι ων αυτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "τοτε α ποκριθειϲ ὁ ιϲ ειπ ε αυτη ω γυναι με γαλη ϲου η πιϲτιϲ · γενηθητω ϲοι ωϲ θελιϲ και ϊαθη η θυγατηρ αυτηϲ απο τηϲ ωραϲ εκινηϲ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και μεταβαϲ εκιθεν ὁ ιϲ ιϲ ηλθ ε ηλθ ε παρα την θαλαϲϲ α θαλαϲϲ α τηϲ γαλιλαιαϲ και αναβαϲ ειϲ το οροϲ εκαθητο εκει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και προϲηλθον αυ τω οχλοι πολλοι εχοντεϲ μεθ εαυτ ω εαυτ ω χωλουϲ · τυφλουϲ · κυλλουϲ · κωφουϲ · και ετερουϲ πολλουϲ και εριψαν αυτουϲ παρα τουϲ ποδαϲ αυ του και εθεραπευϲ ε εθεραπευϲ ε αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ωϲτε τον οχλον θαυμαϲε βλε πονταϲ κωφουϲ λαλουνταϲ και χωλουϲ περιπα τουνταϲ : και τυφλουϲ βλεπονταϲ και εδοξαζον τον θν ι ϲ λ θν ιϲ λ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "ὁ δε ιϲ ιϲ προϲκαλεϲα μενοϲ τουϲ μαθη ταϲ ειπεν αυτοιϲ ϲπλαγχνιζομε ε πι τον οχλον οτι ηδη ημεραϲ · γ · προ ϲμενουϲι μοι και ουκ εχουϲιν τι φα γωϲιν και απολυ ϲε αυτουϲ νηϲτιϲ ου θελω μη εκλυ θωϲιν εν τη οδω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "και λεγουϲιν αυτω οι μαθηται ποθ ε ποθ ε ημιν εν ερημια αρτοι τοϲουτοι ωϲ τε χορταϲε οχλον τοϲουτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "και λεγι αυτοιϲ ο ιϲ ιϲ ποϲουϲ αρτουϲ εχετε οι δε ειπαν επτα · και ο λιγα ϊχθυδια",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "και παραγγιλαϲ τω οχλω αναπεϲιν ε πι την γην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "ελαβ ε ελαβ ε τουϲ επτα αρτουϲ κ(αι) τουϲ δυο ϊχθυαϲ και ευχαριϲτηϲαϲ εκλαϲεν και εδι δου τοιϲ μαθηταιϲ μαθητεϲ οι δε μαθηται μαθητε τοιϲ οχλοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "και εφαγ ο παντεϲ και εχορ ταϲθηϲαν και η ραν το περιϲϲευ ο των κλαϲματ ω επτα ϲπυριδαϲ πλη ριϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "οι δε εϲθιοντεϲ ηϲαν ανδρεϲ ωϲι τετρακιϲχιλιοι χωριϲ πεδιων και γυνεκων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "και απολυϲαϲ τουϲ οχλουϲ ενεβη ειϲ το πλοιον και ηλθ ε ειϲ τα ορια μαγαδ α μαγεδ α",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 16,
      "verses": [
        {
          "verse": 1,
          "original": "και προϲελθοντεϲ οι φαριϲαιοι και οι ϲαδδουκαιοι πι ραζοντεϲ επηρω των ηρωτηϲαν επηρωτων αυτον ϲημι ον εκ του ουνο υ επιδιξε αυτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "ὁ δε αποκριθειϲ ει πεν αυτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "γενε α πονηρα και μοι χαλιϲ ϲημιον ε πιζητει και ϲημι ον ου δοθηϲετε αυτη ει μη το ϲη μιον ϊωνα ˙ και κα αυτουϲ απηλθεν ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "και ελ θοντεϲ οι μαθη ται ειϲ το περαν ε πελαθοντο αρτουϲ λαβειν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ὁ δε ιϲ ιϲ ειπεν ορατε και προϲεχετε απο τηϲ ζυμηϲ των φαριϲαιων και ϲαδδουκαι ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "οι δε διελογιζον το εν εαυτοιϲ λεγ ο τεϲ οτι αρτουϲ ου κ ελαβομεν ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "γνουϲ δε ο ιϲ ειπ ε τι διαλογιζεϲθε ε ν εαυτοιϲ ολιγο πιϲτοι οτι αρτουϲ ουκ εχετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "ουπω νοειτε ουδε μνημονευεται τουϲ πεντε αρτουϲ τ ω πεντακιϲχιλιων και ποϲουϲ κοφι νουϲ ελαβετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ου δε τουϲ ζ · ζ · αρτουϲ τ ω τ ω τετρακιϲχιλιων και ποϲαϲ ϲπυριδαϲ ελαβετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "πωϲ ου νοειτε οτι ου πε ρι αρτων ειπον υ μιν προϲεχετε δε απο τηϲ ζυμηϲ τ ω τ ω φαρειϲαιων και ϲαδ δουκαιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "τοτε ϲυνηκαν οτι ουκ ει πεν προϲεχειν α πο τηϲ ζυμηϲ [1 chars] τ ω φαρειϲαιων και ϲαδ δουκαιων αρτ ω αλλα α πο τηϲ διδαϲκαλιαϲ διδαχηϲ των φαρειϲαιων κ(αι) ϲαδδουκαιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ελθων δε ο ιϲ ειϲ τα μερη καιϲαριαϲ τηϲ φιλιππου ηρωτα τουϲ μαθηταϲ αυ του λεγων τινα οι α νο ι ειναι λεγουϲ ι λεγουϲ ι ειναι τον υϊον του α νου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "οι δε ειπον οι μεν ιωανην τον βαπτι ϲτην αλλοι δε ηλι α ετεροι δε ϊερεμιαν η ενα των προφητ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "λεγει αυτοιϲ υμειϲ δε τινα με λεγετε ειναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "αποκριθειϲ ωᵨ δε ϲιμων πετροϲ ειπεν ϲυ ει ο χϲ ο υϲ του θυ του ζ ω τοϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "αποκριθειϲ δε ο ιϲ ειπεν αυτω μακαριοϲ ει ϲιμων βαρϊωνα οτι ϲαρξ · και αιμα ουκ απε καλυψεν ϲοι αλλα ο π ηρ μου ο εν τοιϲ ουρανοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "καγω δε ϲοι λεγω οτι ϲυ ει πε τροϲ και επι ταυτη τη πετρα οικοδο> μηϲω μου την εκ κληϲιαν και πυλαι αδου ου κατιϲχυϲου ϲιν αυτηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "δωϲω > ϲοι ταϲ κλιδαϲ κλιϲ τηϲ βαϲιλειαϲ των ου ρανων και ο εαν δη ϲηϲ επι την γην τηϲ γηϲ ε ϲται δεδεμενον εν τοιϲ ουρανοιϲ και ο εαν λυϲηϲ ε> πι τηϲ γηϲ εϲται λε λυμενον εν τοιϲ ουρανοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "τοτε διε ϲτειλατο τοιϲ μαθη ταιϲ ϊνα μηδενι ει πωϲιν οτι αυτοϲ εϲτιν ιϲ ο χϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "απο τοτε ηρξατο ιϲ χϲ ο ιϲ δικνυειν τοιϲ μαθηταιϲ αυτου οτι δει αυτον ειϲ ϊεροϲολυμα απελ θειν και πολλα πα θειν απο των πρε ϲβυτερων και αρχι ερεων και γραμμα τεων και αποκτ α θηναι και τη τριτη ημερα εγερθηναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και προϲλαβομενοϲ αυτον ο πετροϲ ηρ ξατο επιτιμαν αυ τω λεγων ειλεωϲ ϲοι κε ου μη εϲται ϲοι τουτο ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ο δε ϲτρα φειϲ ειπεν τω πε τρω υπαγε οπιϲω μου ϲατανα ϲκαν δαλον ει εμου μου οτι ου φρονειϲ τα του θυ αλλα τα των αν θρωπων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "τοτε ο ιϲ ειπεν τοιϲ μαθηταιϲ αυτου ει τιϲ θελει οπιϲω μου ελθειν απαρνη ϲαϲθω εαυτον κ(αι) αρατω τον ϲταυ ρον αυτου και ακο λουθειτω μοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "οϲ γαρ εαν θελη την ψυχην αυτου ϲω ϲαι απολεϲει αυτ η οϲ δ αν απολεϲη > την ψυχην αυτου ενεκεν εμου ευ> ρηϲει αυτην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "τι γαρ ωφεληθηϲεται ανθρωποϲ εαν οταν εαν τ ο κοϲμον ολον κερ δηϲη την δε ψυχ η ψυχ η αυτου ζημιωθη η τι δωϲει α νο ϲ α ταλλαγμα α ταλλαγμα τηϲ ψυ χηϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "μελλει γαρ ο ϋϊοϲ του ανο υ ερχεϲθαι εν τη δο ξη του π ρ ϲ αυτου μετα των αγγελ ω αγγελ ω αυτου και τοτε απο δωϲει εκαϲτω κατα τα εργα την πραξιν αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "αμ η λεγω ϋμιν οτι ειϲ ι τινεϲ των ωδε εϲτω των οιτινεϲ ου μη γευϲωνται θανα του εωϲ αν ϊδωϲιν τον υϊον του ανο υ ερχομενον εν τη βαϲιλεια αυτου δοξη τ(ου) πρϲ αυτου",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 17,
      "verses": [
        {
          "verse": 1,
          "original": "και μεθ ημεραϲ εξ παραλαμβανει ο ιϲ τον πετρον και τον ϊακωβον και ϊωανην τον αδελ φον αυτου και ανα φερει αυτουϲ ειϲ ο ροϲ ϋψηλον κατ ι διαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και μετεμορ φωθη εμπροϲθ ε εμπροϲθ ε αυτων και ελαμψ ε ελαμψ ε το προϲωπον αυ του ωϲ ο ηλιοϲ τα δε ϊματια αυτου εγενετο λευκα ωϲ το φωϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και ϊδου > ωφθη αυτοιϲ μω υϲηϲ και ηλειαϲ ϲ υ λαλουντεϲ μετ αυ του",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "αποκριθειϲ δε ο πετροϲ ειπεν τω ιυ κε καλον εϲτιν ημαϲ ωδε ειναι ει θελειϲ ποιηϲω ωδε τρειϲ ϲκηναϲ ϲοι μι α και μωϋϲει μιαν και ηλεια μιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ετι αυτου λαλουν τοϲ ϊδου νεφελη φωτεινη επεϲκι αϲεν αυτουϲ και ϊ δου φωνη εκ τηϲ νεφεληϲ λεγουϲα ουτοϲ εϲτιν ο ϋιοϲ μου ο αγαπητοϲ ε ν ω ευδοκηϲα ακου ετε αυτου ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "και ακου ϲαντεϲ οι μαθηται επεϲαν επι προ> ϲωπον αυτων κ(αι) εφοβηθηϲαν ϲφο δρα ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "και προϲηλθ ε ο ιϲ και αψαμενοϲ αυτων ειπεν εγερ θητε και μη φοβει ϲθε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "επαραντεϲ δε τουϲ οφθαλμουϲ αυτων ουδενα > ειδον ει μη ιν ιν αυτ ο αυτ ο μονον ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και κατα βαινοντων αυτ ω εκ του ορουϲ ενε> τειλατο αυτοιϲ ο ιϲ λεγων μηδενι ει πητε το οραμα εωϲ ου ο ϋϊοϲ του α νο υ α νου εκ νεκρων αναϲτη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και πηρωτηϲαν επηρωτηϲαν αυ τον οι μαθηται λε γοντεϲ τι ουν οι γραμματειϲ λεγου ϲιν οτι ηλειαν δει ελθειν πρωτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ο δε αποκριθειϲ ειπ ε αυτοιϲ οτι ηλειαϲ μεν ερχεται και α ποκαταϲτηϲει π α τα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "λεγω δε ϋμιν οτι ηλειαϲ ηδη ηλθεν και ουκ επεγνω ϲαν αυτον αλλ ε ποιηϲαν αυτω ο ϲα ουτωϲ και ο ϋϊοϲ του αν θρωπου μελλει > παϲχειν υπ αυτ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε ϲυνηκαν οι μαθηται οτι πε ρι ϊωανου του βα πτιϲτου ειπεν αυ τοιϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και ελθοντ ω προϲ τον οχλον προϲηλθεν αυτω ανθρωποϲ γονυ> πετων αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και λεγων ελεηϲον μου τον υϊον οτι ϲελη νιαζεται και κακωϲ εχει πολλακιϲ γαρ πιπτει ειϲ το πυρ κ(αι) πολλακιϲ ειϲ το ϋ δωρ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και προϲηνεγ κα αυτον τοιϲ μα θηταιϲ ϲου και ουκʼ ηδυνηθηϲαν αυ τον θεραπευϲαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ο δε αποκριθειϲ τοτε αποκριθειϲ ο ιϲ ει> πεν αυτοιϲ ω γε> νεα απιϲτοϲ και δι εϲτραμμενη εωϲ ποτε μεθ υμων εϲομαι εωϲ ποτε ανεξομαι ϋμων φερετε μοι αυτον ωδε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "και επετιμη ϲεν αυτω ο ιϲ και εξηλθεν απ αυτου το δαιμονιον και εθεραπευθη απο τηϲ ωραϲ εκεινηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "τοτε προϲελθον> τεϲ οι μαθηται τω ιυ κατ ϊδιαν ειπαν δια τι ημειϲ ουκ η δυνηθημεν εκβα λειν αυτο ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ο δε λε> γει αυτοιϲ δια τ η ολιγοπιϲτιαν ϋμ ω αμην γαρ λεγω ϋμ ι εαν εχητε πιϲτιν ωϲ κοκκον ϲινα πεωϲ ερειτε τω ο ρει τουτω μεταβα ενθεν εκει και με ταβηϲεται και ου δεν αδυνατηϲει ϋμιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "τουτο δε το γενοϲ ουκ εκβαλλεται ει μη εν προϲευχη κ(αι) νηϲτεια",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ϲυϲτρεφο μενων δε αυτ ω εν τη γαλειλαια ει πεν αυτοιϲ ο ιϲ μελ λει ο ϋιοϲ του ανου παραδιδοϲθαι ειϲ χειραϲ ανθρωπ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και αποκτενου ϲιν αυτον και τη τριτη ημερα εγερ θηϲεται και ελυ πηθηϲαν ϲφοδρα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ελθοντων δε αυ των ειϲ καφαρνα ουμ προϲηλθον οι τα τ̣α διδραχμα λαμ βανοντεϲ τω πε τρω και ειπον ειπαν ο > διδαϲκαλοϲ υμ ω ου τελει τα διδραχμα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "λεγει ναι και ειϲελθοντα ελθοντα ειϲελθοντα ειϲ την οικιαν προε φθαϲεν αυτον ο ιϲ ιϲ λεγων ϲοι > δοκει ϲιμων οι > βαϲιλειϲ τηϲ γηϲ απο τινων λαμ βανουϲιν τελη η κηνϲον απο > των υϊων αυτ ω η απο των αλλο τριων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ο δε εφη α πο των αλλοτρι ω ειποντοϲ δε απο των αλλοτριων εφη αυτω ο ιϲ αρα γε ελευθεροι ειϲιν οι υϊοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ϊνα δε μη > ϲκανδαλιζωμεν αυτουϲ πορευθειϲ ειϲ θαλαϲϲαν βαλε βαλε αγκιϲτρον και τον αναβαντα πρωτ ο πρωτ ο ϊχθυν αρον και α νοιξαϲ το ϲτομα αυτου ευρηϲειϲ > ϲτατηρα εκεινον λαβων δοϲ αυτοιϲ αντι εμου και ϲου",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 18,
      "verses": [
        {
          "verse": 1,
          "original": "εν εκεινη τη ω> ρα προϲηλθον οι μαθηται τω ιυ λε γοντεϲ τιϲ αρα μει ζων εϲτιν εν τη βαϲιλεια των ου ρανων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και προϲκαλεϲαμε νοϲ παιδιον εϲτη ϲεν αυτο εν μεϲω αυτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και ειπεν αμην λεγω ϋμιν εαν μη ϲτραφητε και γενηϲθε ωϲ τα παιδια ου μη ειϲ ελθηε ειϲελθητε ειϲ την βα ϲιλειαν των ουρα νων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "οϲτιϲ ουν ταπινωϲει εαυ τον ωϲ το παιδιον τουτο ουτοϲ εϲτ ι εϲτ ι ο μειζων εν τη βα ϲιλεια των ουρα νων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "και οϲ εαν δε ξηται παιδιον εν τοιουτο επι τω ο νοματι μου εμε δεχεται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "οϲ δ αν ϲκ α δαλιϲη ενα των > μεικρων τουτ ω των πιϲτευοντ ω ειϲ εμε ϲυμφερει αυτω ϊνα κρεμα> ϲθη μυλοϲ ονικοϲ περι τον τραχηλον αυτου και καταπ ο τιϲθη εν τω πελαγι τηϲ θαλαϲϲηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ουαι τω κοϲμω απο των ϲκανδαλων αναγκη γαρ εϲτιν ελθειν τα ϲκανδαλα πλην ουαι τω α νω δι ου το ϲκανδαλ ο ερχεται ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ει δε η χειρ ϲου η ο πουϲ ϲου ϲκ α δαλιζει ϲε εξελε εκκοψ ο αυ τον και βαλε απο ϲου καλον ϲοι εϲτιν ειϲ ελθειν ειϲ την ζω η ζω η κυλλον η χωλον η δυο χειραϲ η δυο πο δαϲ εχοντα βληθη ναι ειϲ το πυρ το αι ωνιον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και ει ο ο> ϲου ϲκ α δαλιζει ϲε εξελε αυ τον και βαλε απο > ϲου καλον ϲοι εϲτ ι μονοφθαλμον ειϲ την ζωην ειϲ ελθειν η δυο οφθαλ μουϲ εχοντα βλη θηναι ειϲ την γε ενναν του πυ> ροϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ορατε μη καταφρο νηϲητε ενοϲ τ ω μεικρων τουτ ω λεγω γαρ υμιν ο τι οι αγγελοι αυτ ω εν ουρανοιϲ δια παντοϲ βλεπουϲι το προϲωπον του πατροϲ μου του εν ουρανοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "τι υμιν δοκει εαν γε νηται τινι ανω εκατον προβατα και πλανηθη ε εξ αυτων ουχι α φιϲ τα ενενηκ ο τα εννεα επι τα ορη πορευ θειϲ ζητι το πλα νωμενον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και ε αν γενηται ευριν ευρ ι αυτο αμην λεγω ϋμιν οτι χαιρι επ αυτω μαλλον η επι τοιϲ ενενηκοντα εν νεα τοιϲ μη πε πλανημενοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ουτωϲ ουκ εϲτιν θελημα του πρ ϲ ϋ μων του εν ουρα νοιϲ ϊνα απολη ται εν των μικρ ω τουτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "εαν δε αμαρτηϲη ὁ αδελφοϲ ϲου ϋ παγε ελεγξον αυ τον μεταξυ ϲου κ(αι) αυτου μονου ε α ϲου ακουϲη εκερ δηϲαϲ τον αδελ φον ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "εαν δε μη ακουϲη παρα λαβε μετα ϲεαυτου ετι ενα η δυο ϊνα επι ϲτοματοϲ δυ ο η τριων μαρτυ ρων ϲταθη παν ρημα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "εαν δε πα ρακουϲη αυτων ειπον τη εκκλη ϲια εαν δε και τηϲ εκκληϲιαϲ παρα κουϲη εϲτω ϲοι ωϲπερ ο εθνικοϲ και ο τελωνηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "αμην λεγω ϋμ ι οϲ οϲα εαν δηϲητε ε πι τηϲ γηϲ εϲται δεδεμενα εν δεδεμενο̣ν̣ ε̣ν̣ τοιϲ ουρανοιϲ κ(αι) και οϲα αν εαν εαν λυϲηται ε πι τηϲ γηϲ εϲται λελυμενα εν ου ρανω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "παλιν λεγω ϋμιν οτι εαν δυο ϲυμ φωνηϲουϲιν ε ξ ϋμων επι τηϲ γηϲ περι παντοϲ πραγματοϲ ου ε α αιτηϲωνται αυ τοιϲ γενηϲεται παρα του πρϲ μου του εν ο υνο ιϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ου οπου ὁυ γαρ ειϲιν δυο η · γ · ϲυ νηγμενοι ειϲ το εμον ονομα εκει ειμι εν με ϲω αυτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "τοτε προϲελθ ω αυτω ο πετροϲ ειπεν κε ποϲακιϲ αμαρτη ϲι ειϲ εμε ο αδελ φοϲ μου και αφη ϲω αυτω εωϲ επτα κιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "λεγι αυτω ο ιϲ ου λεγω ϲοι εωϲ ε πτακιϲ αλλ εωϲ εβδομηκοντακιϲ επτα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "δια τουτο ωμοιω θη η βαϲιλια των ο υνω ν α νω βαϲι λι οϲ ηθεληϲεν ϲυναραι λογον με τα των δουλων αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "αρξαμενου δε αυτου ϲυναιρ ι ϲυναιρ ι προϲηνεχθη ειϲ αυτω αυτω ειϲ οφιλετηϲ πολλων μυριων ταλαντ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "μη εχοντοϲ δε αυτου αποδουνε εκελευϲεν αυτ ο αυτ ο ο κϲ πραθηνε πραθηναι και την γυνεκα γυναικα και τα πεδια και παντα ο ϲα ειχεν και απο δοθηνε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "πεϲων ουν ο δουλοϲ εκινοϲ προϲ εκυνι αυτω λεγ ω κε μακροθυμηϲ ο επ εμοι και παντα αποδωϲω ϲοι ‾̷‾",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ϲπλαγχνιϲθιϲ δε ο κϲ του δουλου ε κινου απελυϲεν αυτον και το δανι ον αφηκεν αυτω ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "εξελθων δε ο δου λοϲ εκινοϲ ευρεν ενα των ϲυνδου λων αυτου οϲ ω φιλεν αυτω εκατ ο εκατ ο δηναρια και κρατη ϲαϲ αυτον επνιγ ε επνιγ ε λεγων αποδοϲ ει τι οφιλιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "πεϲων ουν ο ϲυνδουλοϲ αυτου παρεκαλι αυτον λεγων μακροθυμηϲον επ εμοι και παντα απο δωϲω ϲοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "ο δε ου κ ηθελεν και αλλα α πελθων εβαλεν αυτον ειϲ φυλακ η εωϲ αποδη αποδω το ο φιλομενον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ϊδ ο τεϲ ϊδ ο τεϲ ουν δε ουν οι ϲυνδου λοι αυτου τα γεινομενα γενομενα ελυπηθη ϲαν ϲφοδρα οι δε ελθοντεϲ διεϲα φηϲαν τω κω εαυ των παντα τα γε νομενα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "τοτε προϲκαλεϲα μενοϲ αυτον ο κϲ αυτου λεγι αυτω δουλε πονηρε πα ϲαν την οφιλην εκινην αφηκα ϲοι επι παρεκαλεϲαϲ με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "ουκ εδει και ϲε ελεηϲε τον ϲυν δουλον ϲου ωϲ καγω ϲε ηλεηϲα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "και οργιϲθιϲ ο κϲ ωᵨ αυτου παρεδω κεν αυτον τοιϲ βαϲανιϲταιϲ εω ϲ εωϲ ου αποδω παν το ὁφιλομεν ο ὁφιλομεν ο αυτω αυτω ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ουτωϲ και ο πη ρ μου ο ουρα νιοϲ ποιηϲι ϋμ ι ϋμ ι εαν μη αφητε εκαϲτοϲ τω αδελ φω αυτου απο τ ω καρδιων ϋμων",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 19,
      "verses": [
        {
          "verse": 1,
          "original": "και εγενετο οτε ε τελεϲεν ο ιϲ τουϲ λογουϲ τουτουϲ μετηρεν απο τηϲ γαλιλαιαϲ και ηλ θεν και ηλθεν ειϲ τα ορια τηϲ ιουδε αϲ ιουδαιαϲ περαν του ϊορ δανου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ηκο λουθηϲαν αυτω οχλοι πολλοι και εθεραπευϲεν αυ τουϲ εκι :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και προ ϲηλθον ‾̷‾ προϲηλθον αυτω οι φαριϲεοι πιραζ ο τεϲ πιραζ ο τεϲ αυτον και λε γοντεϲ ει εξεϲτ ι ἀ ν ῴ απολυϲε την γυ νεκα αυτου κατα παϲαν αιτιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "ὁ δε αποκριθειϲ ειπεν ουκ ανε γνωτε οτι ο ποι ηϲαϲ απ αρχηϲ · αρϲεν και θηλυ εποιηϲεν αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "και ειπεν ενεκα τουτου κα ταλιψι ανο ϲ τον πρ α και την μρ α και προϲκολλη θηϲετε τη γυνε κι γυναικι αυτου και εϲ ο τε οι δυο ειϲ ϲαρ κα μιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ωϲτε ου κετι ειϲιν δυο αλλα μια ϲαρξ · ο ο υ ο υ ο θϲ ϲυνεζευξ ε ϲυνεζευξ ε α νο ϲ ανοϲ μη χωριζε τω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "λεγουϲιν αυτω τι ουν μωϲηϲ μωϋϲηϲ μωϋϲηϲ ε νετιλατο δουνε βιβλιον αποϲταϲι και απολυϲε :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "λεγι αυτοιϲ ο ιϲ ιϲ οτι μωϋϲηϲ προϲ τ η τ η ϲκληροκαρδιαν ϋμων επετρεψ ε επετρεψ ε ϋμιν απολυϲαι ταϲ γυναικαϲ ϋμων απ αρχηϲ δε ου γε γονεν ουτωϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "λε γω δε ϋμιν οτι ο ϲ οϲ αν απολυϲη τ η γυνεκα γυναικα αυτου μη επι πορνια και γα μηϲη αλλην μοι χατε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "λεγουϲιν αυτω οι μαθη ται ει ει ουτωϲ εϲτιν η αιτια του α νου α νου μετα τηϲ γυνεκοϲ γυναικοϲ ου ϲυμφερι γαμη ϲαι ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ὁ δε ειπεν αυ τοιϲ ου παντεϲ χωρουϲι τον λογ ο τουτον αλλ οιϲ δε δοτε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ειϲιν γαρ ευνου χοι οιτινεϲ εκ κοι λιαϲ μρϲ εγεννη θηϲαν ουτωϲ · και ειϲιν ευνου χοι οιτινεϲ ευνου χιϲθηϲαν ϋπο τ ω α νω ν α νων και ειϲιν ευνουχοι οιτι νεϲ ευνουχιϲ α εαυτουϲ δια την βαϲιλειαν των ο υνω ν : ο δυναμενοϲ χω ριν χωριτω :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε προϲηνεχθη ϲαν αυτω πεδια ϊνα ταϲ χιραϲ επι θη αυτοιϲ και προϲ ευξητε οι δε μα θητε επετιμηϲ α αυτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ὁ δε ιϲ ειπεν αυτοιϲ αφετε τα πεδια και μη κωλυετε αυτα ελθιν προϲ εμε των γαρ τοιουτ ω εϲτιν η βαϲιλια τ ω ο υνω ν :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και επι θιϲ ταϲ χιραϲ επ αυ τουϲ επορευθη ε κειθεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και ϊδου ειϲ προϲελ θων αυτω ειπεν διδαϲκαλε τι αγα θον ποιηϲαϲ ζω ην αιωνιον κλη ρονομηϲω :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ὁ ο δε ειπεν αυτω τι με ερωταϲ πε ρι του αγαθου ειϲ εϲτιν ὁ ο αγαθοϲ ει δε θελιϲ ειϲ την ζωην ειϲελθιν τηρηϲον ταϲ εν τολαϲ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ποιαϲ φηϲιν : ο δε ιϲ ιϲ ειπεν το ου φονευϲιϲ ου μοιχευϲιϲ ου κλεψειϲ ου ψευδομαρτυρηϲιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "τιμα τον πρα και την μρα και αγα πηϲειϲ τον πλη ϲιον ϲου ωϲ ϲεαυ τον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "λεγι αυτω ο νεανι ϲκοϲ παντα ταυ τα εφυλαξα εκ νεοτητοϲ μου τι ετι ϋϲτερω :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "εφη αυτω ο ιϲ ει θελιϲ τελι οϲ γενεϲθε ειναι ϋπαγε πωληϲον ϲου τα ϋπαρχοντα και δοϲ πτωχοιϲ και εξειϲ εξετε θηϲαυρον ε ν ουν ω και δευ ρο ακολουθι μοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "ακουϲαϲ δε ο νεα νιϲκοϲ απηλθεν λυπουμενοϲ ην γαρ εχων κτημα τα πολλα ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ὁ ο δε ιϲ ειπεν τοιϲ μαθηταιϲ αυτου αμην λεγω ϋμιν οτι πλουϲιοϲ δυ ϲκολωϲ ειϲελευ ϲετε ειϲ την βαϲι λιαν των ο υνω ο υνω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "παλιν δε λεγω ϋ μιν οτι ευκοπω τερον εϲτιν καμη λον δια τρηματοϲ τρυπηματοϲ ραφιδοϲ ειϲελθιν η πλουϲιον ειϲ τ η βαϲιλιαν του θυ θυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ακουϲαντεϲ δε δε οι μαθηται εξεπληϲ ϲοντο ϲφοδρα λεγ ο τεϲ λεγ ο τεϲ τιϲ αρα δυνατε ϲωθηνε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "εμβλεψαϲ δε ο ιϲ ιϲ ει πεν αυτοιϲ παρα ανοι ϲ τουτο αδυνατον εϲτιν παρα δε θω θω δυνα τα παντα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "τοτε αποκριθειϲ ο πετροϲ ειπεν αυ τω ϊδου ημιϲ αφη καμεν παντα και ηκολουθηϲαμ ε ϲοι τι αρα εϲται η μιν ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ο δε ιϲ ειπεν αυτοιϲ αμην λεγω ϋμ ι ϋμ ι οτι ϋμιϲ οι ακολου θηϲαντεϲ μοι εν τη παλινγενεϲι α οταν καθιϲη ο υϲ υϲ του α νου επι θρο νου δοξηϲ αυτου καθηϲεϲθε και αυ τοι επι · ιβ · θρονουϲ κρινοντεϲ ταϲ ιβ φυλαϲ του ιηλ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και παϲ οϲτιϲ αφη κεν αδελφουϲ η αδελφαϲ η π ρ α πρ α η μ ρ α μρ α η γυναικα η τεκνα η αγρουϲ ε νεκα η οικιαϲ ενεκα του εμου ο νοματοϲ ˙ εκατον ταπλαϲιονα λημ ψετε και ζωην αι ωνιον κληρονο μηϲι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "πολλοι δε εϲοντε εϲχατοι πρωτοι και πρωτοι εϲχατοι",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 20,
      "verses": [
        {
          "verse": 1,
          "original": "ομοια γαρ εϲτιν η βαϲιλια των ουρα νων α νω οικοδεϲπο τη οϲτιϲ εξηλθ ε αμα πρωϊ μιϲθω ϲαϲθε εργαταϲ ειϲ τον αμπελωνα αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "ϲυμφωνηϲαϲ δε μετα των εργα των εκ δηναριου την ημεραν απε ϲτιλεν αυτουϲ ειϲ τον αμπελωνα αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και εξελθων πε ρι τριτην ωραν ει δεν αλλουϲ εϲτω ταϲ εν τη αγορα αρ γουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και εκεινοιϲ ειπεν ϋπαγετε κ(αι) ϋμιϲ ειϲ τον αμ πελωνα μου και ο εαν η δικεον δικαιον δω ϲω ϋμιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "οι δε απηλ θον παλιν δε εξελθ ω εξελθ ω περι εκτην και ενα την ωραν εποιηϲ ε ωϲαυτωϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "περι δε την ενδεκα την εξελθων εξηλθεν ευρ ε ευρ ε αλλουϲ εϲτωταϲ και λεγει αυτοιϲ τι ωδε εϲτηκατε ολ η ολ η την ημεραν αργοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "λεγουϲιν αυτω οτι ουδιϲ ημαϲ εμιϲθωϲατο λεγει αυτοιϲ ϋπαγε τε και ϋμιϲ ειϲ τ ο αμπελωνα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "οψιαϲ δε γενομε νηϲ λεγι ο κϲ κϲ του αμπελωνοϲ τω επιτροπω αυτου καλεϲον τουϲ ερ γαταϲ και αποδοϲ τον μιϲθον αρξα μενοϲ απο των εϲχατων εωϲ τ ω τ ω πρωτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και ελθ ο τεϲ οι περι την εν δεκατην ωραν ε λαβον ανα δηνα ριον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "ελθοντεϲ δε οι πρω τοι ενομιϲαν ο τι πλιονα λημψ ο ται και ελαβον το ανα δηναριον και αυτοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "λαβοντεϲ δε εγογγυζον κα τα του οικοδεϲπο του",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "λεγοντεϲ ου τοι οι εϲχατοι μι αν ωραν εποιηϲ α εποιηϲ α και ϊϲουϲ εϊϲουϲ ϊϲουϲ αυτουϲ η εποιηϲαϲ τοιϲ βαϲταϲαϲι το βαροϲ τηϲ ημεραϲ και τ ο καυϲωνα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ο δε αποκριθειϲ ε νι αυτων ειπεν ετερε ουχ αδικω ϲε ουχι δηναριου ϲυνεφωνηϲαϲ μοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "αρον το ϲον και ϋπαγε θελω δε τουτω ω τω εϲχα τω δουναι ωϲ και ϲυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "η ουκ εξεϲτιν μοι ο θελω ποιη ϲε εν τοιϲ εμοιϲ η ο οφθαλμοϲ ϲου πονηροϲ εϲτιν οτι εγω αγαθοϲ ειμι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ουτωϲ εϲον τε οι εϲχατοι πρω τοι και οι πρωτοι εϲχατοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "και αναβενων ο ιϲ ιϲ ειϲ ϊεροϲολυμα παρελαβεν τουϲ ιβ κατ ϊδιαν και εν τη οδω ειπεν αυ τοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ϊδου αναβενο μεν ι ϲ ε ι ϲ ϊεροϲολυ μα και ο υϲ του αν θρωπου παραδο θηϲετε τοιϲ αρχι ερευϲιν και γραμ ματευϲιν και κα τακρινουϲιν αυτ ο αυτ ο ειϲ θανατον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και παραδωϲουϲιν αυτον τοιϲ εθνε ϲιν ειϲ το εμπε ξε και μαϲτιγωϲε μαϲτιγωϲαι και ϲταυρωϲε κ(αι) κ(αι) τη τριτη ημερα εγερ θηϲετε ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "τοτε προϲηλθεν αυτω η μητηρ τ ω ϋϊων ζεβεδαιου μετα των ϋϊων αυτηϲ προϲκυνου ϲα και αιτουϲα τι παρ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "ο δε ει πεν αυτη τι θε λιϲ λεγι αυτω ειπε ϊνα καθιϲωϲιν ου τοι οι δυο ϋϊοι μου ειϲ εκ δεξιων και ειϲ εξ ευωνυμ ω ϲου εν τη βαϲιλια ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "αποκριθιϲ δε ο ιϲ ιϲ ειπεν ουκ οιδα τε τι αιτιϲθε δυνα ϲθε πιειν το πο τηριον ο εγω μελ λω πινιν λεγου ϲιν αυτω δυνα μεθα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "λεγι αυτοιϲ το μ ε ποτηριον μου πιεϲθε το δε κα θιϲαι εκ δεξιων μου και εξ ευω νυμων ουκ εϲ τιν εμον δουνε αλλ οιϲ ητοιμα ϲται ϋπο του πρ ϲ μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "και ακουϲαντεϲ ακουϲαντεϲ δε οι δεκα ηρξαντο αγανακτιν των δυο αδελφ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ὁ δε ιϲ ιϲ προϲκαλε ϲαμενοϲ αυτουϲ ειπεν οιδατε ο τι οι αρχοντεϲ τ ω τ ω εθνων κατακυ ριευουϲιν αυτ ω αυτ ω και οι μεγαλοι κα τεξουϲιαζουϲ ι κατεξουϲιαζουϲ ι αυτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ουχ ου τωϲ εϲτε εν ϋμ ι ϋμ ι αλλ οϲʼ εαν θελη εν ϋμιν μεγαϲ γενεϲθε εϲτε εϲτω ϋ μων διακονοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και οϲ αν θελη ε ν εν ϋμιν εινε πρω τοϲ εϲτε ϋμων δουλοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ωϲπερ ο υϲ υϲ του αν θρωπου ουκ ηλ θεν διακονηθη ναι αλλα διακο νηϲε και δουνε την ψυχην αυτου λυτρον αντι πολ λων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και εκπορευομε νων αυτων απο ϊεριχω ηκολουθη ϲεν αυτω οχλοϲ πολυϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και ϊδου δυο τυφλοι καθημενοι παρα την οδον ακουϲ α τεϲ ο οτι οτι ιϲ παραγει εκρα ξαν λεγοντεϲ ελε ηϲον ημαϲ ιυ ιυ ϋϊε δ α δ δαδ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ο δε οχλοϲ επετι μηϲεν αυτοιϲ ϊ να ϲιωπηϲωϲιν οι δε πολλω μαλ λον εκραξαν εκραζαν εκραξαν λεγ ο τεϲ λεγ ο τεϲ κε ελεηϲον η μαϲ υυ δ α δ υε δαδ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "και ϲταϲ ο ιϲ ιϲ εφω νηϲεν αυτουϲ και ειπεν τι θελετε ϊνα ποι ηϲω ϋμιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "λεγουϲ ι λεγουϲ ι αυτω κε κε ϊνα ανυγω ϲιν οι οφθαλμοι ϋμων ημων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "ϲπλαγχνιϲθειϲ δε ὁ ιϲ ιϲ ηψατο των ο φθαλμων αυτου αυτων και ευθεωϲ ανε βλεψαν και ηκο λουθηϲαν αυτω",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 21,
      "verses": [
        {
          "verse": 1,
          "original": "και οτε ηγγιϲαν ι ϲ ε ι ϲ ϊεροϲολυμα και ηλθεν ηλθον ειϲ βηθφα γη προϲ το οροϲ τ ω τ ω ελεων τοτε ο ιϲ ιϲ απεϲτιλεν · β · μαθηταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "λεγ ω λεγ ω αυτοιϲ ειϲ τ η τ η κωμην την κατε ναντει ϋμων και ευθυϲ ευρηϲετε ονον δεδεμεν η δεδεμεν η και πωλον μετ αυ τηϲ ︴ λυϲαντεϲ αγα γετε μοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και εαν τιϲ υ μιν ειπη τι · ε ρειτε οτι ο κϲ αυτου χριαν εχει ευθυϲ δε αποϲτελι αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "τουτο δε γεγονεν ϊνα πληρωθη το ρηθεν δια του προ φητου λεγοντοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ειπατε τη θυγατρι ϲιων > ϊδου ο βαϲιλευϲ ϲου > ερχετε ϲοι πραϋϲ > και επιβεβηκωϲ > επι ονον και επι > πωλον ϋϊον ϋϊον ϋπο > ζυγιου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "πορευθεντεϲ δε οι μαθηται και ποι ηϲαντεϲ καθωϲ προϲεταξεν αυτοιϲ ο ιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "κ(αι) ηγαγον την ο νον και τον πω λον και επεθηκ α επεθηκ α επ αυτων τα ϊμα τια αυτων και εκαθιϲαν επεκαθιϲαν επανω επ αυτ ω αυτ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ο δε πλιϲτοϲ οχλοϲ εϲτρωϲαν εαυτ ω τα ϊματια εν τη οδω αλλοι δε εκοπτ ο κλαδουϲ απο τ ω δενδρων και εϲ τρωϲαν εϲτρωννυον εν τη οδω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "οι δε οχλοι οι προ αγοντεϲ αυτον κ(αι) οι ακολουθουν τεϲ εκραζον λεγ ο τεϲ λεγ ο τεϲ ωϲαννα τω υυ ω δ α δ ευλογημενοϲ ο ερ χομενοϲ εν ονο ματι κυ ωϲαννα ε τοιϲ ϋψιϲτοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και ελθοντοϲ ειϲελθοντοϲ αυ του ϊϲ ϊεροϲολυμα εϲιϲθη παϲα η πολιϲ λεγουϲα τιϲ εϲτιν ουτοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "οι δε οχλοι ελεγ ο ουτοϲ εϲτιν ο προ φητηϲ ιϲ ο απο να ζαρεθ τηϲ γαλιλε αϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και ειϲηλθεν ὁ ιϲ ειϲ το ϊερον και εξεβα λεν πανταϲ τουϲ πωλουνταϲ και αγοραζονταϲ εν τω ϊερω και ταϲ τρα πεζαϲ των κολλυ βιϲτων κατεϲτρε ψεν και ταϲ καθε δραϲ των πωλο υ των πωλο υ των ταϲ περιϲτε ραϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "και λεγι αυτοιϲ γεγραπται ο οικοϲ μου οικοϲ προϲευ χηϲ κληθηϲετε ϋ μιϲ δε αυτον ποι ειτε ϲπηλεον λη ϲτων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και προϲηλθον προϲελθοντεϲ προϲηλθον αυτω τυφλοι και χωλοι εν τω ϊερω και εθεραπευϲεν αυτουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ϊδοντεϲ δε οι αρχι εριϲ και οι γραμμα τιϲ τα θαυμαϲια α ε ποιηϲεν και τουϲ παιδαϲ τουϲ κραζ ο ταϲ εν τω ϊερω και λεγονταϲ ωϲαν να τω ϋϊω δαδ η γανακτηϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και ειπαν αυτω ακου ειϲ τι ουτοι λεγουϲ ι λεγουϲ ι ο δε ιϲ λεγι αυτοιϲ ναι ουδεποτε α νεγνωτε > εκ ϲτοματοϲ νηπι ων > και θηλαζον των > κατηρτιϲω εν ο αιν ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "και καταλιπων αυ τουϲ εξηλθεν εξω τηϲ πολεωϲ ειϲ βη θανιαν και ηϋλιϲ θη εκει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "πρωϊ πρωϊαϲ δε επαναγαγ ω επαναγ ω ειϲ την πολιν επι ναϲεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και ϊδων ϲυ κην μιαν επι τηϲ οδου ηλθεν επ αυ την και ουδεν ευρεν εν εν αυτη ει μη φυλλα μονον και λεγει αυτη μηκετι εκ ϲου καρποϲ γενοιτο ειϲ τον αιωνα και εξηρανθη παρα χρημα η ϲυκη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και ϊδοντεϲ οι μα θητε εθαυμαϲαν λεγοντεϲ πωϲ πα ραχρημα εξηραν θη η ϲυκη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "αποκριθειϲ δε ο ιϲ ειπεν αυτοιϲ αμ η αμ η λεγω ϋμιν εαν ε χητε πιϲτιν και μη διακριθητε ου μο νον το τηϲ ϲυκηϲ ποιηϲετε αλλα κ α κ α τω ορι τουτω ειπη τε αρθητι και βληθη τι ειϲ την θαλαϲϲ α θαλαϲϲ α γενηϲετε :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και παν τα ‾̷‾ οϲα αν αιτηϲη τε εν τη προϲευχη πιϲτευοντεϲ λημ ψεϲθε :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και ελθοντοϲ αυτου ειϲ το ϊερον προϲηλθον αυτω διδαϲκοντι οι αρ χϊερειϲ και οι πρε ϲβυτεροι του λαου λεγοντεϲ εν ποι α εξουϲια ταυτα ποιειϲ και τιϲ ϲοι εδωκεν την εξου ϲιαν ταυτην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "αποκριθειϲ δε ο ιϲ ιϲ ειπεν αυτοιϲ ε ρωτηϲω ϋμαϲ και εγω λογον ενα ο ν ο εαν ειπητε μοι και εγω ϋμιν ερω εν ποια εξουϲια ταυτα ποιω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "το βαπτιϲμα το ϊω αννου ποθεν η ην ε ξ ουρανου η εξ αν θρωπων οι δε διελογιζοντο παρ εαυτοιϲ λεγ ο τεϲ εαν ειπωμ ε εξ ουρανου ερει η μιν δια τι ουν ου κ επιϲτευϲατε αυ τω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "εαν δε ειπωμεν εξ α νω ν ανω ν φοβου μεθα τον οχλον παντεϲ γαρ ωϲ προ φητην εχουϲι τ ο ι ωαννην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και αποκριθεντεϲ τω ιυ ιυ ειπαν ουκ οι δαμεν εφη αυτοιϲ ο ιϲ ιϲ ουδε εγω λε γω ϋμιν εν ποι α εξουϲια ταυτα ποι ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "τι δε ϋμιν δοκει α νο ϲ ειχεν τεκνα β κ(αι) προϲελθων τω πρωτω ειπεν τε κνον υ παγε ϲη μερον εργαζου ε τω αμπελωνι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ο δε αποκριθειϲ ει πεν ου θελω ϋϲ τερον δε μεταμελη θιϲ απηλθεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "προϲελθων δε τω ετερω δευτερω ειπεν ωϲ αυτωϲ ο δε αποκριθιϲ ειπεν εγω κε και ουκ απηλθεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "τιϲ εκ των β εποιηϲ ε το θελημα του πρ ϲ λεγουϲιν ο πρωτοϲ λεγι αυτοιϲ ο ιϲ ιϲ α μην λεγω ϋμιν οτι οι τελωνε τελωναι και αι πορναι προαγουϲ ι προαγουϲ ι ϋμαϲ ειϲ την βαϲι λιαν του θυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "ηλθεν γαρ ϊωαν νηϲ προϲ ϋμαϲ ε ν οδω δικεοϲυνηϲ δικαιοϲυνηϲ και ουκ επιϲτευϲα τε αυτω οι δε τελω νε και αι πορναι ε πιϲτευϲαν αυτω ϋμιϲ δε ειδοντεϲ ου μετεμεληθη τε ϋϲτερον του πι ϲτευϲαι αυτω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "αλλην παραβολ η παραβολ η ακουϲατε ανο ϲ ανοϲ η η οικοδεϲποτηϲ οϲτιϲ εφυτευϲεν αμπελωνα και φραγμον αυτω πε ριεθηκεν και ω ρυξεν εν αυτω λην ο λην ο και ωκοδομηϲ ε ωκοδομηϲ ε πυργον και εξεδε το εξεδοτο αυτον γεωργοιϲ και απεδημηϲ ε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "οτε δε ηγγιϲεν ο κ(αι) ροϲ των καρπων απεϲτιλεν τουϲ δου λουϲ αυτου προϲ τουϲ γεωργουϲ λαβειν κ̣α̣ι̣ λαβο̣ν̣ τουϲ καρ πουϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "και λα βοντεϲ οι γεωργοι τουϲ δουλουϲ αυ του ον μεν εδιρ α ον δε απεκτιν α ον δε ελιθοβολη ϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "και παλιν απεϲτι λεν αλλουϲ δουλουϲ πλιοναϲ των πρω των και εποιηϲ α εποιηϲ α αυτοιϲ ωϲαυτωϲ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "υϲτερον δε απεϲ τιλεν προϲ αυτουϲ τον υν υν αυτου λεγ ω εντραπηϲονται τον υν μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "οι δε γεωργοι ϊδοντεϲ τον υν ειπον εν ε αυτοιϲ ουτοϲ εϲ τιν ο κληρονομοϲ δευτε αποκτινω μεν αυτον και ϲχωμεν την κλη ρονομιαν αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "και λαβοντεϲ αυτ ο αυτ ο εβαλον εξω του αμπελωνοϲ και απεκτιναν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "οταν ουν ελθη ο κϲ του αμπελωνοϲ τι ποιηϲι τοιϲ γεωρ γοιϲ εκινοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "λεγου ϲιν αυτω κακουϲ κακωϲ απολεϲι αυτουϲ και τον αμπελωνα εκ δωϲετε αλλοιϲ γε ωργοιϲ οιτινεϲ αποδωϲουϲιν αυ τω τουϲ καρπουϲ εν τοιϲ καιροιϲ αυ των",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "λεγει αυτοιϲ ο ιϲ ιϲ ου δεποτε ανεγνω τε εν τεϲ γραφεϲ ταιϲ γραφαιϲ λιθον ον απεδο κιμαϲαν οι οικο δομουντεϲ ου τοϲ εγενηθη ειϲ κεφαλην γωνιαϲ παρα κω κυ εγενετο αυτη και εϲτιν θαυ μαϲτη εν οφθαλ μοιϲ ημων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "δια τουτο λεγω ϋ μιν αρθηϲετε αφ υ μων η βαϲιλια του θυ και δοθηϲετε εθνι ποιουντι τουϲ καρ καρπουϲ αυτου αυτηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "κ(αι) κ(αι) ο πεϲων επι τον λι θον τουτον ϲυν θλαϲθηϲετε εφ ο δ αν πεϲη λικμηϲι αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "ακουϲαντεϲ δε οι αρχϊεριϲ και οι φα ριϲεοι φαριϲαιοι ταϲ παραβο λαϲ αυτου εγνω ϲαν οτι περι αυτ ω λεγει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "και ζητουν τεϲ αυτον κρατη ϲαι εφοβηθηϲαν τον οχλον τουϲ οχλουϲ επι ειϲ προφητην αυτ ο ειχον",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 22,
      "verses": [
        {
          "verse": 1,
          "original": "και αποκριθειϲ ο ιϲ παλιν ειπεν εν εν πα ραβολαιϲ αυτοιϲ λε γων ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "ωμοιωθη η βαϲι λεια των ουραν ω α νω α νω βαϲιλι οϲτιϲ εποιηϲεν γαμουϲ τω ϋϊω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "και απεϲτιλεν τουϲ δουλουϲ αυτου κα λεϲε τουϲ κεκλη μενουϲ ειϲ τουϲ γαμουϲ και ουκ η θελον ελθιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "παλιν απεϲτιλ ε αλλουϲ δουλουϲ λεγων ειπατε τοιϲ κεκλημενοιϲ ϊ δου το αριϲτον μου ητοιμακα οι ταυροι μου και τα ϲιτιϲτα τεθυμενα και παντα ετοιμα δευτε ειϲ τουϲ γα μουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "οι δε αμελη ϲαντεϲ απηλθον ο μεν ειϲ τον ϊδι ον αγρον · οϲ δε ε πι την εμπορι α εμπορι α αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "οι δε λοιποι κρατηϲαντεϲ τουϲ δουλουϲ αυτου ϋ βριϲαν και απεκτι ναν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ο δε βαϲιλευϲ ωργι ϲθη και πεμψαϲ τα ϲτρατευματα αυ του απωλεϲεν τουϲ φονιϲ εκινουϲ κ(αι) την πολιν αυτ ω ενεπρηϲεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "τοτε λεγι τοιϲ δου λοιϲ αυτου ο μεν γα μοϲ ετοιμοϲ εϲτ ι οι δε κεκλημενοι ου κ ηϲαν αξιοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "πορευ εϲθε ουν επι ταϲ δι εξοδουϲ των ο> δων υ̣δ̣α̣των οδων και οϲουϲ ε α ε α ευρητε καλεϲατε ειϲ τουϲ γαμουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και εξελθοντεϲ οι δουλοι εκινοι ειϲ ταϲ οδουϲ ϲυνηγαγ ο ϲυνηγαγ ο πανταϲ ουϲ ευρον πονηρουϲ τε και αγαθουϲ και επλη ϲθη ο νυμφων α νακιμενων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ειϲελθων δε ο βα ϲιλευϲ θεαϲαϲθε τουϲ ανακιμενουϲ ειδεν εκει ανον ανον ουκ ε δεδυμενον ενδυ μα γαμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και λεγι αυτω εταιρε πωϲ ει ϲηλθεϲ ειϲ ηλθεϲ ωδε μη ε χων ενδυμα γαμ(ου) ο δε εφιμωθη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε ο βαϲιλευϲ ειπεν τοιϲ διακονοιϲ δη ϲαντεϲ αυτου ποδαϲ και χιραϲ εκβαλε τε αυτον ειϲ το ϲκο τοϲ το εξωτερον εκι εϲτε ο κλαυθ μοϲ και ο βρυγμοϲ των οδοντων ︴",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "πολλοι γαρ ειϲιν κλη τοι ολιγοι δε εκλεκτοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "τοτε πορευθεντεϲ οι φαριϲεοι ϲυμβου λιον ελαβον οπωϲ αυτον παγιδευϲωϲιν εν λογω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και αποϲτελλουϲ ι αποϲτελλουϲ ι αυτω τουϲ μαθηταϲ αυτων μετα των ηρωδιανων λεγ ο ταϲ λεγ ο ταϲ διδαϲκαλε οι δαμεν οτι αληθη ϲ ι αληθηϲ ει και την οδον του θυ εν αληθια διδα ϲκειϲ και ου μελι ϲοι περι ουδενοϲ ου γαρ βλεπιϲ ειϲ προ ϲωπον ανω ν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ειπε ουν ημιν τι ϲοι δοκι εξεϲτιν δουναι κ η ϲον καιϲαρι η ου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "γνουϲ δε ο ιϲ ιϲ την πο νηριαν αυτων ει πεν τι με πιραζετε ϋποκριται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "επιδιξα τε μοι το νομιϲμα του κηνϲου οι δε προϲηνεγκαν αυ τω δηναριον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και λεγι αυτοιϲ τινοϲ η ϊκων αυτη και η επιγραφη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "λεγου ϲι κεϲαροϲ τοτε λεγι αυτοιϲ α ποδοτε ουν τα κε ϲαροϲ καιϲαρι και τα του θυ τω θω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και ακουϲαντεϲ ε θαυμαϲαν και αφ ε τεϲ αφ ε τεϲ αυτον απηλθ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "και εν εκινη τη η μερα προϲηλθον αυτω ϲαδδουκαιοι οι λεγον τεϲ μη ειναι αναϲτα ϲιν και επηρωτη ϲαν αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "λεγον τεϲ διδαϲκαλε μω ϲηϲ ειπεν · εαν τιϲ αποθανη μη εχων τεκνα επιγαμβρευϲι ο α δελφοϲ αυτου τ η γυνεκα γυναικα αυτου και αναϲτηϲι ϲπερμα τω αδελφω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ηϲαν δε παρ ημιν ε πτα αδελφοι και ο πρωτοϲ γημαϲ ε τελευτηϲεν και μη εχων ϲπερμα αφη κεν την γυνεκα γυναικα αυ του τω αδελφω αυ του",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "ομοιωϲ και ο δευτεροϲ και ο τρι τοϲ εωϲ των επτα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ϋϲτερον δε παντ ω απεθανεν η γυνη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "εν τη αναϲταϲι ο υ τινοϲ των επτα ε ϲτε γυνη παντεϲ γαρ εϲχον αυτην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και αποκριθιϲ ο ιϲ ειπεν αυτοιϲ πλα ναϲθαι μη ϊδοτεϲ ταϲ γραφαϲ μηδε την δυναμιν του θυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "εν γαρ τη αναϲταϲι ουτε γαμουϲι ου τε γαμιζονται αλ λ ωϲ αγγελοι θυ εν τω ουνω ο υνω ειϲιν ειϲ [1 chars] ειϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "περι δε τηϲ αναϲτα ϲεωϲ [1 chars] ϲταϲεωϲ αναϲταϲεωϲ των νεκρ ω ουκ ανεγνωτε το ρηθεν ϋμιν ϋπο του θυ λεγοντοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "εγω ειμι ο θϲ αβρααμ και θϲ ϊϲακ ϊϲαακ και θϲ ϊακωβ ουκ εϲτιν θϲ νεκρων αλλα ζωντων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "και ακουϲαντεϲ οι οχλοι εξεπληϲϲ ο το επι τη διδαχη αυτου :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "οι δε φαριϲε οι φαριϲαιοι ακουϲαντεϲ οτι εφιμωϲε τουϲ ϲαδ δουκεουϲ ϲυνη χθηϲαν επι το αυτο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "και επηρωτηϲεν ειϲ εξ αυτων νομι κοϲ πιραζων αυτ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "διδαϲκαλε ποια ε τολη μεγαλη εν τω νομω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "ο δε εφη αυτω · αγαπηϲιϲ κν τον θν ϲου εν ολη τη καρ δια ϲου και εν ολη τη ψυχη ϲου και ε ν ολη τη διανοια ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "αυτη εϲτιν η μεγα λη και πρωτη εντο λη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "δευτερα δε δε ομοια αυ τη αγαπηϲιϲ τον πληϲιον ϲου ωϲ ϲεαυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "εν ταυτεϲ τεϲ ταυταιϲ ταιϲ ταυταιϲ ταιϲ δυϲ ι εντολεϲ εντολαιϲ ο νομοϲ ολοϲ ο νομοϲ κρεμαται και οι προφητε προφηται ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "ϲυνηγμενων δε των φαριϲεων ε πηρωτηϲεν αυτουϲ ο ιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "λεγων τι ϋμ ι δοκι περι του χυ τι νοϲ υϲ εϲτιν λεγου ϲιν αυτω δ α δ δ α δ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "λεγι αυτοιϲ πωϲ ουν δ α δ δ αδ εν πνι καλι κν αυτον λεγων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "ειπεν κϲ κϲ τω κω κω μ(ου) καθου εκ δεξιων μου εωϲ αν θω τουϲ εχθρουϲ ϲου ϋποκατω των πο δων ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "ει ουν δα δ καλι αυ τον κν πωϲ υϲ αυ του εϲτιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "και ουδειϲ εδυνατο αποκριθηνε αποκριθηναι αυ τω λογον ουδε ε τολμηϲεν τιϲ απ ε κινηϲ τηϲ ημεραϲ επερωτηϲε αυτον ουκετι",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 23,
      "verses": [
        {
          "verse": 1,
          "original": "τοτε ο ιϲ ιϲ ελαληϲεν τοιϲ οχλοιϲ και τοιϲ μαθητεϲ μαθηταιϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "λεγων · επι τηϲ μωϋϲεωϲ καθεδραϲ εκαθιϲ α οι γραμματειϲ και οι φαριϲεοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "παντα ουν οϲα εαν ειπω ϲιν ϋμιν ποιηϲα τε ποιηϲατε κ(αι) τηρειτε ποιηϲατε κ(αι) τηρειτε κατα δε τα εργα αυ των μη ποιειτε λεγουϲιν γαρ και ου ποιουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "δεϲμευ ουϲιν δε φορτια με γαλα βαρεα και επι τιθεαϲιν επι τουϲ ω μουϲ των ανων ανω ν αυτοι δε τω δακτυ λω αυτων ου θε λουϲιν κινηϲε αυ τα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "παντα δε τα εργα αυ των ποιουϲιν προϲ το θεαθηνε τοιϲ ανοι ϲ πλατυνουϲι γαρ τα φυλακτηρι α αυτων και μεγα λυνουϲι τα κραϲπε δα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "φιλουϲι δε την πρωτοκλιϲιαν ταϲ πρωτοκλιϲιαϲ ε τοιϲ διπνοιϲ και ταϲ πρωτοκα θεδριαϲ εν τεϲ ϲυ ναγωγεϲ ταιϲ ϲυναγωγαιϲ ταιϲ ϲυναγωγεϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "και τουϲ αϲπαϲμουϲ εν τεϲ αγορεϲ ταιϲ αγοραιϲ και καλειϲθε ϋπο των α νων ραββει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ϋμειϲ δε μη κληθητε ραββει ειϲ γαρ εϲτιν ϋμ ω ο καθηγητηϲ διδαϲκαλοϲ καθηγητηϲ παντεϲ δε ϋμιϲ α δελφοι εϲτε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και πρ α μη καλεϲη τε ϋμων επι τηϲ ειϲ γαρ εϲτιν ϋμ ω ο πη ρ ο ουρανιοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "μηδε κληθητε κα θηγηται ειϲ γαρ εϲ τιν ϋμων ο καθη γητηϲ ο χϲ χϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ο δε μιζων υ μων εϲται διακονοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "οϲτιϲ δε ϋψωϲει εαυτον ταπινω θηϲετε και οϲτιϲ ταπινωϲει εαυτ ο ϋψωθηϲετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ουαι δε υ μιν γραμμα τιϲ και φαριϲαιοι ϋποκριτε οτι κλιε τε την βαϲιλιαν των ουρανων εμ προϲθεν των αν νω ανω ν ϋμειϲ γαρ ουκ ιϲερ χεϲθε ειϲερχεϲθε ουδε τουϲ ει ϲερχομενουϲ α φιετε ειϲελθειν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ουαι ϋμιν γραμμα τιϲ και φαριϲαιοι ϋ ποκριται οτι περι αγετε την θαλαϲϲ α και την ξηραν ποι ηϲε ενα προϲηλυ τον και οταν γενη τε ποιειτε αυτον υν γεεννηϲ διπλο τερον ϋμων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ουαι υμιν οδηγοι οι τυφλοι οι λεγοντεϲ οϲ αν ομοϲη εν τω ναω ουδεν εϲτ ι οϲ δ αν ομοϲη εν τω χρυϲω του ναου [1 chars] ὁφιλει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "μωροι και τυφλοι τιϲ γαρ μι ζων εϲτιν ο χρυ ϲοϲ η ο ναοϲ ο αγι αϲαϲ τον χρυϲον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "και οϲ αν ομοϲη εν τω θυϲιαϲτη ριω ουδεν εϲτιν οϲ δ αν ομοϲη εν τω δωρω τω επα νω αυτου οφιλι ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "τυφλοι τι γαρ μιζ ο το δωρον · η το θυ ϲιαϲτηριον το αγι αζον το δωρον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "ο ουν ομοϲαϲ εν τω θυϲιαϲτηριω ομνυϊ εν αυτω κ(αι) εν παϲι τοιϲ επανω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "και ο ομοϲαϲ εν τω ναω ομνυει εν αυ τω και εν τω κατοι κουντι αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και ο ομοϲαϲ εν τω ουνω ομνυ ι εν τω θρονω του θυ και εν τω καθη μενω επανω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ουαι ϋμιν γραμμα τιϲ και φαριϲαιοι ϋ ποκριτε οτι απο δεκατουτε το ηδυ οϲμον και το ανη θον και το κυμιν ο και αφηκατε τα βα ρυτερα του νομου την κριϲιν το ελεοϲ και την πι ϲτιν ταυτα εδει ποι ηϲε κακινα μη α φινε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "οδηγοι τυφλοι οι οι διϋλιζοντεϲ τον κωνωπα την δε καμηλον καταπι νοντεϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ουαι ϋμιν γραμμα τιϲ και φαριϲεοι ϋ ποκριτε οτι καθα ριζετε το εξωθ ε του ποτηριου κε τηϲ παροψιδοϲ εϲωθεν δε γεμου ϲιν εξ αρπαγηϲ κε και ακραϲιαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "φαριϲαιε τυφλε καθαριϲον πρωτ ο πρωτ ο το εντοϲ του ποτη ριου και τηϲ παροψι δοϲ ϊνα γενηται κε και το εντοϲ εκτοϲ αυτ ω καθαρον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ουαι ϋμιν γραμμα τιϲ και κε φαριϲεοι ϋ ποκριτε οτι παρο μοιαζετε ταφοιϲ κεκονιαμενοιϲ οιτινεϲ εξωθεν μεν φε νοντε ωρεοι ε ϲωθεν δε γεμου ϲιν οϲτεων νε κρων κε και παϲηϲ α καθαρϲιαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "ουτωϲ κε και ϋμιϲ εξωθ ε μεν φενεϲθε τοιϲ α νοι ϲ δικεοι δικαιοι εϲω θεν δε εϲτε μεϲ τοι με ϲτοι μεϲ τοι ϋποκριϲεωϲ κε ανομιαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ουαι ϋμιν γραμμα τιϲ και φαριϲεοι φαριϲαιοι ϋ ποκριτε οτι οικο δομειτε τουϲ τα φουϲ των προφη των και κοϲμιτε τα μνημια των δικεων δικαιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και λεγε ται ει ημεθα εν τεϲ ημερεϲ ταιϲ ημεραιϲ τ ω πρω ν ημων ου κ αν ημεθα κοι νωνοι αυτων εν τω αιματι τ ω προφητων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "ωϲ τε μαρτυριτε εαυ τοιϲ οτι ϋϊοι εϲτε των φονευϲαντ ω τουϲ προφηταϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "κ(αι) υ̇μιϲ πληρωϲατε το μετρον των πα τερων ϋμων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "οφιϲ γεννηματα εχιδνων πωϲ φυγητε απο τηϲ κριϲεωϲ τηϲ ωᵨ γεεννηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "δια τουτο ϊδου εγω αποϲτελλω προϲ ϋ μαϲ προφηταϲ και ϲοφουϲ και γραμ ματιϲ εξ αυτων αποκτενιτε και ϲταυρωϲετε εξ αυ των και κ(αι) εξ αυτων μαϲτιγω ϲετε εν τεϲ ταιϲ ϲυνα γωγεϲ ϋμων και διωξετε απο πο λεωϲ ειϲ πολιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ο πωϲ αν αν ελθη εφ υ μαϲ παν παν αιμα δικεον δικαιον εκχυννομενον επι τηϲ γηϲ απο του αιματοϲ αβελʼ του δικαιου εωϲ του αιματοϲ ζαχαριου ϋϊου βαραχιου ον εφονευϲατε μεταξυ του ναου και του θυϲιαϲτη ριου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "αμην λεγω ϋμιν ηξι ταυτα παντα επι την γενεαν ταυτην",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "ι ηλμ ι ηλμ τουϲ προ φηταϲ αποκτενου ϲα η αποκτενουϲα τουϲ προφηταϲ η αποκτενουϲα τουϲ προφηταϲ και λιθοβολου ϲα τουϲ απεϲταλ μενουϲ προϲ αυ την ποϲακιϲ ηθεληϲα επιϲυναγειν επιϲυναγαγειν τα τε κνα ϲου ον τροπ ο ορνιϲ επιϲυναγι επιϲυναγει τα νοϲϲια αυτηϲ εαυτηϲ ϋπο ταϲ πτερυγαϲ και ουκ ηθεληϲα τε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "ϊδου αφιεται ϋ μιν ο οικοϲ υμ ω ερημοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "λεγω γαρ ϋμιν ου μη με ϊδητε απ αρ τι εωϲ αν ειπητε ευλογημενοϲ ο ερχομενοϲ εν ο νοματι κυ",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 24,
      "verses": [
        {
          "verse": 1,
          "original": "και εξελθων ο ιϲ απο του ϊερου επο ρευετο και προϲ ηλθον οι μαθητε αυτου επιδιξε αυ τω ταϲ οικοδομαϲ του ϊερου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "ο δε αποκριθειϲ ει πεν αυτοιϲ ου βλε πετε ταυτα παντα αμην λεγω ϋμιν ου μη αφεθη ωδε λιθοϲ επι λιθον οϲ ου καταλυθηϲε ται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "καθημενου δε αυ του επι του ορουϲ τ ω ελεων προϲηλθ ο αυτω οι μαθηται καθ ϊδιαν λεγον τεϲ ειπε ημιν πο τε ποτε ταυτα εϲτε και τι το ϲημιον τηϲ ϲηϲ παρουϲιαϲ και ϲυν τελιαϲ του αιωνοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και αποκριθειϲ ο ιϲ ειπεν αυτοιϲ βλεπε τε μη τιϲ ϋμαϲ πλα νηϲη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "πολλοι γαρ ελευϲοντε επι τω ονοματι μου λεγοντεϲ εγω ειμι χϲ και πολλουϲ πλανηϲουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "μελληϲετε δε ακου ειν πολεμουϲ κ(αι) ακοαϲ πολεμ ω ορατε μη θροειϲθε δι γαρ γενεϲθαι αλ λ ουπω εϲτιν το τε λοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "εγερθηϲετε γαρ ε θνοϲ επ εθνοϲ κ(αι) βαϲιλια επι βαϲιλι αν και εϲοντε ϲιϲμοι και λιμοι κατα τοπουϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "παντα δε ταυτα αρ χη ωδινων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "τοτε παραδωϲουϲ ι ϋμαϲ ειϲ θλιψιν κ(αι) α ποκτενουϲιν ϋμαϲ και εϲεϲθε μιϲου μενοι ϋπο παντων των ε θνων δια το ονο μα μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και τοτε ϲκανδαλι ϲθηϲονται πολλοι και αλληλουϲ πα ραδωϲουϲιν ειϲ θλι ψιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "και πολλοι ψευδο προφηται εγερθη ϲονται και πολλουϲ πλανηϲουϲι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και δι α το πληθυνθηνε πληθυνθηναι την ανομιαν ψυ γηϲετε η αγαπη τ ω πολλων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "ο δε ϋπομιναϲ ειϲ τελοϲ ουτοϲ ϲωθη ϲετε :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και κηρυχθη ϲετε τουτο το ευ αγγελιον τηϲ βα ϲιλιαϲ ειϲ ολην τ η οικουμενην ειϲ μαρτυριον παϲι τοιϲ εθνεϲιν και τοτε ηξι το τελοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "οταν ουν δε ϊδητε το βδελυγμα τηϲ ερη μωϲεωϲ το ρηθ ε δια ι η λ δανιηλ του προφη του εϲτοϲ εν τοπω αγιω ο αναγινω ϲκων νοειτω :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "το τε οι εν τη ϊουδεα ϊουδαια φευγετωϲαν επι τα ορη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ο επι του δω ματοϲ μη καταβα τω καταβητω αραι το τα εκ τηϲ οι κιαϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "και ο ε τω αγρω μη επιϲτρε ψατω οπιϲω αρε αραι το ϊματιον αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "ουαι δε ταιϲ εν γαϲτρι εχουϲεϲ εχουϲαιϲ και ταιϲ θηλαζουϲεϲ θηλαζουϲαιϲ εν ε κινεϲ εκιναιϲ ταιϲ ημερεϲ ημεραιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "προϲευχεϲθε δε ι να μη γενηται η φυ γη ϋμων χιμω νοϲ μηδε ϲαββα τω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "εϲτε γαρ τοτε μεγαλη οια ουκ εγε νετο απ αρχηϲ κο ϲμου εωϲ του ν υ ουδʼ ου μη γενητε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και ει μη εκολοβω θηϲαν αι ημεραι ε κιναι ουκ αν εϲω θη παϲα ϲαρξ δια δε τουϲ εκλεκτουϲ εκο λοβωθηϲαν κολοβωθηϲονται αι η μεραι εκιναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "τοτε εαν τιϲ ϋμιν ειπη ϊδου ωδε ο χϲ χϲ η ωδε μη πιϲτευϲη τε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "εγερθηϲονται γαρ ι ψευδοχριϲτοι και ψευδοπροφη τε και δωϲουϲιν ϲημια και τερατα ωϲτε πλανηθη ναι ει δυνατον και τουϲ εκλεκτουϲ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "ϊ δου ‾̷‾ προειρηκα ϋμ ι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "εαν ουν ειπωϲιν υ μ ι ϊδου εν τη ερημω εϲτιν μη εξελθη τε ϊδου εν τοιϲ ταμι οιϲ μη πιϲτευϲη τε :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "ωϲπερ γαρ η αϲτρα πη εξερχετε απο ανατολων και φαινετε εωϲ δυϲμ ω ουτωϲ εϲτε η πα ρουϲια του υυ του ανο υ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "που οπου οπου εαν ῆ το ϲωμα πτωμα εκι ϲυναχθηϲον τε οι αετοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "ευθεωϲ δε μετα τ η θλιψιν των ημερ ω εκινων ο ηλιοϲ ϲκοτιϲθηϲετε και η ϲεληνη ου δωϲι το φεγγοϲ αυτηϲ κ(αι) οι αϲτερεϲ πεϲο υ ται εκ του ουνου και αι δυναμιϲ τ ω ο υνω ν ϲαλευθη ϲονται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και τοτε φα νηϲετε το ϲημι ο του υυ του ανου εν ουρανω και τοτε κοψ ο τε παϲε ε παϲαι αι φυλαι τηϲ γηϲ : και οψοντε τ ο υν του ανου ανου ερχο μενον επι των νε φελων του ουνου μετα δυναμεωϲ κ(αι) δοξηϲ πολληϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "και αποϲτελι τουϲ αγγελουϲ αυτου με τα ϲαλπιγγοϲ μεγα ληϲ και επιϲυναξι επιϲυναξουϲ ι τουϲ εκλεκτουϲ αυ του εκ των · δ · ανεμ ω απ ακρων ουραν ω εωϲ ακρων αυτ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "απο δε τηϲ ϲυκηϲ μα θετε την παραβολ η οταν ηδη ο κλαδοϲ αυτηϲ γενητε απα λοϲ και τα φυλλα εκ φυη γινωϲκετε ο τι εγγυϲ το θεροϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "ουτωϲ και ϋμιϲ ο ταν ϊδητε ταυτα παντα γινωϲκετε οτι εγγυϲ εϲτιν επι θυραιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "αμην λεγω ϋμιν ου μη παρελθη η γενεα αυτη εωϲ παντα ταυτα γενη τε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ο ου ν οϲ και η γη παρελευϲεται οι δε λογοι μου ου μη παρελθωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "περι δε τηϲ ημε> ραϲ εκεινηϲ και > ωραϲ ουδειϲ οιδ ε οιδ ε ουδε οι αγγελοι τ ω ουρανων ουδε > ο υιοϲ ουδε ο υιοϲ ει μη ο πα τηρ μονοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "ωϲπερ δε αι ημεραι του > νωε ουτωϲ εϲται η παρουϲια του υυ του α θρωπου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "ωϲ γαρ η ϲαν εν ταιϲ ημε ραιϲ ταιϲ προ του κατακλυϲμου τρω γοντεϲ και πειν ο τεϲ κ(αι) γαμουντεϲ κ(αι) γαμιζοντεϲ αχρι ηϲ ημεραϲ ειϲηλ> θεν νωε ειϲ την κιβωτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "και ουκ ε γνωϲαν ο εωϲ ηλθεν ο κατακλυ ϲμοϲ και ηρεν α> πανταϲ ουτωϲ ε ϲται και η παρου ϲια του υϊου του > ανθρωπου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "τοτε εϲονται δυο δυο εϲονται ε τω αγρω ειϲ παραλαμ βανετε και ειϲ αφι ετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "δυο αληθου> ϲαι εν τω μυλω μια παραλαμβανεται και μια αφιεται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "γρηγορειτε ουν ο τι ουκ οιδατε ποια ημερα ο κϲ κϲ υμων ερχεται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "εκεινο δε γινωϲκε τε οτι ει ηδει ο οικο δεϲποτηϲ ποια φυ λακη ο κλεπτηϲ ερ χεται εγρηγορηϲ ε αν και ουκ αν ειαϲ ε διορυχθηναι την οικιαν αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "δια > τουτο και ϋμειϲ γινεϲθε ετοιμοι οτι η ου δοκειτε ωρα ο ϋϊοϲ του αν θρωπου ερχεται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "τιϲ αρα εϲτιν ο πιϲτοϲ δουλοϲ και φρονι μοϲ ον καταϲτη> ϲει ο κϲ επι τηϲ οι> κιαϲ αυτου του δου ναι αυτοιϲ την τρο φην εν καιρω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "μακαριοϲ ο δουλοϲ εκεινοϲ ον ελθ ω ο κϲ αυτου ευρη> ϲει ουτωϲ ποιο υ τα ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "αμην λεγω ϋμ ι οτι επι παϲιν τοιϲ ϋπαρχουϲιν αυτου καταϲτηϲει αυτ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "εαν δε ειπη ο κακοϲ δουλοϲ εκινοϲ εν τη καρ> δια εαυτου χρονι ζει μου ο κϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 49,
          "original": "και αρ ξηται τυπτειν τουϲ ϲυνδουλουϲ εαυ> του εϲθιη δε και πι νη μετα των με θυοντων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 50,
          "original": "ηξει ο κϲ του δουλου εκει νου εν ημερα η ου προϲδοκα και εν ω ρα η ου γινωϲκει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 51,
          "original": "κ(αι) διχοτομηϲει αυ τον και το μεροϲ αυ του μετα των ϋπο κριτων θηϲει εκει εϲται ο κλαυθμοϲ και ο βρυγμοϲ των οδοντων",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 25,
      "verses": [
        {
          "verse": 1,
          "original": "τοτε ομοιωθηϲεται η βαϲιλεια των ου ρανων δεκα παρθε νοιϲ αιτινεϲ λαβου ϲαι ταϲ λαμπαδαϲ αυτων εξηλθον ειϲ ϋπαντηϲιν του νυμφιου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "πεντε δε εξ αυτων ηϲαν μωραι και πεντε > φρονιμοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "αι γαρ μω ραι λαβουϲαι ταϲ λαμ παδαϲ ουκ ελαβον μεθ εαυτων ελαι ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "αι δε φρονιμοι ελα βον ελαιον εν τοιϲ αγγιοιϲ μετα των λαμπαδων εαυτ ω εαυτ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "χρονιζοντοϲ δε > του νυμφιου ενυ ϲταξαν παϲαι και εκαθευδον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "μεϲηϲ δε νυκτοϲ κραυγη γεγονεν ϊδου ο νυμ φιοϲ εξερχεϲθε ειϲ απαντηϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "τοτε ηγερθηϲαν πα ϲαι αι παρθενοι εκει ναι και εκοϲμηϲ α ταϲ λαμπαδαϲ εαυ των",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "αι δε μωραι ταιϲ φρονιμοιϲ ειπον δοτε ημιν εκ του ελαιου ϋμων οτι αι λαμπαδεϲ ημ ω ϲβεννυνται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "απεκριθηϲαν δε αι φρονιμοι λεγουϲαι μηποτε ουκ αρκε ϲη ϋμιν και ημιν πορευεϲθε μαλλ ο προϲ τουϲ πωλο υ ταϲ και αγοραϲατε εαυταιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "απερχομε νων δε αυτων αγο ραϲαι ηλθεν ο νυμ φιοϲ και αι ετοιμοι ειϲηλθον μετ αυ του ειϲ τουϲ γαμουϲ και εκλιϲθη η θυρα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ϋϲτερον δε ερχον ται και αι λοιπαι παρ θενοι λεγουϲαι κε κε ανοιξον η ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "ο δε αποκριθειϲ ει πεν αμην λεγω ϋμιν ουκ οιδα ϋμαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "γρηγορειτε ουν οτι ουκ οιδατε τ η ημεραν ουδε την ωραν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "ωϲπερ γαρ ανθρω ποϲ αποδημων εκαλεϲεν τουϲ ϊ διουϲ δουλουϲ και παρεδωκεν αυ> τοιϲ τα ϋπαρχον> τα αυτου ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "και ω μεν εδωκεν πεντε τα λαντα ω δε δυο ˙ ω δε εν · εκαϲτω κατα την ϊδιαν δυναμ ι και απεδημηϲεν ευθεωϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "πορευθειϲ δε ο τα πεντε αλαντα ταλαντα λαβων ηργαϲατο ειργαϲατο εν αυτοιϲ και εποι ηϲεν εκερδηϲεν εκερδηϲεν αλλα πεντε ταλαντα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ωϲαυτωϲ κ(αι) ο τα δυο εκερδηϲ ε αλλα δυο ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ο δε το ε λαβων απελθων ωρυξεν γην και ε κρυψεν το αργυρι ο του κυριου αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "μετα δε πολυν χρο νον ερχεται ο κυ ριοϲ των δουλ ω εκεινων και ϲυναι ρει λογον μετ αυτ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "και προϲελθων ο τα πεντε λαβων προϲ ηνεγκεν αλλα πεν τε ταλαντα λεγων ˙ κυριε πεντε ταλ α τα μοι παρεδωκαϲ ϊδε αλλα πεντε > ταλαντα εκερδηϲα ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "εφη αυτω ο κυριοϲ αυτου ευ δουλε α γαθε και πιϲτε επι ολιγα ηϲ πιϲτοϲ επι πολλων ϲε κα ταϲτηϲω ειϲελθε ειϲ την χαραν του κυριου ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "προϲελθων δε και ο τα δυο ταλαντα λαβ ω ειπεν δυο ταλαν> τα μοι παρεδωκαϲ ϊδε αλλα δυο ταλαν τα εκερδηϲα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "εφη αυτω ο κυριοϲ αυτου ευ δουλε α γαθε και πιϲτε επι ολιγα ηϲ πιϲτοϲ > επι πολλων ϲε κα ταϲτηϲω ειϲελθε ειϲ την χαραν του κυριου ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "προϲελθων δε και ο το εν ταλαντον ει ληφωϲ ειπεν κε εγνων ϲε οτι αν> θρωποϲ αυϲτηροϲ ει θεριζων οπου ουκ εϲπειραϲ και > ϲυναγων οθεν ου διεϲκορπιϲαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και φοβηθειϲ απελθ ω εκρυψα το ταλαν τον ϲου εν τη γη ϊ δε εχειϲ το ϲον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "αποκριθειϲ δε ο κυ ριοϲ αυτου ειπεν αυτω πονηρε δου λε και οκνηρε ηδειϲ οτι θεριζω οπου ουκ εϲπειρα και ϲυ ναγω οθεν ου διε ϲκορπιϲα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "εδει ϲε ουν βαλειν τα αρ γυρια το αργυριον μου τοιϲ τρα πεζειταιϲ και ελθ ω εγω εκομιϲαμην αν το εμον ϲυν το κω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "αρατε ουν απ αυ του το ταλαντον και δοτε τω εχ ο τι τα δεκα ταλαν τα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "τω γαρ εχοντι παντι δοθηϲεται και περιϲϲευθηϲε ται του δε μη εχ ο τοϲ και ο εχει αρθη ϲεται απ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "κ(αι) τον αχριον δουλ ο εκβαλετε ειϲ το > ϲκοτοϲ το εξωτερ ο εκει εϲται ο κλαυ> θμοϲ και ο βρυγμοϲ των οδοντων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "οταν δε ελθη ο ϋιοϲ του ανθρωπου εν τη δοξη αυτου και παντεϲ οι αγγελοι μετ αυτου τοτε > καθιϲει επι θρονου δοξηϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "και > ϲυναχθηϲονται εμπροϲθεν αυτου παντα τα εθνη κ(αι) αφοριϲει αφοριεει αυτουϲ απ αλληλων ωϲ> περ ο ποιμην αφο ριζει τα προβατα απο των εριφων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "και ϲτηϲει τα μ ε προβατα εκ δεξι ω τα δε εριφια εξ ευ ωνυμων αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "τοτε ερει ο βαϲιλευϲ τοιϲ εκ δεξιων αυ του δευτε οι ευλο γημενοι του π ρ ϲ πρ ϲ μου κληρονομη ϲατε την ητοιμα ϲμενην υμιν βα ϲιλειαν απο κατα βοληϲ κοϲμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "επι ναϲα γαρ και εδω κατε μοι φαγειν ˙ εδιψηϲα και επο> τιϲατε με ξενοϲ > ημην και ϲυνηγα γετε με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "γυμνοϲ και περιεβαλετε με ˙ ηϲθενηϲα κ(αι) επεϲκεψαϲθε με εν φυλακη ημ η και ηλθατε προϲ εμε ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "τοτε αποκριθηϲ ο ται αυτω οι δικαι οι λεγοντεϲ κε κε πο τε ϲε ειδομεν πει> νωντα και εθρεψα μεν · η διψωντα και εποτιϲαμεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "ποτε δε ϲε ειδο> μεν ξενον και ϲυ νηγαγομεν · η γυ μνον και περιεβα λομεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "ποτε δε ϲε αϲθενη η εν φυλακη και ηλθομεν προϲ ϲε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "και αποκριθειϲ ο > βαϲιλευϲ ερει αυτοιϲ αμην λεγω ϋμιν εφ οϲον εποιηϲα τε ενι τουτων τ ω αδελφων μου τ ω ελαχιϲτων εμοι εποιηϲατε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "τοτε ερει και τοιϲ > εξ ευωνυμων ϋ παγετε απ εμου > κατηραμενοι > ειϲ το πυρ το αι> ωνιον το ητοι> μαϲμενον τω δι αβολω και τοιϲ αγγελοιϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "επιναϲα γαρ και ουκ εδωκατε μοι φαγειν εδιψηϲα και ουκ εποτιϲα τε με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "ξενοϲ ημ η και ου ϲυνηγαγε τε με γυμνοϲ κ(αι) ου περιεβαλεται αϲθενηϲ κ(αι) εν φυλακη και > ουκ επεϲκεψαϲθε με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "τοτε αποκριθη> ϲονται αυτω οι αυτοι κ(αι) αυτοι λεγοντεϲ κε πο τε ϲε ειδομεν πι νωντα η διψων τα η ξενον η γυμνον η αϲθενη η εν φυλακη και ουκ ηδιηκο> νηϲαμεν ϲοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "τοτε αποκριθηϲε ται αυτοιϲ λεγων αμην λεγω ϋμιν εφ οϲον ουκ ε> ποιηϲατε ενι του των των ελαχι> ϲτων ουδε εμοι εποιηϲατε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "και > απελευϲονται > ουτοι ειϲ κολαϲ ι αιωνιον οι δε δι καιοι ειϲ ζωην > αιωνιον",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 26,
      "verses": [
        {
          "verse": 1,
          "original": "και εγενετο οτε ε τελεϲεν ο ιϲ παν ταϲ τουϲ λογουϲ του τουϲ ειπεν τοιϲ μα θηταιϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "οιδα τε οτι μετα δυο ημε ραϲ το παϲχα γινεται και ο ϋϊοϲ του ανο υ παραδιδοται ειϲ το ϲταυρωθηναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "τοτε ϲυνηχθηϲαν οι αρχϊερειϲ και οι πρεϲβυτεροι του λαου ειϲ την αυλ η του αρχιερεωϲ του λεγομενου καϊαφα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "και ϲυνεβουλευ> ϲαντο ϊνα τον ιν δολω κρατηϲω ϲιν και αποκτει> νωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "ελεγον δε μη εν > τη εορτη ϊνα μη > θορυβοϲ γενηται ε τω λαω ‾̷‾",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "του δε ιυ γενομε νου εν βηθανια > εν οικια ϲιμω>> νοϲ του λεπρου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "προϲηλθεν αυτω γυνη εχουϲα αλα βαϲτρον μυρου πολυτιμου και κα τεχεεν επι τηϲ κεφαληϲ αυτου ανακιμενου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "ϊδοντεϲ δε οι μα θηται ηγανακτη ϲαν λεγοντεϲ ειϲ τι η απωλια αυτη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "εδυνατο γαρ του το πραθηναι πολ λου και δοθηναι πτωχοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "γνουϲ δε ο ιϲ ειπ ε αυτοιϲ τι κοπουϲ παρεχετε τη γυνε κι γυναικι εργον γαρ γαρ καλ ο ηργαϲατο ειργαϲατο ειϲ εμε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "παντοτε γαρ τουϲ πτωχουϲ εχετε μεθ εαυτων εμε δε ου παντοτε ε χετε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "βαλουϲα γαρ αυτη το μυρον τουτο επι του ϲω ματοϲ μου προϲ το ενταφιαϲαι με εποιηϲεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "αμην λεγω ϋμ ι οπου εαν κηρυ χθη το ευαγγελι ο τουτο εν ολω τω κοϲμω λαληθη ϲετε και ο εποιη ϲεν αυτη ειϲ μνη μοϲυνον αυτηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "τοτε πορευθιϲ ειϲ των · ιβ · ο λεγομε νοϲ ϊουδαϲ ϊϲκα ριωτηϲ προϲ τουϲ αρχϊεριϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "ειπεν τι ι θελεται μοι δω νε και εγω ϋμιν παραδωϲω αυτ ο οι δε εϲτηϲαν αυ τω · λ · αργυρια",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "και απο τοτε εζητι ευ κεριαν ϊνα αυτον παραδω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "τη δε πρωτη των αζυμων προϲηλ θον οι μαθηται τω ιυ λεγοντεϲ που θελιϲ ετοιμαϲω μεν ϲοι φαγιν το παϲχα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "ο δε ειπεν ϋπαγετε ειϲ την πολιν προϲ τον δινα · και ειπα τε αυτω ο διδαϲκα λοϲ λεγει ο καιροϲ μου εγγυϲ εϲτιν προϲ ϲε ποιω το πα ϲχα μετα των μα θητων μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "και ε ποιηϲαν οι μαθη ται ωϲ ϲυνεταξ ε αυτοιϲ ο ιϲ και ητοι μαϲαν το παϲχα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "οψιαϲ δε γενομε νηϲ ανεκιτο μετα των · ιβ · μαθητ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "και εϲθιοντων αυτων λεγι αμ η λεγω ϋμιν οτι ειϲ εξ ϋμων παραδω ϲι με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "και λυπουμε ϲφοδρα ηρξ α το ηρξ α το λεγιν αυτω ειϲ εκαϲτοϲ μητι εγω ειμι κε κε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ο δε αποκριθιϲ ει πεν ο εμβαψαϲ με τ εμου την χιρα εν τω τρυβλιω . ουτοϲ με παραδωϲει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ο μεν υϲ υϲ του ανου ανου ϋπαγι καθωϲ γε γραπται περι αυτου · ουαι δε τω ανω ανω ε κεινω δι ου ο υϲ υϲ του α νο υ παραδι δοται καλον ην αυτω ει ουκ εγεν νηθη ο ανοϲ εκι νοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "αποκριθιϲ δε ϊου δαϲ ο παραδιδουϲ αυτον ειπεν μη τι εγω ειμι ραββει λεγει αυτω ο ιϲ ϲυ ειπαϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "εϲθιοντων δε αυ των λαβων ο ιϲ αρ τον και ευλογηϲαϲ εκλαϲεν και εδι δου δουϲ δουϲ τοιϲ μαθητεϲ μαθηταιϲ ειπεν λαβετε φα γετε τουτο εϲτιν το ϲωμα μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "και λαβων ποτηρι ον και ευχαριϲτη ϲαϲ εδωκεν αυ τοιϲ λεγων πιετε εξ αυτου παντεϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "τουτο γαρ εϲτιν το αιμα μου τηϲ δια θηκηϲ το περι πολ λων εκχυννομε νον ειϲ αφεϲιν αμαρτιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "λεγω δε ϋμιν ου μη πιω απ αρτι εκ του τουτου γενημα τοϲ τηϲ αμπελου εωϲ τηϲ ημεραϲ εκινηϲ οταν αυ το πινω μεθ ϋμ ω κενον εν τη βαϲι λεια του πρϲ μου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και ϋμνηϲαντεϲ εξηλθον ειϲ το ο ροϲ των ελαιων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "τοτε λεγι αυτοιϲ ο ιϲ παντεϲ ϋμιϲ ϲκανδαλιϲθηϲε ϲθαι εν εμοι εν τη νυκτι ταυτη γεγραπται γαρ πα ταξω τον ποιμενα και διαϲκορπιϲθη ϲοντε διαϲκορπιϲθηϲονται τα προβατα τηϲ ποιμνηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "μετα δε το εγερθη νε με προαξω ϋμαϲ ειϲ την γαλιλαιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "αποκριθειϲ δε ο πετροϲ ειπεν αυ τω ει κ(αι) ϲκαν δαλιϲθηϲονται ε ϲοι εγω ουδεποτε ϲκανδαλιϲθηϲομε ϲκανδαλιϲθηϲομαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "εφη αυτω ο ιϲ αμ η λεγω ϲοι οτι εν ταυ τη τη νυκτι πριν αλεκτορα φωνη ϲαι τριϲ με απαρνη ϲη απαρνηϲη με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "λεγι αυτω ο πετροϲ καν δεη με ϲυν ϲοι αποθανιν ου μη ϲε απαρνηϲομαι ομοιωϲ και παν τεϲ οι μαθηται ει πον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "τοτε ερχεται μετ αυ των ο ιϲ ειϲ χωρι ον λεγομενον γεθ ϲημανι και λεγι τοιϲ μαθηταιϲ αυ του καθιϲατε εωϲ απελθων εκι προ ϲευξωμε προϲ ευξωμε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "και παραλαβων τ ο πετρον και τουϲ δυ ο ϋϊουϲ ζεβεδεου ηρξατο λυπιϲθε και αδημονιν ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "τοτε λεγει αυτοιϲ περιλυποϲ εϲτ ι η ψυχη μου εωϲ θανατου μινατε ωδε και γρηγορι τε μετ εμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "και προϲελθων μικρον επεϲεν επι προϲωπον αυ του προϲευχομε νοϲ και λεγων περ μου ει δυνατον ε ϲτιν εϲ τιν παρελθατω α π εμου το ποτηρι ον τουτο πλην ου χ ωϲ εγω θελω αλ λ ωϲ ϲυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "και ερχετε προϲ τουϲ μαθηταϲ και ευριϲκι αυτουϲ καθευδον ταϲ και λεγι τω πε τρω ουτωϲ ουκ ϊϲχυ ϲατε μιαν ωραν γρη γορηϲε μετ εμου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "γρηγορειτε και προϲ ευχεϲθε ϊνα μη ει ϲελθηται ειϲ πιραϲμ ο το μεν πν α προθυ μον η δε ϲαρξ αϲθε νηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "παλιν εκ δευτερου απελθων προϲη ϋξατο ο ιϲ λεγων περ μου ει ου δυνατε του το παρελθιν εαν μη αυτο πιω γενηθη τω το θελημα ϲου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "και ελθων παλιν ευρεν αυτουϲ καθευ δονταϲ ηϲαν γαρ αυ των οι οφθαλμοι βεβαρημενοι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "και αφιϲ αυτουϲ πα λιν απελθων προϲ ηϋξατο τον αυτον εκ τριτου εκ τριτου τον αυτον λογον ει πων παλιν :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "τοτε ερχετε προϲ τουϲ μαθηταϲ και λεγι αυτοιϲ : καθευδετε το λοιπον και ανα παυεϲθε ϊδου ηγγι κεν η ωρα και ο υϲ του ανο υ παραδιδο ται ειϲ χιραϲ αμαρτω λων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "εγειρεϲθε αγωμεν ϊδου ηγγικεν ο πα ραδιδων παραδιδουϲ με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "και ετι αυτου λαλουν τοϲ ϊδου ϊουδαϲ ειϲ των · ιβ · ηλθεν και μετ αυτου οχλοϲ πολυϲ μετα μαχε ρων και ξυλων α πο των αρχιερε ω αρχϊερε ω και πρεϲβυτερων του λαου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "ο δε παραδιδουϲ αυ τον εδωκεν αυτοιϲ ϲημιον λεγων ο ν ο εαν φιληϲω αυ τοϲ εϲτιν κρατηϲα ται αυτον ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 49,
          "original": "και ευθε ωϲ προϲελθων τω ιυ ειπεν χαιρε ραββει και κατεφι ληϲεν αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 50,
          "original": "ο δε ειπεν αυτω εταιρε εφ ο παρει τοτε προϲελθοντεϲ επεβαλον ταϲ χι ραϲ επι τον ιν και ε κρατηϲαν αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 51,
          "original": "κ(αι) κ(αι) ϊδου ειϲ των μετα ιυ εκτιναϲ την χι ρα απεϲπαϲε την μαχαιραν αυτου κ(αι) παταξαϲ τον δουλ ο του αρχϊερεωϲ αφι λεν αυτου το ωτι ο ωτι ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 52,
          "original": "τοτε λεγει αυτω ο ιϲ ιϲ αποϲτρεψον την μαχαιραν ϲου ειϲ τ ο τοπον αυτηϲ παν τεϲ γαρ οι λαβοντεϲ μαχαιραν εν μα χαιρη απολουντε απολουνται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 53,
          "original": "η δοκειϲ οτι ου δυ ναμαι παρακαλεϲε τον π ρ α πρα μου και πα ραϲτηϲει μοι ωδε αρτι πλειω πλειουϲ δωδε κα λεγιωνων αγ γελουϲ λεγιωνων αγγελων λεγαιωνων αγγελων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 54,
          "original": "πωϲ ουν πληρωθωϲιν αι γραφε γραφαι οτι ουτωϲ δι δει γενεϲθε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 55,
          "original": "εν εκεινη τη ωρα ειπεν ο ιϲ τοιϲ ο χλοιϲ ωϲ επι ληϲτ η εξηλθατε μετα μαχαιρων και ξυ λων ϲυλλαβειν με · καθ ημεραν εν τω ϊερω εκαθεζομ η διδαϲκων και ου κ εκρατηϲατε με",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 56,
          "original": "τουτο δε ολον γεγο νεν ϊνα πληρωθω ϲιν πληρωθο̣ϲιν αι γραφε γραφαι των προ φητων τοτε οι μαθηται π α τεϲ αφεντεϲ αυτον εφυγον :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 57,
          "original": "οι δε κρατη ϲαντεϲ τον ιν απη γαγον προϲ καϊαφ α τον αρχϊερεα οπου οι γραμματιϲ και οι πρεϲβυτεροι ϲυνη χθηϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 58,
          "original": "ο δε πετροϲ ηκολου θι αυτω μακροθεν εωϲ τηϲ αυληϲ του αρχϊερεωϲ και ειϲ ελθων εϲω εκαθη το μετα των ϋπηρε των ϊδειν το τελοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 59,
          "original": "οι δε αρχϊεριϲ και το ϲυνεδριον ολον ε ζητουν ψευδομαρ τυριαν κατα του ιυ οπωϲ αυτον θανα τωϲωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 60,
          "original": "και ου χ ευρον πολλων προϲελθοντων ψευδομαρτυρ ω ψευδομαρτυρ ω ϋϲτερον δε προϲελ θοντεϲ β",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 61,
          "original": "ειπαν ου τοϲ εφη δυναμαι καταλυϲε τον να ο του θυ και δια τρι ω ημερων αυτον οι κοδομηϲαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 62,
          "original": "και αναϲταϲ ο αρχι ερευϲ ειπεν αυτω [1 chars] ουδεν αποκρινη τι ουτοι ϲου καταμαρ τυρουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 63,
          "original": "[1 chars] ο δε ιϲ εϲιωπα και ο αρχϊερευϲ ειπεν αυτω εξορκιζω ϲε κατα του θυ του ζωντοϲ ϊνα ημιν ειπηϲ ει ϲυ ει ο χϲ ο υϲ του θυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 64,
          "original": "λεγει αυτω ο ιϲ ϲυ ει παϲ πλην λεγω ϋ μιν απ αρτι οψεϲ θε τον υν του ανο υ καθημενον εκ δε ξιων τηϲ δυναμε ωϲ και ερχομενον επι των νεφελ ω νεφελ ω του ο υνου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 65,
          "original": "τοτε ο αρχιερευϲ διερ ρηξεν τα ϊματια αυ του και λεγει ϊδε λεγων ε βλαϲφημηϲεν τι ετι χριαν εχομεν μαρτυριων ϊδε ν υ ν υ ηκουϲατε την βλα ϲφημιαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 66,
          "original": "τι ϋμιν δοκει οι δε αποκρι θεντεϲ ειπαν ειπον ενο χοϲ θανατου εϲτ ι εϲτ ι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 67,
          "original": "ενεπτυϲαν ειϲ το προϲωπον αυ του και εκολαφιϲαν αυτον οι δε εραπιϲ α εραπιϲ α",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 68,
          "original": "λεγοντεϲ προφη τευϲον ημιν χε χε τιϲ εϲτιν ο παιϲαϲ ϲε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 69,
          "original": "ο δε πετροϲ εκαθη το εξω εν τη αυλη και προϲηλθεν αυ τω μια παιδιϲκη λεγουϲα και ϲυ ηϲθα μετα ιυ του γαλιλεου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 70,
          "original": "ο δε ηρνηϲατο εμ προϲθεν παντ ω παντ ω λεγων ουκ οιδα τι λεγειϲ :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 71,
          "original": "εξελθοντα δε ειϲ τον πυλωνα ειδεν αυτον αλλη και λεγει τοιϲ εκει ουτοϲ ην μετα ιυ του ναζωραιου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 72,
          "original": "και παλιν ηρνηϲα το μετα ορκου ου κ οιδα τον ανο ν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 73,
          "original": "μετα μικρον δε προϲελθοντεϲ οι εϲτωτεϲ ειπον τω πετρω αληθωϲ και ϲυ εξ αυτων ει · και γαρ η λαλια ϲου δηλον ϲε ποιει ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 74,
          "original": "τοτε ηρξατο κατα θεματιζειν και ο μνυειν οτι ουκ οι δα τον ανον και ευ θεωϲ αλεκτωρ ε φωνηϲεν :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 75,
          "original": "και ε μνηϲθη ο πετροϲ του ρηματοϲ ιυ ει ρηκοτοϲ οτι πριν αλεκτορα φωνη ϲαι τριϲ απαρνηϲη με · και εξελθων εξω εκλαυϲεν πικρωϲ",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 27,
      "verses": [
        {
          "verse": 1,
          "original": "πρωϊαϲ δε γενο μενηϲ ϲυμβου λιον ελαβον π α τεϲ οι αρχϊεριϲ και οι πρεϲβυτεροι του λαου κατα του ιυ ωϲτε θανατω ϲαι αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και δη ϲαντεϲ αυτον α πηγαγον : και πα ρεδωκαν πιλατω τω ηγεμονι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "τοτε ϊδων ϊουδαϲ ο παραδιδουϲ αυ τον οτι κατεκρι θη μετεμεληθη μεταμεληθιϲ και εϲτρεψεν εϲτρεψεν απεϲτρεψεν τα λ · αργυρια τοιϲ αρ χϊερευϲι και πρε ϲβυτεροιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "λεγ ω ημαρτον παραδουϲ αιμα αθωον οι δε ειπον τι προϲ ημαϲ ϲυ οψη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "και ριψαϲ τα λ αργυρι α ειϲ τον ναον α νεχωρηϲεν και απελθων απηγ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "οι δε αρχϊερειϲ λα βοντεϲ τα αργυρι α ειπον ουκ εξεϲτ ι βαλιν αυτα ειϲ τ ο κορβαναν επι τι μη αιματοϲ εϲτ ι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "ϲυμβουλιον δε λα βοντεϲ ηγοραϲαν εξ αυτων τον αγρ ο του κεραμεωϲ ειϲ ταφην τοιϲ ξενοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "διο εκληθη ο αγροϲ εκινοϲ αγροϲ αι ματοϲ εωϲ τηϲ ϲη μερον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και τοτε επληρωθη το ρηθεν δια ϊερεμι ου του προφητου > λεγοντοϲ και ελα βον > τα · λ · αργυρια τ η > τιμην του τετιμη μενου > ον ετιμη ϲαντο > απο ϋϊων > ιηλ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "και εδωκα αυ τα > ειϲ τον αγρον του > κεραμεωϲ καθα > ϲυνεταξεν μοι κϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "ὁ δε ιϲ εϲταθη εμ προϲθεν του ηγε μονοϲ : και επηρω τηϲεν αυτον ο ο ηγε μων λεγων ϲυ ει ο βαϲιλευϲ των ϊου δαιων ο δε ιϲ εφη ϲυ λεγιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και εν τω κατηγο ριϲθε αυτον ϋπο των αρχϊερεων και πρεϲβυτερ ω ουδεν απεκρινα το",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "τοτε λεγι αυτω ο πιλατοϲ ουκ ακου ειϲ ποϲα ϲου κατα μαρτυρουϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και ουκ απεκριθη αυ τω προϲ ουδε εν ρη μα ωϲτε θαυμαζ ι τον ηγεμονα λι α λι α",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "κατα δε εορτην ει ωθει ο ηγεμων απολυειν ενα τω οχλω δεϲμιον ο ο παρητουντο ηθελον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "ειχ ο ειχ ο δε τον τε τοτε δεϲμιον επιϲημον λεγο μενον βαραββαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "ϲυνηγμενων ουν αυτων ειπεν αυτοιϲ ο ο πιλατοϲ τινα θε λετε απολυϲω υμ ι βαραββαν · η ιν ιν τον λεγομενον χν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "η δι γαρ οτι δια φθον ο παρεδωκαν αυτ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "καθημενου δε αυ του επι του βηματοϲ απεϲτιλεν προϲ αυ τον η γυνη αυτου λεγουϲα μηδεν ϲοι και τω δικαιω εκι νω πολλα γαρ επα ϲημερον κατ ο ναρ δι αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "οι δε αρχϊεριϲ και οι πρεϲβυτεροι επιϲ α τουϲ οχλουϲ ϊνα αι τηϲωνται τον βα ραββαν τον δε ιν ιν α πολεϲωϲιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 21,
          "original": "αποκριθειϲ δε ο η γεμων ειπεν αυ τοιϲ τινα θελετε απο των · β · απολυ ϲω ϋμιν οι δε ειπ ο τον βαραββαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 22,
          "original": "λεγι αυτοιϲ ο πιλα τοϲ τι ουν ποιηϲω ιν τον λεγομενον χν λεγουϲιν παν τεϲ ϲταυρωθητω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 23,
          "original": "ο δε εφη τι γαρ κακ ο εποιηϲεν οι δε περιϲϲω περιϲϲωϲ εκρα ζον λεγοντεϲ ϲταυ ρωθητω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 24,
          "original": "ϊδων δε ο πιλατοϲ οτι ουδεν ωφελι αλλα μαλλον θορυ βοϲ γεινεται λαβ ω λαβ ω ϋδωρ απενιψατο ταϲ χιραϲ απεναν τι του οχλου λεγων · αθωοϲ ειμι απο του αιματοϲ του δικαιου τουτου υμειϲ δε ο ψεϲθαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 25,
          "original": "και αποκριθιϲ παϲ ο λαοϲ ειπεν το αιμα αυτου εφ ημαϲ και επι τα τεκνα ημων ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 26,
          "original": "τοτε απελυϲεν αυτοιϲ τον βαραββαν τον δε ιν φραγελλωϲαϲ παρεδωκεν αυτοιϲ ϊνα ϲταυ ρωθη",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 27,
          "original": "τοτε οι ϲτρατιωται του ηγεμονοϲ πα ραλαβοντεϲ τον ιν ειϲ το πραιτωριον ϲυνηγαγον επ αυτ ο ολην την ϲπιραν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 28,
          "original": "και εκδυϲαντεϲ ενδυϲαντεϲ εκδυϲαντεϲ αυ τον · χλαμυδα κοκ κινην περιεθηκ α αυτω ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 29,
          "original": "και πλεξαν τεϲ ϲτεφανον εξ α κανθων επεθη καν επι τηϲ κεφα ληϲ αυτου · και κα λαμον εν τη δεξι α αυτου · και γονυ πετηϲαντεϲ εμ προϲθεν αυτου ενε πεξαν αυτω λεγον τεϲ χαιρε ο βαϲιλευϲ των ϊουδαιων :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 30,
          "original": "και εμπτυϲαντεϲ ειϲ αυ τον ελαβον τον κα λαμον και ετυπτ ο ειϲ την κεφαλην αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 31,
          "original": "και οτε ενεπε ξαν αυτω · εκδυϲ α τεϲ αυτον την χλα μυδα ενεδυϲαν αυτον τα ϊματια και απηγαγον αυτον ειϲ το ϲταυ ρωϲαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 32,
          "original": "εξερχομενοι δε ευ ρον ανον κυρηνε ον ονοματι ϲιμω να τουτον ηγγαρευ ϲαν ϊνα αρη τον ϲταυ ρον αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 33,
          "original": "και ελθοντεϲ ειϲ το πον λεγομενον γολγοθα ο εϲ τιν κρανιου τοποϲ λεγομενοϲ λεγομενοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 34,
          "original": "εδω καν αυτω πιν πιειν οιν ο μετα χοληϲ μεμιγ μενον και γευϲα μενοϲ ουκ ηθελη ϲεν ηθελεν ηθεληϲεν πιν πιειν πιειν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 35,
          "original": "ϲταυρωϲ α τεϲ δε αυτον διεμε ριϲαντο τα ιματια αυ του βαλοντεϲ κλη ρον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 36,
          "original": "και καθημενοι ετηρουν αυτον ε κει",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 37,
          "original": "και επεθηκαν επα νω τηϲ κεφαληϲ αυ του την αιτιαν αυ του γεγραμμενην ουτοϲ εϲτιν ιϲ ο βα ϲιλευϲ των ϊουδε ων",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 38,
          "original": "τοτε ϲταυρουνται ϲυ ν ϲ υ αυτω δυο ληϲτε ληϲται ειϲ εκ δεξιων και ειϲ εξ ευωνυμ ω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 39,
          "original": "οι δε παραπορευο μενοι εβλαϲφη μουν αυτον κινο υ τεϲ ταϲ κεφαλαϲ αυ των",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 40,
          "original": "και λεγοντεϲ ο καταλυων τον να ον και εν τριϲιν η μεραιϲ οικοδομ ω ϲωϲον ϲεαυτον ˙ ει υϊοϲ ει του θυ και καταβηθι απο του ϲταυρου :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 41,
          "original": "ομοι ωϲ οι αρχϊεριϲ εμ πεζοντεϲ μετα των πρεϲβυτερ ω και γραμμαται ω ελεγον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 42,
          "original": "αλλουϲ ε ϲωϲεν εαυτον ου δυναται ϲωϲαι · βα ϲιλευϲ ι ηλ εϲτιν · καταβατω νυν α πο του ϲταυρου και πιϲτευϲωμ ε επ αυτον ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 43,
          "original": "πεποι θεν επι τον θν · ρυϲαϲθω νυν · ει θελι αυτον ˙ ειπ ε γαρ οτι θεου ειμι υϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 44,
          "original": "το δʼ αυτο και οι λη ϲται οι ϲυνϲταυ ρωθεντεϲ ϲυν αυτω ωνειδιζ ο αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 45,
          "original": "απο δε εκτηϲ ω ραϲ ϲκοτοϲ εγενε το εφ ολην την γην εωϲ ωραϲ ενα τηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 46,
          "original": "περι δε την ε νατην ωραν ανε βοηϲεν ο ιϲ φω νη μεγαλη λεγ ω ελωϊ ελωϊ λεμα ϲαβαχθανει του τ εϲτιν θε μου θε μου · ϊνατι με εγ κατελιπεϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 47,
          "original": "τινεϲ δε των εκει εϲτηκοτων ακου ϲαντεϲ ελεγον η λιαν φωνι ουτοϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 48,
          "original": "και ευθεωϲ δραμ ω ειϲ · και λαβων ϲπογ γον πληϲαϲ τε ο ξουϲ και περιθειϲ καλαμω . εποτιζ ο̣ εποτιζ ε αυτον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 49,
          "original": "οι δε λοιποι ελεγ ο ελεγ ο αφεϲ ϊδωμεν ει ερχεται ηλιαϲ ϲω ϲαι ϲωϲων αυτον αλλοϲ δε λαβων λογχ η λογχ η ενυξεν αυτου τ η πλευραν και εξηλ θεν ϋδωρ και αι μα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 50,
          "original": "ο δε ιϲ παλιν κρα ξαϲ φωνη μεγα λη αφηκεν το πνα ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 51,
          "original": "και ϊδου το κατα πεταϲμα του να ου εϲχιϲθη ειϲ δυο ανωθεν εωϲ κατω · και η γη εϲι ϲθη εϲιϲ θη και αι πετραι εϲχιϲθηϲαν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 52,
          "original": "κ(αι) τα μνημια ανεωχθηϲαν και πολλα ϲωματα των κεκοιμημε νων αγιων ηγερ θηϲαν ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 53,
          "original": "και εξελ θοντεϲ εκ των μνημιων μετα την εγερϲιν αυτου ειϲ την αγιαν πο λιν ενεφανιϲθη ϲαν πολλοιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 54,
          "original": "ο δε εκατονταρχηϲ και οι μετ αυτου τηρουντεϲ τον ιν ϊδοντεϲ τον ϲιϲμ ο και τα γενομενα εφοβηθηϲαν ϲφο δρα λεγοντεϲ αλη θωϲ υϲ ην του θυ θυ υϲ ην ουτοϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 55,
          "original": "ηϲαν δε κακει γυ ναικεϲ πολλαι απο μακροθεν θεωρουϲαι αιτι νεϲ ηκολουθηϲ α τω ιυ απο τηϲ γα λιλαιαϲ διακονου ϲαι αυτω",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 56,
          "original": "εν αιϲ ην μαρια η μαγδαληνη κ(αι) μαρια η του ϊακω βου και η μαρια η ιωϲηφ και η μαρια η ιωϲηφ μηρ και η μητηρ των ϋϊων ζεβε δεου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 57,
          "original": "οψιαϲ δε γενομε νηϲ ηλθεν ανοϲ πλουϲιοϲ απο α ριμαθαιαϲ τουνο μα ϊωϲηφʼ οϲ και αυτοϲ εμαθητευ θη τω ιυ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 58,
          "original": "ουτοϲ προϲελθων τω πιλατω ητηϲατο το ϲωμα του ιυ το τε ο πιλατοϲ εκε λευϲεν αποδοθη νε αποδοθηναι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 59,
          "original": "και λαβων το ϲω μα ο ϊωϲηφʼ ενε τυλιξεν αυτο ϲιν δονι καθαρα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 60,
          "original": "και εθηκεν εν τω καινω αυτου μνη μιω ο ελατομη ϲεν εν τη πετρα και προϲκυλιϲαϲ λιθον μεγαν τη θυρα του μνημι ου απηλθεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 61,
          "original": "ην δε εκει μαρι αμʼ η μαγδαληνη και η αλλη μαρια καθημενε καθημεναι απε ναντι του ταφου ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 62,
          "original": "τη δε επαυριον η τιϲ εϲτιν μετα τ η παραϲκευην ϲυ νηχθηϲαν ϲ υ ηχθηϲαν οι αρ χϊερειϲ και οι φα ριϲαιοι προϲ πι λατον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 63,
          "original": "λεγοντεϲ · κε εμνηϲθημ ε οτι εκινοϲ ο πλα νοϲ ειπεν ετι ζ ω μετα τριϲ ημεραϲ εγιρομαι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 64,
          "original": "κελευ ϲον ουν αϲφαλι ϲθηναι τον ταφ ο εωϲ τηϲ τριτηϲ ημεραϲ μηποτε ελθοντεϲ οι μαθη ται κλεψουϲιν αυ τον και ειπωϲιν τω λαω ηγερθη α πο των νεκρων και εϲται η εϲχα τη πλανη χειρ ο χειρ ο τηϲ πρωτηϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 65,
          "original": "εφη δε αυτοιϲ ο πι λατοϲ εχετε κουϲ τωδιαν · ϋπαγετε αϲφαλιϲαϲθαι ωϲ οιδατε",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 66,
          "original": "οι δε πορευ θεντεϲ ηϲφαλιϲ α το τον ταφον ϲφρα γιϲαντεϲ τον λιθ ο μετα τηϲ κουϲτω διαϲ",
          "translation": "",
          "footnotes": []
        }
      ]
    },
    {
      "chapter": 28,
      "verses": [
        {
          "verse": 1,
          "original": "οψε δε ϲαββατων τη επιφωϲκουϲη ειϲ μιαν ϲαββατ ω ηλθεν μαριαμʼ η μαγδαληνη · και η αλλη μαρια · θεω ρηϲαι τον ταφ ο",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 2,
          "original": "και ϊδου ϲιϲμοϲ ε γενετο μεγαϲ · αγ γελοϲ γαρ κυ κατα βαϲ εξ ο υν ου ο υνου και προϲελθων απε κυλιϲε τον λιθ ο και εκαθητο ε πανω αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 3,
          "original": "ην δε η ειδεα αυτου ωϲ αϲτραπη και το ε δυμα αυτου λευ κον ωϲ η χιων :",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 4,
          "original": "απο δε του φοβου αυ του εϲιϲθηϲαν οι τηρουντεϲ και ε γενηθηϲαν ωϲ νεκροι",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 5,
          "original": "αποκριθειϲ δε ο αγγελοϲ ειπεν [1 chars] ταιϲ γυναιξιν μη φοβηθηται φοβιϲθαι ϋμιϲ · οιδα γαρ οτι ιν ιν τον εϲταυρω μενον ζητειτε ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 6,
          "original": "ουκ εϲτιν ωδε · η γερθη γαρ καθωϲ ειπεν δευτε ειδε τε τον τοπον οπου εκειτο ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 7,
          "original": "και ταχυ πορευθιϲαι ειπα τε τοιϲ μαθηταιϲ αυτου οτι ηγερθη απο των νεκρ ω νεκρ ω και ϊδου προαγει ϋμαϲ ειϲ την γαλι λαιαν εκει αυτ ο αυτ ο οψεϲθαι · ϊδου ει πα ειπον υμιν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 8,
          "original": "και απελθουϲαι ταχυ απο του μνη μιου μετα φοβου και χαραϲ μεγαληϲ εδραμον απαγγι λαι τοιϲ μαθηταιϲ αυτου",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 9,
          "original": "και ϊδου ιϲ υπηντη ϲεν απηντηϲεν αυταιϲ λεγ ω χαιρετε αι δε προϲ ελθουϲαι εκρατη ϲαν αυτου τουϲ πο δαϲ και προϲεκυ νηϲαν αυτω ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 10,
          "original": "τοτε λεγει αυταιϲ ο ιϲ μη φοβειϲθε ϋπαγεται απαγγι λατε τοιϲ αδελφοιϲ μου ϊνα ελθωϲιν απελθωϲιν ειϲ την γαλιλαιαν και εκει με οψονται",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 11,
          "original": "πορευομενων δε αυτων ϊδου τι νεϲ τηϲ κουϲτω διαϲ ελθοντεϲ ειϲ την πολιν ανηγ γιλαν τοιϲ αρχϊε ρευϲιν απαντα τα γενομενα",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 12,
          "original": "και ϲυναχθεντεϲ μετα των πρεϲβυ τερων ϲυμβουλι ον τε εποιηϲαν εποιηϲαν κ(αι) λαβοντεϲ λαβοντεϲ εποιηϲαν κ(αι) λαβοντεϲ αργυρια ϊκανα ε δωκαν τοιϲ ϲτρα τιωταιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 13,
          "original": "λεγοντεϲ οτι ειπατε οι μαθη ται αυτου νυκτοϲ ελθοντεϲ εκλε ψαν αυτον ημ ω κοιμωμενων ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 14,
          "original": "και εαν ακουϲθη τουτο επι του η γεμονοϲ ημειϲ πειϲομεν και ϋ μαϲ αμεριμνουϲ ποιηϲωμεν",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 15,
          "original": "οι δε λαβοντεϲ τα αρ γυρια εποιηϲαν ωϲ καθωϲ εδιδαχθηϲαν και εφημιϲθη ο λογοϲ ουτοϲ πα ρα ϊουδαιοιϲ εωϲ μεχρι τηϲ ϲημερον",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 16,
          "original": "οι δε ενδεκα μαθη ται επορευθηϲαν ειϲ την γαλιλαι α γαλιλαι α ειϲ το οροϲ ου ε ταξατο αυτοιϲ ο ιϲ",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 17,
          "original": "και ϊδοντεϲ αυτ ο προϲεκυνηϲαν οι δε εδιϲταϲαν ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 18,
          "original": "και προϲελθων ο ιϲ ελαληϲεν αυτοιϲ λε γων εδοθη μοι παϲα εξουϲια εν ουρανω και επι γηϲ ·",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 19,
          "original": "πορευθεντεϲ μαθητευϲατε π α τα τα εθνη βαπτι ζοντεϲ αυτουϲ · ειϲ το ονομα του π ρ ϲ πρϲ και του ϋϊου και του αγιου πνϲ ˙",
          "translation": "",
          "footnotes": []
        },
        {
          "verse": 20,
          "original": "διδαϲκοντεϲ αυ τουϲ τηριν παντα οϲα ενετιλαμην ϋμιν και ϊδου εγω ειμι μεθ υμων παϲαϲ ταϲ ημε ραϲ εωϲ τηϲ ϲυν τελειαϲ του αιω νοϲ ·:· ⌇﹏",
          "translation": "",
          "footnotes": []
        }
      ]
    }
  ]
}